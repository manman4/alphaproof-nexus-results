  have h3 : pureOSequence (dipOrderIdeal3 t) (3 * t - 2) = t + 5 := pureOSeq_3t_minus_2 t ht
  have hsocle : socleDegree (dipPureOrderIdeal3 t ht) = 3 * t := socleDegree_dipPureOrderIdeal3 t ht
