  have hg_deg : totalDeg g = 3 * t := by
    exact h_pure g (dipMonomialFat t) hg_mem_max h_fat_max |>.trans h_fat_deg
  have h_le : m ≤ g := mem_divisorsFinset_iff.mp hmg
  have heq : m = g := by delta totalDeg divisorsFinset IsPure Monomial at*
                         exact (le_antisymm h_le fun and=>not_lt.mp fun and' =>by simp_all [ Finsupp.sum_of_support_subset (s:=⊤), ( Finset.sum_lt_sum (fun R L=>h_le R) ⟨and, _⟩).ne',<-hdeg])
  rw [heq]
  rw [maximalMonomials_dipOrderIdeal3 t ht] at hg_mem_max
  exact hg_mem_max

lemma pureOSeq_3t (t : ℕ) (ht : 5 ≤ t) : pureOSequence (dipOrderIdeal3 t) (3 * t) = t := by
  unfold pureOSequence
  have h1 : (dipOrderIdeal3 t).carrier.filter (fun m => totalDeg m = 3 * t) = maximalMonomials (dipOrderIdeal3 t) := by
    ext m
