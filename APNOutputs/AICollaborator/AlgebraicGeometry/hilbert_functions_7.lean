/-- Monomials in `r` variables as finitely supported exponent vectors on `Fin r`. -/
abbrev Monomial (r : ℕ) := Fin r →₀ ℕ

/-- Total degree of a monomial (sum of all exponents). -/
def totalDeg {r : ℕ} (m : Monomial r) : ℕ :=
  m.sum fun _ e => e

/-- A finite order ideal of monomials, closed downward under divisibility.
    Divisibility of monomials uses the standard pointwise `≤` on `Finsupp`. -/
structure OrderIdeal (r : ℕ) where
  carrier : Finset (Monomial r)
  downward_closed : ∀ {m n : Monomial r}, n ∈ carrier → m ≤ n → m ∈ carrier

lemma OrderIdeal.mem_of_dvd {r : ℕ} (I : OrderIdeal r) {m n : Monomial r}
    (hn : n ∈ I.carrier) (hmn : m ≤ n) : m ∈ I.carrier :=
  I.downward_closed hn hmn

/-- The finite set of divisors of a monomial, i.e. the principal lower set `{m | m ≤ g}`. -/
noncomputable def divisorsFinset {r : ℕ} (g : Monomial r) : Finset (Monomial r) :=
  Finset.Iic g

lemma mem_divisorsFinset_iff {r : ℕ} {m g : Monomial r} :
    m ∈ divisorsFinset g ↔ m ≤ g :=
  Finset.mem_Iic

/-- The finite order ideal generated by a finite set of monomials. -/
noncomputable def generatedOrderIdeal {r : ℕ} (G : Finset (Monomial r)) : OrderIdeal r where
  carrier := G.biUnion divisorsFinset
  downward_closed := by
    intro m n hn hmn
    rcases Finset.mem_biUnion.mp hn with ⟨g, hg, hng⟩
    exact Finset.mem_biUnion.mpr ⟨g, hg, mem_divisorsFinset_iff.2
      (le_trans hmn (mem_divisorsFinset_iff.1 hng))⟩

lemma mem_generatedOrderIdeal_iff {r : ℕ} {G : Finset (Monomial r)} {m : Monomial r} :
    m ∈ (generatedOrderIdeal G).carrier ↔ ∃ g ∈ G, m ≤ g := by
  constructor
  · intro hm
    rcases Finset.mem_biUnion.mp hm with ⟨g, hg, hmg⟩
    exact ⟨g, hg, mem_divisorsFinset_iff.1 hmg⟩
  · rintro ⟨g, hg, hmg⟩
    exact Finset.mem_biUnion.mpr ⟨g, hg, mem_divisorsFinset_iff.2 hmg⟩

/-- Maximality with respect to divisibility inside an order ideal. -/
def IsMaximalIn {r : ℕ} (I : OrderIdeal r) (m : Monomial r) : Prop :=
  m ∈ I.carrier ∧ ∀ n, n ∈ I.carrier → m ≤ n → n ≤ m

open Classical in
/-- The finite set of maximal monomials of an order ideal. -/
noncomputable def maximalMonomials {r : ℕ} (I : OrderIdeal r) : Finset (Monomial r) :=
  I.carrier.filter (fun m => IsMaximalIn I m)

/-- Purity: all maximal monomials have the same total degree. -/
def IsPure {r : ℕ} (I : OrderIdeal r) : Prop :=
  ∀ m n, m ∈ maximalMonomials I → n ∈ maximalMonomials I → totalDeg m = totalDeg n

/-- A pure order ideal packages an order ideal with purity and a nonempty maximal set. -/
structure PureOrderIdeal (r : ℕ) where
  ideal : OrderIdeal r
  isPure : IsPure ideal
  maximal_nonempty : (maximalMonomials ideal).Nonempty

/-- Type of a pure order ideal: the number of maximal monomials. -/
noncomputable def typePO {r : ℕ} (P : PureOrderIdeal r) : ℕ :=
  (maximalMonomials P.ideal).card

open Classical in
/-- Socle degree of a pure order ideal (the common degree of maximal monomials). -/
noncomputable def socleDegree {r : ℕ} (P : PureOrderIdeal r) : ℕ :=
  totalDeg (Classical.choose P.maximal_nonempty)

/-- The pure O-sequence: number of monomials of total degree `d` in an order ideal. -/
def pureOSequence {r : ℕ} (I : OrderIdeal r) (d : ℕ) : ℕ :=
  (I.carrier.filter fun m => totalDeg m = d).card

/-- Unimodality of a finite sequence `h` up to index `e`:
    there exists a peak `j ≤ e` such that `h` is weakly increasing
    on `[0, j]` and weakly decreasing on `[j, e]`. -/
def IsUnimodal (e : ℕ) (h : ℕ → ℕ) : Prop :=
  ∃ j, j ≤ e ∧
    (∀ i, i < j → h i ≤ h (i + 1)) ∧
    (∀ i, j ≤ i → i < e → h (i + 1) ≤ h i)

/-- Log-concavity up to degree `e`: `h_i² ≥ h_{i-1} h_{i+1}` for `i ∈ (0, e)`. -/
def IsLogConcaveUpTo (e : ℕ) (h : ℕ → ℕ) : Prop :=
  ∀ i ∈ Finset.Ioo 0 e, h (i - 1) * h (i + 1) ≤ (h i) ^ 2


/-- The monomial `xyz` encoded as an exponent vector in 3 variables. -/
noncomputable def mXYZ : Monomial 3 :=
  Finsupp.single (0 : Fin 3) 1 + Finsupp.single (1 : Fin 3) 1 + Finsupp.single (2 : Fin 3) 1

/-- The monomial `xz^2` encoded as an exponent vector in 3 variables. -/
noncomputable def mXZ2 : Monomial 3 :=
  Finsupp.single (0 : Fin 3) 1 + Finsupp.single (2 : Fin 3) 2

/-- The order ideal generated by the two monomials from P1. -/
noncomputable def GammaP1 : OrderIdeal 3 :=
  generatedOrderIdeal ({mXYZ, mXZ2} : Finset (Monomial 3))

/-- P1 statement: the degree-counting values for the generated order ideal are `(1, 3, 4, 2)`. -/
def ProblemP1 : Prop :=
  pureOSequence GammaP1 0 = 1 ∧
  pureOSequence GammaP1 1 = 3 ∧
  pureOSequence GammaP1 2 = 4 ∧
  pureOSequence GammaP1 3 = 2

-- Reformulation choice for P2:
-- instead of formal power series, we encode the generating-function claim at the
-- coefficient level using degree counts of divisors of the single generator.
/-- P2 (coefficient-level): one-generator degree counts match the product-formula coefficients. -/
def ProblemP2CoeffFormula : Prop :=
  ∀ {r : ℕ} (g : Monomial r) (d : ℕ),
    pureOSequence (generatedOrderIdeal ({g} : Finset (Monomial r))) d =
      ((divisorsFinset g).filter fun m => totalDeg m = d).card

/-- P2 consequence: every type-1 pure O-sequence is unimodal. -/
def ProblemP2Type1Unimodal : Prop :=
  ∀ {r : ℕ} (P : PureOrderIdeal r), typePO P = 1 →
    IsUnimodal (socleDegree P) (pureOSequence P.ideal)

/-- P2 consequence: every type-1 pure O-sequence is log-concave. -/
def ProblemP2Type1LogConcave : Prop :=
  ∀ {r : ℕ} (P : PureOrderIdeal r), typePO P = 1 →
    IsLogConcaveUpTo (socleDegree P) (pureOSequence P.ideal)

/-- P2 statement, split into a coefficient-level formula plus two sequence consequences. -/
def ProblemP2 : Prop :=
  ProblemP2CoeffFormula ∧ ProblemP2Type1Unimodal ∧ ProblemP2Type1LogConcave

/-- P3 statement: in codimension 3, first-half log-concavity up to `e / 2`.
Here `e` is the socle degree of the pure order ideal. -/
def ProblemP3 : Prop :=
  ∀ (P : PureOrderIdeal 3) (i : ℕ),
    0 < i →
    i ≤ socleDegree P / 2 →
      pureOSequence P.ideal (i - 1) * pureOSequence P.ideal (i + 1) ≤
        (pureOSequence P.ideal i) ^ 2

/-- P4 statement: codimension 3 and type 2 imply unimodality. -/
def ProblemP4 : Prop :=
  ∀ (P : PureOrderIdeal 3),
    typePO P = 2 →
    IsUnimodal (socleDegree P) (pureOSequence P.ideal)

/-- Helper predicate for open problems about non-log-concavity at fixed codimension/type. -/
def ExistsNonLogConcavePureOSeq (r t : ℕ) : Prop :=
  ∃ P : PureOrderIdeal r, typePO P = t ∧
    ¬ IsLogConcaveUpTo (socleDegree P) (pureOSequence P.ideal)

/-- P5: in codimension `3`, every type-`2` pure O-sequence is log-concave. -/
def ProblemP5 : Prop :=
  ∀ (P : PureOrderIdeal 3),
    typePO P = 2 →
    IsLogConcaveUpTo (socleDegree P) (pureOSequence P.ideal)

/-- P6: for fixed `r ≥ 5`, every type-`2` pure O-sequence in codimension `r` is unimodal. -/
def ProblemP6 (r : ℕ) : Prop :=
  5 ≤ r →
    ∀ (P : PureOrderIdeal r),
      typePO P = 2 →
      IsUnimodal (socleDegree P) (pureOSequence P.ideal)

/-- P7: threshold existence for eventual log-concavity failure in codimension `r`. -/
def ProblemP7 (r : ℕ) : Prop :=
  3 ≤ r →
    ∃ T : ℕ, 1 ≤ T ∧ ∀ t : ℕ, T ≤ t → ExistsNonLogConcavePureOSeq r t

/-- Helper: `t0` is a threshold after which all types admit a non-log-concave example. -/
def LCFailureThreshold (r t0 : ℕ) : Prop :=
  ∀ t : ℕ, t0 ≤ t → ExistsNonLogConcavePureOSeq r t

/-- P8: least threshold for eventual log-concavity failure in codimension `r`. -/
def ProblemP8 (r : ℕ) : Prop :=
  3 ≤ r →
    ∃ t0 : ℕ, IsLeast {t : ℕ | LCFailureThreshold r t} t0

-- EVOLVE-BLOCK-START
lemma not_log_concave_of_dip {r : ℕ} (P : PureOrderIdeal r) {i : ℕ}
    (hi1 : 0 < i) (hi2 : i < socleDegree P)
    (hdip : (pureOSequence P.ideal i)^2 < pureOSequence P.ideal (i - 1) * pureOSequence P.ideal (i + 1)) :
    ¬ IsLogConcaveUpTo (socleDegree P) (pureOSequence P.ideal) := by
  intro h
  have h_mem : i ∈ Finset.Ioo 0 (socleDegree P) := by
    rw [Finset.mem_Ioo]
    exact ⟨hi1, hi2⟩
  have h_lc := h i h_mem
  omega

def embedFin3 {r : ℕ} (hr : 3 ≤ r) : Fin 3 ↪ Fin r :=
  ⟨fun i => ⟨i.val, lt_of_lt_of_le i.isLt hr⟩, by
    intro i j hij
    ext
    exact Fin.mk.inj hij⟩

noncomputable def embedMonomial {r : ℕ} (hr : 3 ≤ r) (m : Monomial 3) : Monomial r :=
  m.mapDomain (embedFin3 hr)

lemma embed_totalDeg {r : ℕ} (hr : 3 ≤ r) (m : Monomial 3) :
    totalDeg (embedMonomial hr m) = totalDeg m := by
  delta totalDeg embedMonomial
  norm_num [ Finsupp.sum_mapDomain_index, mul_pow]

lemma embed_le_iff {r : ℕ} (hr : 3 ≤ r) (m n : Monomial 3) :
    embedMonomial hr m ≤ embedMonomial hr n ↔ m ≤ n := by
  delta embedMonomial Monomial at*
  norm_num[ Finsupp.mapDomain]
  norm_num[embedFin3, Finsupp.sum_of_support_subset (s:=⊤), Finsupp.single_apply, Finsupp.le_def]
  use fun and p=> (by norm_num[ Fin.val_injective.eq_iff] ∘(. ⟨ _,p.2.trans_le hr⟩)) and,by bound

noncomputable def embedOrderIdeal {r : ℕ} (hr : 3 ≤ r) (I : OrderIdeal 3) : OrderIdeal r :=
  generatedOrderIdeal (I.carrier.image (embedMonomial hr))

lemma embed_injective {r : ℕ} (hr : 3 ≤ r) : Function.Injective (embedMonomial hr) := by
  delta embedMonomial
  exact ( ·.mapDomain_injective fun and=>by simp_all)

lemma embed_pureOSequence {r : ℕ} (hr : 3 ≤ r) (I : OrderIdeal 3) (d : ℕ) :
    pureOSequence (embedOrderIdeal hr I) d = pureOSequence I d := by
  unfold pureOSequence
  have h1 : (embedOrderIdeal hr I).carrier = I.carrier.image (embedMonomial hr) := by
    norm_num[embedOrderIdeal, Finset.ext_iff]
    norm_num[generatedOrderIdeal]
    conv_rhs=>norm_num[embedMonomial, mem_divisorsFinset_iff]
    cases I
    norm_num[Monomial, Finsupp.mapDomain]at*
    norm_num[Monomial, Finsupp.sum_of_support_subset (s:=⊤), Finsupp.single_apply,Finsupp.le_def,Finsupp.ext_iff]at*
    revert‹Finset _›d
    delta Monomial
    norm_num(config := {singlePass:=1})[embedFin3]
    use fun and A B=>⟨fun ⟨a, M, H⟩=>⟨∑S: Fin (3),.single S (B (S.castLE hr)),A M fun and=>? _, fun and=>?_⟩,.imp fun and=>.imp_right (by rw [. ·])⟩
    · norm_num[ Finsupp.single_apply,(H _).trans, Fin.val_injective.eq_iff, Fin.castLE]
    norm_num+contextual[ Finsupp.single_apply, Finset.sum_eq_single (⟨and, _⟩: Fin _), Fin.ext_iff,(H and).trans,comm]
    cases lt_or_ge and.1 (3)
    · norm_num +contextual[comm, Fintype.sum_eq_single (by use and: Fin _), Fin.ext_iff]
    · exact (eq_bot_mono (H _) (Finset.sum_eq_zero fun and X=>if_neg (by valid ∘ Fin.mk.inj))).trans ( Finset.sum_eq_zero fun and c=>if_neg (by valid)).symm
  rw [h1]
  have h2 : (I.carrier.image (embedMonomial hr)).filter (fun m => totalDeg m = d) =
      (I.carrier.filter (fun m => totalDeg m = d)).image (embedMonomial hr) := by
    norm_num[embedMonomial,totalDeg, Finset.filter_image]
    norm_num[ Finsupp.sum_mapDomain_index ·]
  rw [h2]
  exact Finset.card_image_of_injective (I.carrier.filter (fun m => totalDeg m = d)) (embed_injective hr)

lemma embed_isPure {r : ℕ} (hr : 3 ≤ r) (I : OrderIdeal 3) (h : IsPure I) :
    IsPure (embedOrderIdeal hr I) := by
  delta embedOrderIdeal IsPure at *
  delta maximalMonomials totalDeg embedMonomial at*
  induction I
  simp_rw [generatedOrderIdeal,@forall_comm ↑(Monomial _), Finset.mem_filter] at h⊢
  simp_rw [ Finset.image_biUnion, and_imp,divisorsFinset] at h⊢
  simp_rw [ Finset.mem_biUnion, Finset.mem_Iic,IsMaximalIn] at h⊢
  use fun and⟨A, B, M⟩ R L ⟨a, C, N⟩p=>le_antisymm M (R.2 _ (( Finset.mem_biUnion.2 ⟨A, B,by norm_num⟩)) M)▸?_
  rw[le_antisymm N (p.2 _ (( Finset.mem_biUnion.2 ⟨a, C,by norm_num⟩)) N)]
  convert(h A B ⟨B, fun and K V=>_⟩ a C ⟨ C, fun and K V=>_⟩) using 1
  · norm_num[ Finsupp.sum_mapDomain_index]
  · norm_num[ Finsupp.sum_mapDomain_index]
  · simp_rw [Monomial, Finset.mem_biUnion, Finset.mem_Iic] at h R M V⊢
    exact ( Finsupp.mapDomain_injective fun and=>by norm_num) (le_antisymm.comp ( (R.2 _) ⟨ _, K,le_rfl⟩ (M.trans ( Finsupp.mapDomain_mono V))).trans M (Finsupp.mapDomain_mono V))▸le_rfl
  · obtain ⟨S, rfl⟩:=Nat.exists_eq_add_of_le' hr
    exact ( Finsupp.mapDomain_injective fun and=>by norm_num[funext_iff] (le_antisymm.comp ( (p.2 _) (( Finset.mem_biUnion.2 ⟨ _, K,by norm_num⟩)) (N.trans (a.mapDomain_mono V))).trans N (a.mapDomain_mono V))).le

lemma embed_maximal_nonempty {r : ℕ} (hr : 3 ≤ r) (I : OrderIdeal 3) (h : (maximalMonomials I).Nonempty) :
    (maximalMonomials (embedOrderIdeal hr I)).Nonempty := by
  norm_num[embedOrderIdeal, Iff,maximalMonomials,Set.nonempty_def] at h⊢
  norm_num [generatedOrderIdeal, false,IsMaximalIn, false, Finset.Nonempty] at h⊢
  delta embedMonomial divisorsFinset Monomial
  refine h.elim fun and⟨A, B⟩=>⟨_, ⟨ _,A, Finset.mem_Iic.2 le_rfl⟩, fun and R L K V=>.trans ( Finset.mem_Iic.1 K) ?_⟩
  cases I
  norm_num[Monomial, Finsupp.mapDomain] at B K V L⊢
  norm_num[Monomial, Finsupp.sum_of_support_subset (s:=⊤),Finsupp.single_apply, Finsupp.le_def] at B⊢
  use fun and=> Finset.sum_le_sum fun a s=> if I:_ then (if_pos I▸if_pos I▸B R L (fun M=>not_lt.1 fun and' =>absurd ((V.trans K and)) ? _) _)else (by push_cast[I])
  norm_num[I.symm, Finsupp.sum_of_support_subset (s:=⊤), Finsupp.single_apply,Function.Injective]
  norm_num[Monomial, Finsupp.sum_of_support_subset (s:=⊤), Finsupp.single_apply, Finsupp.le_def]at K V and'⊢
  use absurd.comp (V (embedFin3 hr M)).trans (K _) (by norm_num[mt hr.trans_eq, and', Finset.sum_ite, Finset.filter_eq'])

noncomputable def embedPureOrderIdeal {r : ℕ} (hr : 3 ≤ r) (P : PureOrderIdeal 3) : PureOrderIdeal r where
  ideal := embedOrderIdeal hr P.ideal
  isPure := embed_isPure hr P.ideal P.isPure
  maximal_nonempty := embed_maximal_nonempty hr P.ideal P.maximal_nonempty

lemma embed_maximalMonomials {r : ℕ} (hr : 3 ≤ r) (I : OrderIdeal 3) :
    maximalMonomials (embedOrderIdeal hr I) = (maximalMonomials I).image (embedMonomial hr) := by
  norm_num[embedOrderIdeal, false,embedMonomial, false,maximalMonomials, Finset.ext_iff]
  norm_num[generatedOrderIdeal,embedMonomial,embedFin3,IsMaximalIn, and_assoc]
  conv_rhs=>norm_num[divisorsFinset,@forall_comm<|Monomial r]
  use fun and=>⟨fun⟨⟨A, B, R⟩,H⟩=>? _,fun⟨A, B, C, e⟩=>e▸⟨ (by use A), fun and K V R M=>R.trans (? _)⟩⟩
  · cases R.antisymm (H A B _ le_rfl R)
    use A,B,fun R L S=>by_contra (absurd (H R L _ (by rw [])) ∘? _)
    norm_num[ Fin.ext_iff, Finsupp.mapDomain]
    norm_num[Monomial,Finsupp.sum_of_support_subset (s:=⊤),Finsupp.single_apply,Finsupp.le_def]at S⊢
    exact ( ⟨by bound, ⟨ _,·.2.trans_le hr⟩,by norm_num[., Fin.val_injective.eq_iff]⟩)
  cases I
  norm_num[Monomial, Finsupp.mapDomain] at C K⊢
  norm_num[Monomial, Finsupp.sum, Finsupp.single_apply, Finsupp.le_def] at C R M⊢
  use fun and=> if a:∃S: Fin (3), ⟨ S,by valid⟩= and then a.choose_spec▸?_ else (by norm_num[not_exists.1 a])
  norm_num+contextual[ Fin.val_injective.eq_iff, Finset.sum_eq_single a.choose]
  use(C _) K ( fun and=>.trans (by norm_num[ Finsupp.mapDomain_apply fun and=> _, Fin.val_injective.eq_iff]) ( (M ⟨and,by valid⟩).trans ((R _).trans ( (by norm_num[ Finsupp.mapDomain_apply fun and=> _, Fin.val_injective.eq_iff]))))) _

lemma embed_socleDegree {r : ℕ} (hr : 3 ≤ r) (P : PureOrderIdeal 3) :
    socleDegree (embedPureOrderIdeal hr P) = socleDegree P := by
  unfold socleDegree
  have h1 : Classical.choose (embedPureOrderIdeal hr P).maximal_nonempty ∈ maximalMonomials (embedPureOrderIdeal hr P).ideal :=
    Classical.choose_spec (embedPureOrderIdeal hr P).maximal_nonempty
  have h2 : Classical.choose P.maximal_nonempty ∈ maximalMonomials P.ideal :=
    Classical.choose_spec P.maximal_nonempty
  have h3 : embedMonomial hr (Classical.choose P.maximal_nonempty) ∈ maximalMonomials (embedPureOrderIdeal hr P).ideal := by
    change embedMonomial hr (Classical.choose P.maximal_nonempty) ∈ maximalMonomials (embedOrderIdeal hr P.ideal)
    rw [embed_maximalMonomials]
    exact Finset.mem_image_of_mem _ h2
  have h4 : totalDeg (Classical.choose (embedPureOrderIdeal hr P).maximal_nonempty) = totalDeg (embedMonomial hr (Classical.choose P.maximal_nonempty)) := by
    exact (embedPureOrderIdeal hr P).isPure _ _ h1 h3
  rw [h4, embed_totalDeg]

lemma embed_typePO {r : ℕ} (hr : 3 ≤ r) (P : PureOrderIdeal 3) :
    typePO (embedPureOrderIdeal hr P) = typePO P := by
  unfold typePO
  change (maximalMonomials (embedOrderIdeal hr P.ideal)).card = (maximalMonomials P.ideal).card
  rw [embed_maximalMonomials]
  exact Finset.card_image_of_injective (maximalMonomials P.ideal) (embed_injective hr)

lemma reduction_to_r3 {r : ℕ} (hr : 3 ≤ r) (t : ℕ) :
    ExistsNonLogConcavePureOSeq 3 t → ExistsNonLogConcavePureOSeq r t := by
  rintro ⟨P, htype, hnot_lc⟩
  use embedPureOrderIdeal hr P
  constructor
  · rw [embed_typePO]
    exact htype
  · rw [embed_socleDegree]
    intro h_lc
    apply hnot_lc
    intro i hi
    have h_lc_i := h_lc i hi
    change pureOSequence (embedOrderIdeal hr P.ideal) (i - 1) * pureOSequence (embedOrderIdeal hr P.ideal) (i + 1) ≤ pureOSequence (embedOrderIdeal hr P.ideal) i ^ 2 at h_lc_i
    rw [embed_pureOSequence, embed_pureOSequence, embed_pureOSequence] at h_lc_i
    exact h_lc_i

noncomputable def dipMonomialFat (t : ℕ) : Monomial 3 :=
  Finsupp.single 0 t + Finsupp.single 1 t + Finsupp.single 2 t

noncomputable def dipMonomialLong (i t : ℕ) : Monomial 3 :=
  Finsupp.single 0 (3 * t - i) + Finsupp.single 1 i

lemma totalDeg_dipMonomialFat (t : ℕ) : totalDeg (dipMonomialFat t) = 3 * t := by
  show totalDeg ↑(id _) = _
  simp_all[Nat.succ_mul,totalDeg, add_assoc, Finsupp.sum_add_index']

lemma totalDeg_dipMonomialLong (i t : ℕ) (hi : i < t - 1) : totalDeg (dipMonomialLong i t) = 3 * t := by
  change totalDeg (id _) = _
  norm_num[totalDeg, (by valid:i≤3*t), Finsupp.sum_add_index']
  norm_num[← Finsupp.single_mul,← Finsupp.single_tsub, (by valid:i≤3*t)]

noncomputable def dipMonomials3 (t : ℕ) : Finset (Monomial 3) :=
  insert (dipMonomialFat t) ((Finset.range (t - 1)).image (fun i => dipMonomialLong i t))

noncomputable def dipOrderIdeal3 (t : ℕ) : OrderIdeal 3 :=
  generatedOrderIdeal (dipMonomials3 t)

lemma maximalMonomials_dipOrderIdeal3 (t : ℕ) (ht : 5 ≤ t) :
    maximalMonomials (dipOrderIdeal3 t) = dipMonomials3 t := by
  show(maximalMonomials (id _)=id _)
  norm_num[generatedOrderIdeal,maximalMonomials, Finset.ext_iff]
  conv_rhs=>norm_num[divisorsFinset,IsMaximalIn,Nat.lt_sub_iff_add_lt]
  show∀y,(∃ a ∈{s |_},_) ∧(∀ R M,M ∈{s |_} →_) ↔y =(id _) ∨∃_, _∧(id _)=y
  show∀x,(∃ a ∈{s | a ∈{s |_}},_) ∧(∀ R M,M ∈{s |s ∈{s |_}} →_) ↔_
  norm_num[@forall_comm<|Monomial _,Nat.succ_mul,Nat.lt_sub_iff_add_lt,add_assoc]
