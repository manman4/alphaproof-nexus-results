  · omega
  · constructor
    · omega
    · have eq1 : 3 * t - 1 - 1 = 3 * t - 2 := by omega
      have eq2 : 3 * t - 1 + 1 = 3 * t := by omega
      rw [eq1, eq2, h1, h2, h3]
