lemma P2_coeff : ProblemP2CoeffFormula := by
  intro r g d
  dsimp [ProblemP2CoeffFormula, pureOSequence, generatedOrderIdeal]
  congr 1
  ext m
  simp

noncomputable def seq_of_g {r : ℕ} (g : Monomial r) : ℕ → ℕ :=
  fun d => ((divisorsFinset g).filter fun m => totalDeg m = d).card

lemma ring_identity (X fd fdc fdp1 fdcm1 : ℤ) :
  (X + fdc) * (X + fdc) - (X - fd + fdc + fdcm1) * (fdp1 + X) =
  (fd * X - fdp1 * (X - fd + fdc)) + ((X + fdc) * fdc - (fdp1 + X) * fdcm1) := by
  ring

lemma sum_eval_1 (f : ℤ → ℤ) (d : ℤ) (c : ℕ) :
  ∑ m ∈ Finset.range c, (f d * f (d - m) - f (d + 1) * f (d - m - 1)) =
  f d * (∑ m ∈ Finset.range c, f (d - m)) - f (d + 1) * (∑ m ∈ Finset.range c, f (d - m - 1)) := by
  push_cast only [ Finset.mul_sum, true, Finset.sum_sub_distrib]

lemma sum_eval_2 (f : ℤ → ℤ) (d : ℤ) (c : ℕ) :
  ∑ m ∈ Finset.range (c + 1), (f (d - m) * f (d - (c:ℤ)) - f (d - m + 1) * f (d - (c:ℤ) - 1)) =
  (∑ m ∈ Finset.range (c + 1), f (d - m)) * f (d - (c:ℤ)) - (∑ m ∈ Finset.range (c + 1), f (d - m + 1)) * f (d - (c:ℤ) - 1) := by
  push_cast only[ Finset.sum_mul, Finset.sum_sub_distrib]

lemma sum_eval_H1 (f : ℤ → ℤ) (d : ℤ) (c : ℕ) :
  ∑ i ∈ Finset.range (c + 1), f (d - i) = (∑ m ∈ Finset.range c, f (d - m)) + f (d - c) := by
  apply Finset.sum_range_succ

lemma sum_eval_H2 (f : ℤ → ℤ) (d : ℤ) (c : ℕ) :
  ∑ i ∈ Finset.range (c + 1), f (d - 1 - i) = (∑ m ∈ Finset.range c, f (d - m)) - f d + f (d - c) + f (d - c - 1) := by
  exact ( Finset.sum_range_succ _ _).trans (congr_arg₂ @_ (by induction c with |zero=>norm_num |succ R L=>exact (.trans (by rw [ Finset.sum_range_succ, L]) (.symm (.trans (by rw [ Finset.sum_range_succ, R.cast_succ]) (by grind))))) (by rw [sub_right_comm]))

lemma sum_eval_H3 (f : ℤ → ℤ) (d : ℤ) (c : ℕ) :
  ∑ i ∈ Finset.range (c + 1), f (d + 1 - i) = f (d + 1) + ∑ m ∈ Finset.range c, f (d - m) := by
  zify [ Finset.sum_range_succ',add_sub_add_right_eq_sub, sub_zero, true,add_comm]

lemma sum_eval_H4 (f : ℤ → ℤ) (d : ℤ) (c : ℕ) :
  ∑ m ∈ Finset.range c, f (d - m - 1) = (∑ m ∈ Finset.range c, f (d - m)) - f d + f (d - c) := by
  induction@c with|zero=>norm_num |succ R L =>exact (.trans (by rw [ Finset.sum_range_succ, L, sub_sub]) ((.symm (.trans (by rw [ Finset.sum_range_succ, R.cast_succ]) (by. (abel))))))

lemma sum_eval_H5 (f : ℤ → ℤ) (d : ℤ) (c : ℕ) :
  ∑ m ∈ Finset.range (c + 1), f (d - m + 1) = f (d + 1) + ∑ m ∈ Finset.range c, f (d - m) := by
  norm_num [ Finset.sum_range_succ',add_comm (f _),sub_add]

lemma log_concave_conv_identity (f : ℤ → ℤ) (d : ℤ) (c : ℕ) :
  (∑ i ∈ Finset.range (c + 1), f (d - i)) * (∑ i ∈ Finset.range (c + 1), f (d - i)) -
  (∑ i ∈ Finset.range (c + 1), f (d - 1 - i)) * (∑ i ∈ Finset.range (c + 1), f (d + 1 - i)) =
    (∑ m ∈ Finset.range c, (f d * f (d - m) - f (d + 1) * f (d - m - 1))) +
    (∑ m ∈ Finset.range (c + 1), (f (d - m) * f (d - (c : ℤ)) - f (d - m + 1) * f (d - (c : ℤ) - 1))) := by
  rw [sum_eval_1, sum_eval_2, sum_eval_H1, sum_eval_H2, sum_eval_H3, sum_eval_H4, sum_eval_H5]
  exact ring_identity (∑ m ∈ Finset.range c, f (d - m)) (f d) (f (d - c)) (f (d + 1)) (f (d - c - 1))

def is_ratio_decreasing_Z (f : ℤ → ℤ) : Prop :=
  ∀ a b : ℤ, a ≥ b → f a * f b ≥ f (a + 1) * f (b - 1)

lemma log_concave_conv_Z (f : ℤ → ℤ) (c : ℕ) (hrd : is_ratio_decreasing_Z f) :
  ∀ d : ℤ, (∑ i ∈ Finset.range (c + 1), f (d - i)) * (∑ i ∈ Finset.range (c + 1), f (d - i)) ≥
    (∑ i ∈ Finset.range (c + 1), f (d - 1 - i)) * (∑ i ∈ Finset.range (c + 1), f (d + 1 - i)) := by
  intro d
  have h_id := log_concave_conv_identity f d c
  have h1 : 0 ≤ ∑ m ∈ Finset.range c, (f d * f (d - m) - f (d + 1) * f (d - m - 1)) := by
    apply Finset.sum_nonneg
    intro m _
    have := hrd d (d - m) (by omega)
    linarith
  have h2 : 0 ≤ ∑ m ∈ Finset.range (c + 1), (f (d - m) * f (d - ↑c) - f (d - m + 1) * f (d - ↑c - 1)) := by
    apply Finset.sum_nonneg
    intro m hm
    have : m ≤ c := by
      rw [Finset.mem_range] at hm
      omega
    have := hrd (d - m) (d - c) (by omega)
    linarith
  linarith

noncomputable def seq_of_g_Z {r : ℕ} (g : Monomial r) : ℤ → ℤ :=
  fun d => if d < 0 then 0 else seq_of_g g d.toNat

lemma totalDeg_eq_sum_univ {r : ℕ} (m : Monomial r) :
  totalDeg m = ∑ i : Fin r, m i := by
  rw [←eq_comm,totalDeg]
  exact (.symm (by apply Finset.sum_subset m.support.subset_univ fun and I I => Finsupp.notMem_support_iff.1 I))

lemma totalDeg_le_of_le {r : ℕ} {m n : Monomial r} (h : m ≤ n) : totalDeg m ≤ totalDeg n := by
  rw [totalDeg_eq_sum_univ, totalDeg_eq_sum_univ]
  apply Finset.sum_le_sum
  intro i _
  exact h i

lemma seq_of_g_zero {r : ℕ} (g : Monomial r) (d : ℕ) (hd : totalDeg g < d) :
  seq_of_g g d = 0 := by
  dsimp [seq_of_g]
  apply Finset.card_eq_zero.mpr
  rw [Finset.filter_eq_empty_iff]
  intro m hm
  have h_le : m ≤ g := mem_divisorsFinset_iff.mp hm
  have h_deg : totalDeg m ≤ totalDeg g := totalDeg_le_of_le h_le
  intro hd_eq
  linarith

lemma exists_index_lt_of_totalDeg_lt {r : ℕ} {m g : Monomial r} (hle : m ≤ g) (hlt : totalDeg m < totalDeg g) : ∃ i, m i < g i := by
  by_contra h_not
  push_neg at h_not
  have heq : m = g := by
    ext i
    exact le_antisymm (hle i) (h_not i)
  rw [heq] at hlt
  exact lt_irrefl _ hlt

lemma totalDeg_add_single {r : ℕ} (m : Monomial r) (i : Fin r) :
    totalDeg (m + Finsupp.single i 1) = totalDeg m + 1 := by
  exact (m.sum_add_index' (by valid) (by simp_all)).trans (congr_arg @_ (by simp_all))

lemma exists_dvd_of_totalDeg_le {r : ℕ} (g : Monomial r) (d : ℕ) (hd : d ≤ totalDeg g) :
    ∃ m : Monomial r, m ≤ g ∧ totalDeg m = d := by
  induction d with
  | zero =>
    use 0
    constructor
    · intro i; exact Nat.zero_le _
    · exact rfl
  | succ d' ih =>
    have hd' : d' ≤ totalDeg g := le_trans (Nat.le_succ d') hd
    rcases ih hd' with ⟨m', hm'_le, hm'_deg⟩
    have hm'_lt : totalDeg m' < totalDeg g := by
      rw [hm'_deg]
      exact hd
    have h_ex_i : ∃ i, m' i < g i := exists_index_lt_of_totalDeg_lt hm'_le hm'_lt
    rcases h_ex_i with ⟨i, hi⟩
    let m := m' + Finsupp.single i 1
    use m
    constructor
    · intro j
      by_cases hj : j = i
      · rw [hj]
        have : m i = m' i + 1 := by
          dsimp [m]
          rw [Finsupp.single_eq_same]
        rw [this]
        exact hi
      · have : m j = m' j := by
          dsimp [m]
          rw [Finsupp.single_eq_of_ne hj, add_zero]
        rw [this]
        exact hm'_le j
    · rw [totalDeg_add_single]
      rw [hm'_deg]

lemma seq_of_g_pos {r : ℕ} (g : Monomial r) (d : ℕ) (hd : d ≤ totalDeg g) : 0 < seq_of_g g d := by
  dsimp [seq_of_g]
  have h_ex := exists_dvd_of_totalDeg_le g d hd
  rcases h_ex with ⟨m, hm_le, hm_deg⟩
  have hm_mem : m ∈ (divisorsFinset g).filter (fun x => totalDeg x = d) := by
    rw [Finset.mem_filter]
    exact ⟨mem_divisorsFinset_iff.mpr hm_le, hm_deg⟩
  exact Finset.card_pos.mpr ⟨m, hm_mem⟩

lemma seq_of_g_Z_pos {r : ℕ} (g : Monomial r) (d : ℤ) (hd1 : 0 ≤ d) (hd2 : d ≤ totalDeg g) :
  0 < seq_of_g_Z g d := by
  dsimp [seq_of_g_Z]
  have hd_pos : ¬(d < 0) := by linarith
  rw [if_neg hd_pos]
  have h2 : d.toNat ≤ totalDeg g := by
    have h_toNat : (d.toNat : ℤ) = d := Int.toNat_of_nonneg hd1
    linarith
  have h3 : 0 < seq_of_g g d.toNat := seq_of_g_pos g d.toNat h2
  exact_mod_cast h3

lemma seq_of_g_Z_zero {r : ℕ} (g : Monomial r) (d : ℤ) (hd : d < 0 ∨ (totalDeg g : ℤ) < d) :
  seq_of_g_Z g d = 0 := by
  dsimp [seq_of_g_Z]
  split_ifs with h
  · rfl
  · have h1 : (totalDeg g : ℤ) < d := by
      rcases hd with h_lt | h_gt
      · contradiction
      · exact h_gt
    have h2 : totalDeg g < d.toNat := by
      have hd_pos : 0 ≤ d := by linarith
      omega
    have h3 : seq_of_g g d.toNat = 0 := seq_of_g_zero g d.toNat h2
    exact_mod_cast h3

lemma ratio_decreasing_of_log_concave_Z (f : ℤ → ℤ) (e : ℤ)
  (hlc : ∀ k : ℤ, f k * f k ≥ f (k - 1) * f (k + 1))
  (hpos : ∀ k, 0 ≤ k ∧ k ≤ e → 0 < f k)
  (hzero : ∀ k, k < 0 ∨ e < k → f k = 0) :
  is_ratio_decreasing_Z f := by
  push_cast[is_ratio_decreasing_Z, and_imp,←@Int.cast_le ℝ,←sq]at*
  use mod_cast fun and A B=> if a: A≥0 then if I: A≤e then A.le_induction ?_ ( fun and R M=>? _) and B else(? _)else(? _)
  · repeat rw[(hzero _) (by (omega ) ), zero_mul]
  · norm_num[(hzero A (by valid)),hzero (A-1) (by valid)]
  · push_cast[←@Int.cast_le ℝ,hlc,←sq, false,mul_comm (f (A+1) : ℝ),id]
  use if I2 :and≤e then if I2 :and+1≤e then(? _)else(? _)else if I2 : and+1 ≤e then(? _)else(? _)
  · rcases lt_or_ge (A-1) 0
    · exact (.trans (by rw [(hzero (A-1) (by valid)),mul_zero]) (Int.mul_pos (hpos _ (mod_cast (by omega)) (mod_cast I2)) (hpos A (mod_cast a) (mod_cast I))).le)
    · nlinarith only[ M,show(f and > 0)∧(f (and+1) > 0)∧(f (A-1) > 0)by(repeat use(hpos _) ↑(mod_cast (by omega)) (mod_cast by omega)),mod_cast add_sub_cancel_right (and) (1)▸hlc _,1]
  · norm_num[hzero, not_le.1 (I2),e.lt_add_one_of_le ∘le_of_lt]
  · linarith
  · norm_num[*, (not_le.1 I2).trans_le]

lemma seq_of_g_Z_conv {r : ℕ} (g' : Monomial r) (i : Fin r) (c : ℕ) (hi : i ∉ g'.support) (d : ℤ) :
  seq_of_g_Z (g' + Finsupp.single i c) d = ∑ j ∈ Finset.range (c + 1), seq_of_g_Z g' (d - j) := by
  delta seq_of_g_Z abs
  delta seq_of_g
  push_cast only[totalDeg, sub_neg,divisorsFinset, Finset.card_filter]
  refine if a:_ then (if_pos a▸by rw [ Finset.sum_eq_zero (by valid)])else (if_neg a▸mod_cast ? _)
  trans∑ a ∈.range (c+1),∑S ∈.Iic g',ite (S.sum (@ fun and true => true)+a = d.toNat) (1) 0
  · replace a:.Iic (g'+.single i c) = ( Finset.Iic g').biUnion fun and=>.image (and+.single i ·) (.range (c + 1)) := ( Finset.ext) ?_
    · refine(a▸ Finset.sum_biUnion fun and _ _ _ _=>? _).trans (.trans (congr_arg _ (by norm_num[ Finsupp.sum_add_index', Finsupp.single_eq_single_iff, Finset.sum_image _])) Finset.sum_comm)
      simp_all -contextual [Monomial, true, Finset.disjoint_left, false, Finsupp.ext_iff]
      use (by valid:).elim fun a s _ _ _ A B h=>⟨a,A a▸s ∘by cases em (i=a) with simp_all[eq_bot_mono (‹and≤g'› _),eq_bot_mono (‹_≤g'› _),]⟩
    simp_all [Monomial]
    use fun and=>⟨fun R=>⟨ _, fun and=>? _,and i,(R i).trans (by norm_num[*]),tsub_add_cancel_of_le (by norm_num)⟩,fun⟨x,k,y,A, B⟩b=>B▸Nat.add_le_add (k _) @?_⟩
    · cases em<|i =and with simp_all[(R _).trans]
    · cases em<|i =b with aesop_cat
  · exact (congr_arg _) ((funext fun and=>or_not.elim (if_pos ·▸ Finset.sum_eq_zero fun and n=>if_neg (by valid)) (if_neg ·▸congr_arg _ (funext fun and=>if_congr (by valid) (rfl) (rfl)))))

lemma log_concave_seq_of_g_Z_ind {r : ℕ} (g : Monomial r) :
  is_ratio_decreasing_Z (seq_of_g_Z g) := by
  refine Finsupp.induction g ?_ ?_
  · norm_num[is_ratio_decreasing_Z,seq_of_g_Z]
    use fun and A B=>or_not.elim (if_pos ·▸by bound) (if_neg ·▸and.toNat_add (by valid) zero_le_one▸A.toNat.sub_add_cancel (by valid: A.toNat > 0)▸? _)
    norm_num[seq_of_g, (by valid: A≥0∧and≥0),add_nonneg, if_neg]
  · intro i c g' hi hc ih
    rw [add_comm]
    have hd_eq : totalDeg (g' + Finsupp.single i c) = totalDeg g' + c := by
      norm_num[totalDeg, Finsupp.sum_add_index']
    have hlc : ∀ k : ℤ, seq_of_g_Z (g' + Finsupp.single i c) k * seq_of_g_Z (g' + Finsupp.single i c) k ≥
        seq_of_g_Z (g' + Finsupp.single i c) (k - 1) * seq_of_g_Z (g' + Finsupp.single i c) (k + 1) := by
      intro k
      rw [seq_of_g_Z_conv g' i c hi k, seq_of_g_Z_conv g' i c hi (k - 1), seq_of_g_Z_conv g' i c hi (k + 1)]
      exact log_concave_conv_Z (seq_of_g_Z g') c ih k
    apply ratio_decreasing_of_log_concave_Z (seq_of_g_Z (g' + Finsupp.single i c)) (totalDeg (g' + Finsupp.single i c)) hlc
    · intro k hk
      exact seq_of_g_Z_pos _ k hk.1 hk.2
    · intro k hk
      exact seq_of_g_Z_zero _ k hk

lemma log_concave_seq_of_g {r : ℕ} (g : Monomial r) :
  IsLogConcaveUpTo (totalDeg g) (seq_of_g g) := by
  dsimp [IsLogConcaveUpTo]
  intro i hi
  have h_rd := log_concave_seq_of_g_Z_ind g i i (by omega)
  have h_Z1 : seq_of_g_Z g i = seq_of_g g i := by
    dsimp [seq_of_g_Z]
    have : ¬((i : ℤ) < 0) := by linarith
    rw [if_neg this]
  have h_Z2 : seq_of_g_Z g (i - 1) = seq_of_g g (i - 1) := by
    dsimp [seq_of_g_Z]
    have : ¬(((i : ℤ) - 1) < 0) := by
      rw [Finset.mem_Ioo] at hi
      linarith
    rw [if_neg this]
    have h_sub : ((i : ℤ) - 1).toNat = i - 1 := by
      rw [Finset.mem_Ioo] at hi
      omega
    rw [h_sub]
  have h_Z3 : seq_of_g_Z g (i + 1) = seq_of_g g (i + 1) := by
    dsimp [seq_of_g_Z]
    have : ¬(((i : ℤ) + 1) < 0) := by linarith
    rw [if_neg this]
  rw [h_Z1, h_Z2, h_Z3] at h_rd
  have h_sq : seq_of_g g i ^ 2 = seq_of_g g i * seq_of_g g i := sq _
  rw [h_sq, mul_comm (seq_of_g g (i - 1)) _]
  exact_mod_cast h_rd

lemma unimodal_of_log_concave {e : ℕ} (h : ℕ → ℕ) (h_log : IsLogConcaveUpTo e h)
    (h_pos : ∀ d, d ≤ e → 0 < h d) : IsUnimodal e h := by
  delta IsLogConcaveUpTo IsUnimodal at*
  use (sSup {n ≤e|∀k< (n : ℕ),h k≤h (k + 1)}),? _,?_
  · use fun and R M=>not_lt.1 (by valid ∘R.trans'.comp (le_csSup ⟨e, fun and=>And.left⟩ ⟨ M,fun a s=>(a.le_of_lt_succ s).eq_or_lt.elim (.▸le_of_lt (by valid)) fun and=>not_lt.1.comp (? _) ·⟩))
    exact (fun A B=> A.asymm (and.le.rec (by valid) ( fun and R L=>Nat.lt_of_mul_lt_mul_left.comp ( (h_log _) (Finset.mem_Ioo.2 ⟨by·bound, L⟩)).trans_lt (sq (h _)▸by·bound) ) M))
  · delta SupSet.sSup
    exact csSup_le' fun and=>And.left
  · use fun and x =>(exists_lt_of_lt_csSup (by use(0),bot_le, nofun) x).choose_spec.elim (·.2 _)

lemma unimodal_seq_of_g {r : ℕ} (g : Monomial r) :
  IsUnimodal (totalDeg g) (seq_of_g g) := by
  have h_log := log_concave_seq_of_g g
  have h_pos : ∀ d, d ≤ totalDeg g → 0 < seq_of_g g d := seq_of_g_pos g
  exact unimodal_of_log_concave (seq_of_g g) h_log h_pos

lemma mem_maximalMonomials_iff {r : ℕ} (I : OrderIdeal r) (m : Monomial r) :
    m ∈ maximalMonomials I ↔ IsMaximalIn I m := by
  dsimp [maximalMonomials]
  letI : DecidablePred (IsMaximalIn I) := Classical.decPred _
  rw [Finset.mem_filter]
  exact and_iff_right_of_imp (fun h => h.1)

lemma eq_of_le_of_totalDeg_le {r : ℕ} {m n : Monomial r} (hmn : m ≤ n) (h_deg : totalDeg n ≤ totalDeg m) : m = n := by
  ext i
  norm_num [totalDeg]at*
  use(hmn _).eq_of_not_lt fun and=>by simp_all[ Finsupp.sum_of_support_subset (s:=⊤), Finset.sum_lt_sum (fun R L=>hmn R) ⟨i, _⟩,not_le.2]

lemma exists_le_maximal {r : ℕ} (I : OrderIdeal r) (m : Monomial r) (hm : m ∈ I.carrier) :
    ∃ g ∈ maximalMonomials I, m ≤ g := by
  let S := I.carrier.filter (fun n => m ≤ n)
  have h_nonempty : S.Nonempty := by
    use m
    rw [Finset.mem_filter]
    exact ⟨hm, le_rfl⟩
  let degrees := S.image totalDeg
  have h_deg_nonempty : degrees.Nonempty := Finset.Nonempty.image h_nonempty totalDeg
  let max_deg := degrees.max' h_deg_nonempty
  have h_max_deg_mem : max_deg ∈ degrees := Finset.max'_mem degrees h_deg_nonempty
  rcases Finset.mem_image.mp h_max_deg_mem with ⟨g, hg_S, hg_deg⟩
  rw [Finset.mem_filter] at hg_S
  have hm_le_g : m ≤ g := hg_S.2
  have hg_I : g ∈ I.carrier := hg_S.1
  use g
  constructor
  · rw [mem_maximalMonomials_iff]
    dsimp [IsMaximalIn]
    refine ⟨hg_I, ?_⟩
    intro n hn_I hg_le_n
    have hn_S : n ∈ S := by
      rw [Finset.mem_filter]
      exact ⟨hn_I, le_trans hm_le_g hg_le_n⟩
    have hn_deg : totalDeg n ∈ degrees := Finset.mem_image_of_mem totalDeg hn_S
    have h_deg_le : totalDeg n ≤ max_deg := Finset.le_max' degrees (totalDeg n) hn_deg
    rw [← hg_deg] at h_deg_le
    have h_eq : g = n := eq_of_le_of_totalDeg_le hg_le_n h_deg_le
    rw [h_eq]
  · exact hm_le_g

lemma type1_carrier_eq {r : ℕ} (P : PureOrderIdeal r) (h : typePO P = 1) :
  ∃ g, P.ideal.carrier = divisorsFinset g ∧ socleDegree P = totalDeg g := by
  have h_card : (maximalMonomials P.ideal).card = 1 := h
  rcases Finset.card_eq_one.mp h_card with ⟨g, hg⟩
  use g
  constructor
  · ext m
    constructor
    · intro hm
      have h_ex := exists_le_maximal P.ideal m hm
      rcases h_ex with ⟨g', hg', hmg'⟩
      have hg'_eq : g' = g := by
        have : g' ∈ ({g} : Finset (Monomial r)) := by
          rw [← hg]
          exact hg'
        exact Finset.mem_singleton.mp this
      rw [hg'_eq] at hmg'
      exact mem_divisorsFinset_iff.mpr hmg'
    · intro hm
      have h_le : m ≤ g := mem_divisorsFinset_iff.mp hm
      have hg_mem : g ∈ maximalMonomials P.ideal := by
        rw [hg]
        exact Finset.mem_singleton_self g
      have hg_c : g ∈ P.ideal.carrier := (mem_maximalMonomials_iff P.ideal g).mp hg_mem |>.left
      exact OrderIdeal.mem_of_dvd P.ideal hg_c h_le
  · dsimp [socleDegree]
    have h_choose_mem : Classical.choose P.maximal_nonempty ∈ maximalMonomials P.ideal :=
      Classical.choose_spec P.maximal_nonempty
    have h_choose_eq : Classical.choose P.maximal_nonempty = g := by
      have : Classical.choose P.maximal_nonempty ∈ ({g} : Finset (Monomial r)) := by
        rw [← hg]
        exact h_choose_mem
      exact Finset.mem_singleton.mp this
    rw [h_choose_eq]

lemma P2_unimodal : ProblemP2Type1Unimodal := by
  intro r P hP
  rcases type1_carrier_eq P hP with ⟨g, hg_c, hg_socle⟩
  have h_seq : pureOSequence P.ideal = seq_of_g g := by
    ext d
    dsimp [pureOSequence, seq_of_g]
    rw [hg_c]
  rw [h_seq, hg_socle]
  exact unimodal_seq_of_g g

lemma P2_logconcave : ProblemP2Type1LogConcave := by
  intro r P hP
  rcases type1_carrier_eq P hP with ⟨g, hg_c, hg_socle⟩
  have h_seq : pureOSequence P.ideal = seq_of_g g := by
    ext d
    dsimp [pureOSequence, seq_of_g]
    rw [hg_c]
  rw [h_seq, hg_socle]
  exact log_concave_seq_of_g g
