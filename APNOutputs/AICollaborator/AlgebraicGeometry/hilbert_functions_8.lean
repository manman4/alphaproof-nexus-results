lemma same_degree_le_eq {r : ℕ} {m n : Monomial r} (h_deg : totalDeg m = totalDeg n) (h_le : m ≤ n) : m = n := by
  delta totalDeg Monomial at*
  exact (le_antisymm h_le fun and=>not_lt.mp fun and' =>by simp_all -contextual [(Finset.sum_lt_sum (@fun R M=>h_le R) (by use and, Finset.mem_univ and)).ne, Finsupp.sum_of_support_subset (s:=⊤)])

lemma maximal_of_same_degree {r : ℕ} {S : Finset (Monomial r)} {d : ℕ} (hS : ∀ m ∈ S, totalDeg m = d) :
    maximalMonomials (generatedOrderIdeal S) = S := by
  push_cast[generatedOrderIdeal, false,maximalMonomials]
  norm_num[divisorsFinset,totalDeg,IsMaximalIn,Finset.ext_iff]at*
  use fun and=>⟨fun⟨⟨x,A, B⟩,C⟩=>le_antisymm B (C _ _ A le_rfl B)▸A, fun and' =>⟨ (by use and), fun and A B R M=>R.trans (? _)⟩⟩
  use fun and=>not_lt.1 fun andx=>(hS A B).symm.not_lt (hS _ and'▸by norm_num[ Finsupp.sum_of_support_subset (s:=⊤), andx, Finset.sum_lt_sum (fun a s=>(M a).trans (R a)) ⟨and, _⟩])

noncomputable def pureOrderIdealOfSet {r : ℕ} (S : Finset (Monomial r)) (d : ℕ)
    (hS : ∀ m ∈ S, totalDeg m = d) (h_nonempty : S.Nonempty) : PureOrderIdeal r where
  ideal := generatedOrderIdeal S
  isPure := by
    intro m n hm hn
    have h_max := maximal_of_same_degree hS
    rw [h_max] at hm hn
    rw [hS m hm, hS n hn]
  maximal_nonempty := by
    have h_max := maximal_of_same_degree hS
    rw [h_max]
    exact h_nonempty

lemma typePO_pureOrderIdealOfSet {r : ℕ} (S : Finset (Monomial r)) (d : ℕ)
    (hS : ∀ m ∈ S, totalDeg m = d) (h_nonempty : S.Nonempty) :
    typePO (pureOrderIdealOfSet S d hS h_nonempty) = S.card := by
  delta pureOrderIdealOfSet typePO totalDeg at *
  norm_num[maximalMonomials]
  push_cast [generatedOrderIdeal, IsMaximalIn, Eq.comm] at*
  delta divisorsFinset Monomial at *
  let := { a ∈ S.biUnion (.Iic ·)|∀α ∈ S.biUnion (.Iic ·), a ≤α →α ≤ a}
  replace hS:this = S.image ( ·) :=(this.ext) ?_
  · simp_all only[this, S.image_id', and_iff_right, Finset.filter_congr fun and=>and_iff_right]
  simp_all -contextual[↑this, Finsupp.sum_of_support_subset (s:=⊤)]
  refine fun and=>⟨fun⟨ ⟨a, M, R⟩,H⟩=>le_antisymm R (H _ _ M le_rfl R)▸ M,fun M=>⟨ (by use and), fun and A B R L=>R.trans ( fun and=>not_lt.1 fun and' =>(hS A B).symm.not_lt (hS _ M▸?_))⟩⟩
  exact ( Finset.sum_lt_sum fun and p=>(L and).trans (R and)) (by use and, Finset.mem_univ _)

lemma exists_set_monomials_same_degree (r t : ℕ) (hr : 3 ≤ r) :
    ∃ d : ℕ, ∃ S : Finset (Monomial r), S.card = t ∧ ∀ m ∈ S, totalDeg m = d := by
  contrapose! hr
  delta totalDeg Monomial at*
  by_cases h : ∀a, {x : Fin r →₀ℕ|x.sum ( fun and true => true)=a}.Finite
  · use not_le.1 fun and=>match r with | S+3=>(((tendsto_natCast_atTop_atTop.eventually_ge_atTop t).exists.elim) ? _)
    use fun and x =>((h and).exists_finset_coe.elim) ?_
    use fun A B=>(A.exists_subset_card_eq (not_lt.1 fun and' =>?_)).elim fun and(S) =>(hr _ _ S.right).elim fun and true => true.2 (B.le (S.1 true.1))
    replace B:.image (.single 0 ·+.single (1) (and-by valid)) (.range and) ⊆A
    · simp_all[le_of_lt,Set.ext_iff, Finsupp.sum_add_index', Finset.image_subset_iff]
      simp_all[← Finsupp.single_tsub,le_of_lt]
    · exact ( Finset.card_image_of_injOn fun and _ _ _=>by norm_num ∘congr_arg (. 0)).not_lt (( Finset.card_mono B).trans_lt (and'.trans_le (x.trans (by norm_num))))
  · rcases h fun and=>by_contra fun and=>(Set.Infinite.exists_subset_card_eq and _).elim fun and (A) =>(@hr _ _ A.2).elim fun and true => true.2 (A.left true.left)

lemma exists_pure_order_ideal_of_type (r t : ℕ) (hr : 3 ≤ r) (ht : 1 ≤ t) :
    ∃ P : PureOrderIdeal r, typePO P = t := by
  have ⟨d, S, h_card, h_deg⟩ := exists_set_monomials_same_degree r t hr
  have h_nonempty : S.Nonempty := by
    rw [← Finset.card_pos, h_card]
    exact ht
  use pureOrderIdealOfSet S d h_deg h_nonempty
  rw [typePO_pureOrderIdealOfSet S d h_deg h_nonempty, h_card]

lemma socleDegree_pureOrderIdealOfSet {r : ℕ} (S : Finset (Monomial r)) (d : ℕ)
    (hS : ∀ m ∈ S, totalDeg m = d) (h_nonempty : S.Nonempty) :
    socleDegree (pureOrderIdealOfSet S d hS h_nonempty) = d := by
  delta socleDegree totalDeg Finset.Nonempty pureOrderIdealOfSet at *
  delta Classical.choose
  delta generatedOrderIdeal maximalMonomials Monomial at*
  rcases (Classical.indefiniteDescription _ _)
  norm_num[divisorsFinset, true, IsMaximalIn]at‹_›⊢
  refine (by assumption:).elim fun⟨A, B, M⟩H=>le_antisymm M (H _ _ B le_rfl M)▸hS A B

