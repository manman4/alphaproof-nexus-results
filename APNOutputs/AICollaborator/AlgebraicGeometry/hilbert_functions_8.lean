lemma exists_add_two_of_dvd_deg_minus_two {m g : Monomial 3} (h_le : m ≤ g) (h_deg : totalDeg m + 2 = totalDeg g) :
  (∃ i : Fin 3, g = m + Finsupp.single i 2) ∨
  (∃ i j : Fin 3, i ≠ j ∧ g = m + Finsupp.single i 1 + Finsupp.single j 1) := by delta totalDeg Monomial at*
