lemma h_D_eq (t : ℕ) (ht : 5 ≤ t) : pureOSequence (generatedOrderIdeal (S_t t)) (t + 5) = t := by
  unfold pureOSequence
  rw [filter_D_eq t ht]
  exact card_S_t_eq t ht

lemma h_D_1_eq (t : ℕ) (ht : 5 ≤ t) : pureOSequence (generatedOrderIdeal (S_t t)) (t + 4) = t + 2 := by
  unfold pureOSequence
  rw [filter_D_minus_1_eq t ht]
  exact card_S_t_minus_1_eq t ht

lemma h_D_2_eq (t : ℕ) (ht : 5 ≤ t) : pureOSequence (generatedOrderIdeal (S_t t)) (t + 3) = t + 5 := by
  unfold pureOSequence
  rw [filter_D_minus_2_eq t ht]
  exact card_S_t_minus_2_eq t ht

lemma S_t_not_lc (t : ℕ) (ht : 5 ≤ t) : ¬ IsLogConcaveUpTo (t + 5) (pureOSequence (generatedOrderIdeal (S_t t))) := by
  intro h_lc
  unfold IsLogConcaveUpTo at h_lc
  have h_eval := h_lc (t + 4) (by
    rw [Finset.mem_Ioo]
    omega
  )
  have h_sub_1 : t + 4 - 1 = t + 3 := by omega
  have h_add_1 : t + 4 + 1 = t + 5 := by omega
  rw [h_sub_1, h_add_1] at h_eval
  rw [h_D_eq t ht, h_D_1_eq t ht, h_D_2_eq t ht] at h_eval
  nlinarith

lemma S_t_nonempty (t : ℕ) (ht : 5 ≤ t) : (S_t t).Nonempty := by delta and S_t Set.Nonempty
                                                                 norm_num
lemma totalDeg_S_t (t : ℕ) (m : Monomial 3) (hm : m ∈ S_t t) : totalDeg m = t + 5 := by delta S_t totalDeg Monomial at*
                                                                                        norm_num [m_star, G_D] at hm
                                                                                        rcases hm with rfl|⟨s, a, rfl⟩
                                                                                        · norm_num[ Finsupp.sum_add_index',add_left_comm]
                                                                                        · norm_num[← Finsupp.single_add,← Finsupp.single_tsub,le_add_right (a.le.trans t.pred_le), Finsupp.sum_add_index']

noncomputable def pureIdeal_S_t (t : ℕ) (ht : 5 ≤ t) : PureOrderIdeal 3 :=
  pureOrderIdealOfSet (S_t t) (t + 5) (totalDeg_S_t t) (S_t_nonempty t ht)

lemma typePO_S_t (t : ℕ) (ht : 5 ≤ t) : typePO (pureIdeal_S_t t ht) = t := by
  change typePO (pureOrderIdealOfSet (S_t t) (t + 5) (totalDeg_S_t t) (S_t_nonempty t ht)) = t
  rw [typePO_pureOrderIdealOfSet (S_t t) (t + 5) (totalDeg_S_t t) (S_t_nonempty t ht)]
  exact card_S_t_eq t ht

lemma socle_S_t (t : ℕ) (ht : 5 ≤ t) : socleDegree (pureIdeal_S_t t ht) = t + 5 := by
  change socleDegree (pureOrderIdealOfSet (S_t t) (t + 5) (totalDeg_S_t t) (S_t_nonempty t ht)) = t + 5
  exact socleDegree_pureOrderIdealOfSet (S_t t) (t + 5) (totalDeg_S_t t) (S_t_nonempty t ht)

lemma exists_non_lc_r3 (t : ℕ) (ht : 5 ≤ t) : ExistsNonLogConcavePureOSeq 3 t := by
  use pureIdeal_S_t t ht
  constructor
  · exact typePO_S_t t ht
  · have h_socle : socleDegree (pureIdeal_S_t t ht) = t + 5 := socle_S_t t ht
    rw [h_socle]
    exact S_t_not_lc t ht

noncomputable def embedMonomial {r : ℕ} (m : Monomial r) : Monomial (r + 1) :=
  Finsupp.mapDomain Fin.castSucc m

noncomputable def embedFinset {r : ℕ} (S : Finset (Monomial r)) : Finset (Monomial (r + 1)) :=
  S.image embedMonomial

lemma card_embedFinset {r : ℕ} (S : Finset (Monomial r)) :
    (embedFinset S).card = S.card := by
  rw [←eq_comm,embedFinset]
  delta embedMonomial Monomial at*
  refine(S.card_image_of_injective ↑( ·.mapDomain_injective fun and=>by simp_all)).symm

lemma totalDeg_embedMonomial {r : ℕ} (m : Monomial r) :
    totalDeg (embedMonomial m) = totalDeg m := by
  delta totalDeg embedMonomial
  norm_num[ Finsupp.sum_mapDomain_index]

lemma pureOSequence_embedFinset {r : ℕ} (S : Finset (Monomial r)) :
    pureOSequence (generatedOrderIdeal (embedFinset S)) = pureOSequence (generatedOrderIdeal S) := by
  norm_num [generatedOrderIdeal, false,embedFinset, false,pureOSequence, false,funext_iff]
  delta totalDeg embedMonomial divisorsFinset Monomial at*
  use fun and=>((congr_arg _) (Finset.ext fun and=>.trans ( Finset.mem_filter) ? _)).trans.comp ( Finset.card_image_of_injective _) (show Function.Injective (·.mapDomain .castSucc) from fun and=>? _)
  · norm_num [ Fin.sum_univ_castSucc, and_assoc, S.image_biUnion, true, Finsupp.sum_of_support_subset (s:=⊤)]
    norm_num [ Finsupp.mapDomain]
    use fun ⟨⟨A, B, C⟩, _⟩=>⟨∑ S,.single S (and S.castSucc),⟨A, B, fun and=>by norm_num[(C _).trans, A.sum_fintype, Finsupp.single_apply,id]⟩,?_⟩,fun⟨x,A, B, C⟩=>C▸?_
    · norm_num[←by valid, A.sum_fintype,eq_bot_mono (C _), Finsupp.sum_of_support_subset (s:=⊤), Finsupp.single_apply, Finsupp.ext_iff]
      use Fin.lastCases (.trans (by norm_num[A.sum_of_support_subset (s:=⊤)]) (eq_bot_mono (C _) (by norm_num[ Finsupp.sum])).symm) (by norm_num)
    · use A.imp fun and=>.imp_right (by norm_num[Finsupp.sum_of_support_subset (s:=⊤), Finsupp.single_apply,. _, Finset.sum_le_sum]),B▸by norm_num[ Finsupp.sum_of_support_subset (s:=⊤), Finsupp.single_apply,ne_of_gt]
  · exact ( fun and=>(Finsupp.mapDomain_injective fun and=>by simp_all ·))

lemma non_lc_step (r t : ℕ) (h : ExistsNonLogConcavePureOSeq r t) :
    ExistsNonLogConcavePureOSeq (r + 1) t := by
  rcases h with ⟨P, ht, hlc⟩
  let S := maximalMonomials P.ideal
  let d := socleDegree P
  have hS_deg : ∀ m ∈ S, totalDeg m = d := by
    norm_num[ socleDegree, S, d]
    delta Classical.choose
    rcases Classical.indefiniteDescription _ _
    aesop
    induction P
    simp_all[totalDeg,maximalMonomials]
    delta IsPure IsMaximalIn at *
    cases‹OrderIdeal r›
    delta totalDeg maximalMonomials at*
    delta IsMaximalIn at*
    apply_rules[ Finset.mem_filter.2]
  have hS_card : S.card = t := by
    valid
  have hS_nonempty : S.Nonempty := P.maximal_nonempty
  let S' := embedFinset S
  have hS'_deg : ∀ m ∈ S', totalDeg m = d := by
    simp_all? (config := {singlePass:=1})[embedFinset, S']
    simp_all[embedMonomial,totalDeg]
    simp_all[Finsupp.sum_mapDomain_index]
  have hS'_nonempty : S'.Nonempty := by
    simp_all[embedFinset,S']
  let P' := pureOrderIdealOfSet S' d hS'_deg hS'_nonempty
  use P'
  constructor
  · have h_type := typePO_pureOrderIdealOfSet S' d hS'_deg hS'_nonempty
    rw [h_type, card_embedFinset, hS_card]
  · have h_socle : socleDegree P' = d := by
      exact socleDegree_pureOrderIdealOfSet S' d hS'_deg hS'_nonempty
    rw [h_socle]
    have h_ideal : P'.ideal = generatedOrderIdeal S' := rfl
    have h_P_ideal : P.ideal = generatedOrderIdeal S := by
      simp_all only[typePO, S,maximalMonomials]
      show _=(id _)
      cases P
      norm_num[divisorsFinset,IsPure,IsMaximalIn, Finset.Nonempty, Finset.ext_iff]at‹IsPure _›hS_nonempty⊢
      cases‹OrderIdeal r›
      norm_num[divisorsFinset,Finset.ext_iff]at‹_›⊢
      delta Monomial at*
      use fun and=>⟨fun R=>? _,by tauto⟩
      let := { a ∈ (by apply_rules: Finset (Fin r →₀ ℕ)) | and ≤ a}
      choose _ _ _ using this.exists_maximal ⟨ _, Finset.mem_filter.2 (by use R)⟩
      cases Finset.mem_filter.1 (by valid) with|intro A B=>exists _,⟨A, fun and a s=>by push_cast[a, this, B.trans, *, Finset.mem_filter, and_self]⟩
    rw [h_ideal, pureOSequence_embedFinset, ← h_P_ideal]
    exact hlc

lemma exists_non_lc_of_r3_aux (k t : ℕ) (ht : 5 ≤ t) :
    ExistsNonLogConcavePureOSeq (3 + k) t := by
  induction k with
  | zero =>
    exact exists_non_lc_r3 t ht
  | succ k ih =>
    have h_step := non_lc_step (3 + k) t ih
    exact h_step

lemma exists_non_lc_of_r3 (r t : ℕ) (hr : 3 ≤ r) (ht : 5 ≤ t) :
    ExistsNonLogConcavePureOSeq r t := by
  have h_eq : r = 3 + (r - 3) := by
    omega
  rw [h_eq]
  exact exists_non_lc_of_r3_aux (r - 3) t ht

lemma exists_non_lc_pure_order_ideal (r : ℕ) (hr : 3 ≤ r) :
  ∃ T : ℕ, 1 ≤ T ∧ ∀ t : ℕ, T ≤ t → ExistsNonLogConcavePureOSeq r t := by
  use 5
  constructor
  · omega
  · intro t ht
    exact exists_non_lc_of_r3 r t hr ht

lemma P7_implies_P8 (r : ℕ) (h7 : ProblemP7 r) : ProblemP8 r := by
  intro hr
  have h_exists : ∃ T, LCFailureThreshold r T := by
    obtain ⟨T, _, hT⟩ := h7 hr
    exact ⟨T, hT⟩
  exact exists_isLeast_of_exists h_exists

