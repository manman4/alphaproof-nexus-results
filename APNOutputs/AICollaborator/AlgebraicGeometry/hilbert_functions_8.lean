lemma card_S_t_eq (t : ℕ) (ht : 5 ≤ t) : (S_t t).card = t := by rw [←eq_comm, S_t]
                                                                delta G_D m_star
                                                                rw [ Finset.card_union_of_disjoint (Finset.disjoint_singleton_right.mpr (mt Finset.mem_image.mp fun and=>absurd (congr_arg (· (2)) and.choose_spec.2) (by simp_all))), Finset.card_image_of_injOn fun and _ _ _=>by simp_all ∘congr_arg (· 1), Finset.card]
                                                                norm_num[ht.trans']
lemma card_S_t_minus_1_eq (t : ℕ) (ht : 5 ≤ t) : (S_t_minus_1 t).card = t + 2 := by rw [←eq_comm, S_t_minus_1]
                                                                                    delta G_D_minus_1 m_star_divs_1
                                                                                    rw[ Finset.card_union_of_disjoint (Finset.disjoint_left.mpr.comp Finset.forall_mem_image.mpr fun and β=>mt Finset.mem_insert.mp ((or_congr_right (by rw [ Finset.mem_insert, Finset.mem_singleton])).not.mpr _))]
                                                                                    · exact (symm) (.trans (by rw [ Finset.card_image_of_injOn fun and _ _ _=>by simp_all ∘congr_arg (. (1))]) (by simp_all[ht.trans', Finsupp.ext_iff, Fin.forall_iff_succ]))
                                                                                    · refine fun and β=>by simp_all[mt ht.trans_eq, Ne.symm] ∘Or.imp (congr_arg (· (2))) (Or.imp (congr_arg (· (2))) (congr_arg (· (2))))
lemma card_S_t_minus_2_eq (t : ℕ) (ht : 5 ≤ t) : (S_t_minus_2 t).card = t + 5 := by rw [←eq_comm,S_t_minus_2]
                                                                                    delta G_D_minus_2 m_star_divs_2
                                                                                    rw[ Finset.card_union_of_disjoint, Finset.card_image_of_injOn fun and _ _ _=>by simp_all ∘congr_arg (@ · 1), Finset.card_range, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem]
                                                                                    · exact (symm (.trans (by rw [ Finset.card_eq_three.2 ⟨ _, _, _,by simp_all ∘congr_arg (. 1),by simp_all ∘congr_arg (. 0),by simp_all ∘congr_arg (. 0), rfl⟩]) (by valid)))
                                                                                    · simp_all -contextual[ Finsupp.ext_iff, Fin.forall_iff_succ]
                                                                                    · simp_all[mt (Finsupp.ext_iff.1 · (1: Fin _))]
                                                                                    · simp_all[mt (Finsupp.ext_iff.1 · (0: Fin _))]
