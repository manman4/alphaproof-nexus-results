noncomputable def G_D (t : ℕ) : Finset (Monomial 3) :=
  (Finset.range (t - 1)).image (fun i => Finsupp.single 0 (t + 5 - i) + Finsupp.single 1 i)

noncomputable def m_star (t : ℕ) : Monomial 3 :=
  Finsupp.single 0 2 + Finsupp.single 1 2 + Finsupp.single 2 (t + 1)

noncomputable def S_t (t : ℕ) : Finset (Monomial 3) :=
  G_D t ∪ {m_star t}

noncomputable def G_D_minus_1 (t : ℕ) : Finset (Monomial 3) :=
  (Finset.range (t - 1)).image (fun i => Finsupp.single 0 (t + 4 - i) + Finsupp.single 1 i)

noncomputable def m_star_divs_1 (t : ℕ) : Finset (Monomial 3) :=
  { Finsupp.single 0 1 + Finsupp.single 1 2 + Finsupp.single 2 (t + 1),
    Finsupp.single 0 2 + Finsupp.single 1 1 + Finsupp.single 2 (t + 1),
    Finsupp.single 0 2 + Finsupp.single 1 2 + Finsupp.single 2 t }

noncomputable def S_t_minus_1 (t : ℕ) : Finset (Monomial 3) := G_D_minus_1 t ∪ m_star_divs_1 t

noncomputable def G_D_minus_2 (t : ℕ) : Finset (Monomial 3) :=
  (Finset.range (t - 1)).image (fun i => Finsupp.single 0 (t + 3 - i) + Finsupp.single 1 i)

noncomputable def m_star_divs_2 (t : ℕ) : Finset (Monomial 3) :=
  { Finsupp.single 0 0 + Finsupp.single 1 2 + Finsupp.single 2 (t + 1),
    Finsupp.single 0 2 + Finsupp.single 1 0 + Finsupp.single 2 (t + 1),
    Finsupp.single 0 2 + Finsupp.single 1 2 + Finsupp.single 2 (t - 1),
    Finsupp.single 0 1 + Finsupp.single 1 1 + Finsupp.single 2 (t + 1),
    Finsupp.single 0 1 + Finsupp.single 1 2 + Finsupp.single 2 t,
    Finsupp.single 0 2 + Finsupp.single 1 1 + Finsupp.single 2 t }

noncomputable def S_t_minus_2 (t : ℕ) : Finset (Monomial 3) := G_D_minus_2 t ∪ m_star_divs_2 t

