  ∃ i : Fin 3, g = m + Finsupp.single i 1 := by norm_num [totalDeg, g.ext_iff, Finsupp.single_apply,id] at@h_deg⊢
                                                norm_num[ Finsupp.sum_of_support_subset (s:=⊤)]at*
