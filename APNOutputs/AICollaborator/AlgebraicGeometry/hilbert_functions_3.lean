lemma nat_AMGM (A C : ℕ) : 4 * (A * C) ≤ (A + C) * (A + C) := by
  have h : (A : ℤ) * (A : ℤ) - 2 * (A : ℤ) * (C : ℤ) + (C : ℤ) * (C : ℤ) ≥ 0 := by
    have h1 : (A : ℤ) * (A : ℤ) - 2 * (A : ℤ) * (C : ℤ) + (C : ℤ) * (C : ℤ) = ((A : ℤ) - (C : ℤ)) * ((A : ℤ) - (C : ℤ)) := by ring
    rw [h1]
    exact mul_self_nonneg ((A : ℤ) - (C : ℤ))
  zify
  linarith

def FirstDiffZ (P : PureOrderIdeal 3) (j : ℕ) : ℤ :=
  if j = 0 then 1 else (pureOSequence P.ideal j : ℤ) - (pureOSequence P.ideal (j - 1) : ℤ)

lemma exists_maximal_super {r : ℕ} (I : OrderIdeal r) (m : Monomial r) (hm : m ∈ I.carrier) :
  ∃ M ∈ maximalMonomials I, m ≤ M := by
  delta maximalMonomials OrderIdeal.carrier at*
  norm_num [IsMaximalIn, and_assoc]
  induction I
  let α :=‹ Finset _›.filter (m≤.)
  refine (α.exists_max_image (Set.ncard { a ∈α|a≤.}) ⟨m,by norm_num[ α,hm]⟩).imp fun and⟨A, B⟩=>(Finset.mem_filter.1 A).imp_right fun and=>⟨?_, and⟩
  exact (fun a s M=>(Set.eq_of_subset_of_ncard_le (by gcongr) (B a (by norm_num[s, and.trans M,α])) (α.finite_toSet.sep @_)).ge (by use Finset.mem_filter.mpr (by use@s, and.trans M)) |>.2)

lemma pure_degree_eq (P : PureOrderIdeal 3) (M : Monomial 3) (hM : M ∈ maximalMonomials P.ideal) :
  totalDeg M = socleDegree P := by
  induction P
  delta socleDegree totalDeg IsPure maximalMonomials at *
  apply_rules[Classical.choose_spec]

lemma pure_extension (P : PureOrderIdeal 3) (m : Monomial 3) (hm : m ∈ P.ideal.carrier) (h_deg : totalDeg m < socleDegree P) :
  ∃ v : Fin 3, m + Finsupp.single v (1 : ℕ) ∈ P.ideal.carrier := by
  delta socleDegree totalDeg Ne at*
  delta Classical.choose and at*
  revert‹_›hm
  cases Classical.indefiniteDescription _ _
  rcases P
  induction‹OrderIdeal (3)›
  norm_num[maximalMonomials,IsPure, Finsupp.sum_of_support_subset (s:=⊤)]at*
  norm_num [maximalMonomials]at*
  revert‹Monomial (3)› m‹ Finset _›
  delta IsPure IsMaximalIn Monomial maximalMonomials
  use fun and a s A B R L K V=>by_contra fun and' =>absurd (B and a) ?_
  norm_num[totalDeg, K, L]at V and'⊢
  use fun and R M a=>not_lt.1 (and' a ∘A R ∘fun S i=>? _),L.2.2,by norm_num[ Finsupp.sum_of_support_subset (s:=⊤),V.ne]
  use if I: a=i then I▸.trans (by norm_num) S else by norm_num[I, M i]

lemma pureOSequence_zero_of_pure {r : ℕ} (P : PureOrderIdeal r) : pureOSequence P.ideal 0 = 1 := by
  have h_nonempty := P.maximal_nonempty
  rcases h_nonempty with ⟨max_m, hmax⟩
  have hz_le_max : (0 : Monomial r) ≤ max_m := by exact OrderBot.bot_le max_m
  have hmax_in : max_m ∈ P.ideal.carrier := (Finset.mem_filter.1 hmax).1
  have hz_in : (0 : Monomial r) ∈ P.ideal.carrier := by
    apply OrderIdeal.mem_of_dvd P.ideal hmax_in hz_le_max
  have h_filter : (P.ideal.carrier.filter fun m => totalDeg m = 0) = {0} := by
    ext m
    simp only [Finset.mem_filter, Finset.mem_singleton]
    constructor
    · rintro ⟨_, h_deg⟩
      ext i
      have h_sum : m.sum (fun _ e => e) = 0 := h_deg
      simp_all[m.sum_of_support_subset (s:=⊤)]
    · rintro rfl
      exact ⟨hz_in, by simp [totalDeg]⟩
  unfold pureOSequence
  rw [h_filter]
  exact Finset.card_singleton 0

lemma pureOSeq_eq_sum_FirstDiffZ (P : PureOrderIdeal 3) (k : ℕ) :
  (pureOSequence P.ideal k : ℤ) = (Finset.range (k + 1)).sum (FirstDiffZ P) := by
  induction k with
  | zero =>
    unfold FirstDiffZ
    simp
    have hz := pureOSequence_zero_of_pure P
    omega
  | succ k ih =>
    rw [Finset.sum_range_succ]
    rw [← ih]
    unfold FirstDiffZ
    simp

lemma binomial_of_FirstDiffZ (P : PureOrderIdeal 3) (i : ℕ) (hi0 : 0 < i) :
  (∀ j ≤ i + 1, FirstDiffZ P j = (j : ℤ) + 1) →
  2 * (pureOSequence P.ideal (i - 1) : ℤ) = (i : ℤ) * ((i : ℤ) + 1) ∧
  2 * (pureOSequence P.ideal i : ℤ) = ((i : ℤ) + 1) * ((i : ℤ) + 2) ∧
  2 * (pureOSequence P.ideal (i + 1) : ℤ) = ((i : ℤ) + 2) * ((i : ℤ) + 3) := by
  delta FirstDiffZ and pureOSequence
  induction P
  revert‹OrderIdeal (3)›hi0
  delta totalDeg IsPure maximalMonomials
  use fun and ideal x⟨A, B⟩C=>mod_cast match i with | S+1=>?_
  cases ideal
  clear‹∃_, _›and i
  norm_num[Monomial, sub_eq_iff_eq_add',IsMaximalIn]at*
  replace C : ∀y≤S+2,{ a ∈‹ Finset (Monomial _)›|a.sum ( fun and true => true)=y}.card={ a ∈‹ Finset (Monomial _)›|a.sum ( fun and true => true)=0}.card+∑ a ∈.range y,(a+2)
  · exact (Nat.rec (by{subsingleton}) fun and R M=>Nat.cast_injective ((eq_add_of_sub_eq' (C and.succ M)).trans (R (le_of_lt M)▸mod_cast by rw [ Finset.sum_range_succ, add_assoc])))
  norm_num[IsMaximalIn, C S,C (S+1), C (S+2), Finset.sum_range_succ] at B⊢
  rw[ Finset.card_eq_one.2]
  · exact S.rec (by decide) (by bound[ Finset.sum_range_succ (.+2) ·])
  · use(0), Finset.ext fun and=> Finset.mem_filter.trans ⟨by norm_num+contextual[and.sum_of_support_subset (s:=⊤), and.ext_iff],by norm_num+contextual[‹∀ (x a _),x ≤ a →_› _ _ (by use B.1)]⟩

def setD (P : PureOrderIdeal 3) (j : ℕ) : Finset (Monomial 3) :=
  P.ideal.carrier.filter fun m => totalDeg m = j ∧ m 2 = 0

def setE (P : PureOrderIdeal 3) (j : ℕ) : Finset (Monomial 3) :=
  P.ideal.carrier.filter fun m => totalDeg m = j ∧
    ∀ m2 ∈ P.ideal.carrier, m2 0 = m 0 → m2 1 = m 1 → m2 2 = m 2 + 1 → False

lemma totalDeg_add_single_z (m : Monomial 3) : totalDeg (m + Finsupp.single 2 1) = totalDeg m + 1 := by
  have h_sum1 := deg_eq_degXY_plus_degZ (m + Finsupp.single 2 1)
  have h_sum2 := deg_eq_degXY_plus_degZ m
  unfold degXY degZ at h_sum1 h_sum2
  have h1 : (m + Finsupp.single 2 1 : Monomial 3) 0 = m 0 := by
    change m 0 + Finsupp.single 2 1 0 = m 0; simp
  have h2 : (m + Finsupp.single 2 1 : Monomial 3) 1 = m 1 := by
    change m 1 + Finsupp.single 2 1 1 = m 1; simp
  have h3 : (m + Finsupp.single 2 1 : Monomial 3) 2 = m 2 + 1 := by
    change m 2 + Finsupp.single 2 1 2 = m 2 + 1; simp
  omega

lemma totalDeg_sub_single_z (m : Monomial 3) (hm : m 2 > 0) : totalDeg (m - Finsupp.single 2 1) = totalDeg m - 1 := by
  have h_sum1 := deg_eq_degXY_plus_degZ (m - Finsupp.single 2 1)
  have h_sum2 := deg_eq_degXY_plus_degZ m
  unfold degXY degZ at h_sum1 h_sum2
  have h1 : (m - Finsupp.single 2 1 : Monomial 3) 0 = m 0 := by
    change m 0 - Finsupp.single 2 1 0 = m 0; simp
  have h2 : (m - Finsupp.single 2 1 : Monomial 3) 1 = m 1 := by
    change m 1 - Finsupp.single 2 1 1 = m 1; simp
  have h3 : (m - Finsupp.single 2 1 : Monomial 3) 2 = m 2 - 1 := by
    change m 2 - Finsupp.single 2 1 2 = m 2 - 1; simp
  omega

lemma pureOSeq_eq_D_E (P : PureOrderIdeal 3) (j : ℕ) (hj : 0 < j) :
  FirstDiffZ P j = ((setD P j).card : ℤ) - ((setE P (j - 1)).card : ℤ) := by
  let S1 := P.ideal.carrier.filter fun m => totalDeg m = j - 1 ∧ ¬(∀ m2 ∈ P.ideal.carrier, m2 0 = m 0 → m2 1 = m 1 → m2 2 = m 2 + 1 → False)
  let S2 := P.ideal.carrier.filter fun m => totalDeg m = j ∧ m 2 > 0
  have h_S1_E : (P.ideal.carrier.filter fun m => totalDeg m = j - 1).card = S1.card + (setE P (j - 1)).card := by
    have h_disj : Disjoint S1 (setE P (j - 1)) := by
      rw [Finset.disjoint_iff_ne]
      intro a ha b hb heq
      rw [heq] at ha
      unfold setE at hb
      rw [Finset.mem_filter] at ha hb
      exact ha.2.2 hb.2.2
    have h_union : S1 ∪ setE P (j - 1) = P.ideal.carrier.filter (fun m => totalDeg m = j - 1) := by
      ext m
      simp only [S1, setE, Finset.mem_union, Finset.mem_filter]
      tauto
    rw [← h_union, Finset.card_union_of_disjoint h_disj]
  have h_S2_D : (P.ideal.carrier.filter fun m => totalDeg m = j).card = S2.card + (setD P j).card := by
    have h_disj : Disjoint S2 (setD P j) := by
      rw [Finset.disjoint_iff_ne]
      intro a ha b hb heq
      rw [heq] at ha
      unfold setD at hb
      rw [Finset.mem_filter] at ha hb
      have hz : b 2 = 0 := hb.2.2
      have hg : b 2 > 0 := ha.2.2
      omega
    have h_union : S2 ∪ setD P j = P.ideal.carrier.filter (fun m => totalDeg m = j) := by
      ext m
      simp only [S2, setD, Finset.mem_union, Finset.mem_filter]
      constructor
      · rintro (⟨hm, hdeg, hz⟩ | ⟨hm, hdeg, hz⟩)
        · exact ⟨hm, hdeg⟩
        · exact ⟨hm, hdeg⟩
      · rintro ⟨hm, hdeg⟩
        have hz : m 2 = 0 ∨ m 2 > 0 := by omega
        rcases hz with hz0 | hz_pos
        · right; exact ⟨hm, hdeg, hz0⟩
        · left; exact ⟨hm, hdeg, hz_pos⟩
    rw [← h_union, Finset.card_union_of_disjoint h_disj]
  have h_S1_S2 : S1.card = S2.card := by
    let f : Monomial 3 → Monomial 3 := fun m => m + Finsupp.single 2 1
    have h_inj : Set.InjOn f S1 := by
      intro m1 hm1 m2 hm2 heq
      ext i
      have hi : i.val = 0 ∨ i.val = 1 ∨ i.val = 2 := by omega
      rcases hi with h | h | h
      · have heqi : i = 0 := Fin.ext h
        rw [heqi]
        have hf1 : (f m1) 0 = m1 0 := by simp [f]
        have hf2 : (f m2) 0 = m2 0 := by simp [f]
        have heqi0 : (f m1) 0 = (f m2) 0 := by rw [heq]
        rw [hf1, hf2] at heqi0
        exact heqi0
      · have heqi : i = 1 := Fin.ext h
        rw [heqi]
        have hf1 : (f m1) 1 = m1 1 := by simp [f]
        have hf2 : (f m2) 1 = m2 1 := by simp [f]
        have heqi1 : (f m1) 1 = (f m2) 1 := by rw [heq]
        rw [hf1, hf2] at heqi1
        exact heqi1
      · have heqi : i = 2 := Fin.ext h
        rw [heqi]
        have hf1 : (f m1) 2 = m1 2 + 1 := by simp [f]
        have hf2 : (f m2) 2 = m2 2 + 1 := by simp [f]
        have heqi2 : (f m1) 2 = (f m2) 2 := by rw [heq]
        rw [hf1, hf2] at heqi2
        omega
    have h_map : ∀ m ∈ S1, f m ∈ S2 := by
      intro m hm
      rw [Finset.mem_filter] at hm ⊢
      rcases hm with ⟨hm_c, hm_deg, hm_not_e⟩
      have h_f_in : f m ∈ P.ideal.carrier := by
        push_neg at hm_not_e
        rcases hm_not_e with ⟨m2, hm2, h0, h1, h2⟩
        have h_le : f m ≤ m2 := by
          intro i
          have hi : i.val = 0 ∨ i.val = 1 ∨ i.val = 2 := by omega
          rcases hi with h | h | h
          · have heqi : i = 0 := Fin.ext h
            have hfm0 : (f m) 0 = m 0 := by simp [f]
            rw [heqi, hfm0]
            omega
          · have heqi : i = 1 := Fin.ext h
            have hfm1 : (f m) 1 = m 1 := by simp [f]
            rw [heqi, hfm1]
            omega
          · have heqi : i = 2 := Fin.ext h
            have hfm2 : (f m) 2 = m 2 + 1 := by simp [f]
            rw [heqi, hfm2]
            omega
        exact OrderIdeal.mem_of_dvd P.ideal hm2 h_le
      constructor
      · exact h_f_in
      · constructor
        · have h_sum_f := totalDeg_add_single_z m
          have h_fm : f m = m + Finsupp.single 2 1 := rfl
          rw [h_fm]
          omega
        · have hfm2 : (f m) 2 = m 2 + 1 := by simp [f]
          omega
    have h_surj : ∀ m2 ∈ S2, ∃ m1 ∈ S1, f m1 = m2 := by
      intro m2 hm2
      rw [Finset.mem_filter] at hm2
      rcases hm2 with ⟨hm2_c, hm2_deg, hm2_z⟩
      let m1 := m2 - Finsupp.single 2 1
      use m1
      have h_f_m1 : f m1 = m2 := by
        ext i
        have hi : i.val = 0 ∨ i.val = 1 ∨ i.val = 2 := by omega
        rcases hi with h | h | h
        · have heqi : i = 0 := Fin.ext h
          rw [heqi]
          simp [f, m1]
        · have heqi : i = 1 := Fin.ext h
          rw [heqi]
          simp [f, m1]
        · have heqi : i = 2 := Fin.ext h
          rw [heqi]
          have hm2_z_val : m2 2 > 0 := hm2_z
          simp [f, m1]
          omega
      have hm1_in_S1 : m1 ∈ S1 := by
        rw [Finset.mem_filter]
        have h_le : m1 ≤ m2 := by intro i; exact tsub_le_self
        have hm1_c : m1 ∈ P.ideal.carrier := OrderIdeal.mem_of_dvd P.ideal hm2_c h_le
        constructor
        · exact hm1_c
        · constructor
          · have h_deg := totalDeg_sub_single_z m2 hm2_z
            have hm1 : m1 = m2 - Finsupp.single 2 1 := rfl
            rw [hm1]
            omega
          · push_neg
            use m2
            constructor
            · exact hm2_c
            · constructor
              · simp [m1]
              · constructor
                · simp [m1]
                · simp [m1]
                  have h_gt : m2 2 > 0 := hm2_z
                  omega
      exact ⟨hm1_in_S1, h_f_m1⟩
    have h_image : S1.image f = S2 := by
      ext m2
      rw [Finset.mem_image]
      constructor
      · rintro ⟨m1, hm1, heq⟩
        rw [← heq]
        exact h_map m1 hm1
      · intro hm2
        exact h_surj m2 hm2
    rw [← h_image]
    exact (Finset.card_image_of_injOn h_inj).symm
  unfold FirstDiffZ
  simp [hj.ne']
  have h_j : (pureOSequence P.ideal j : ℤ) = ((P.ideal.carrier.filter fun m => totalDeg m = j).card : ℤ) := by rfl
  have h_jm1 : (pureOSequence P.ideal (j - 1) : ℤ) = ((P.ideal.carrier.filter fun m => totalDeg m = j - 1).card : ℤ) := by rfl
  rw [h_j, h_jm1, h_S1_E, h_S2_D, h_S1_S2]
  push_cast
  ring

def setD_X (P : PureOrderIdeal 3) (j : ℕ) : Finset ℕ :=
  (setD P j).image fun m => m 0

lemma card_setD_eq_card_setD_X (P : PureOrderIdeal 3) (j : ℕ) :
  (setD P j).card = (setD_X P j).card := by
  delta setD_X setD
  rw [ Finset.card_image_of_injOn fun and _ _ A B=>(?_)]
  simp_all[totalDeg,←List.ofFn_inj,eq_comm, Fin.sum_univ_three]
  simp_all[ Fin.sum_univ_three, and.ext_iff, Finsupp.sum_of_support_subset (s:=⊤), Fin.forall_iff_succ]
  omega

lemma setD_X_down (P : PureOrderIdeal 3) (j x : ℕ) (hx : x ∈ setD_X P (j + 1)) :
  (x < j + 1 → x ∈ setD_X P j) ∧ (x > 0 → x - 1 ∈ setD_X P j) := by
  simp_rw [x.lt_succ_iff, setD_X,] at hx⊢
  delta setD Monomial at*
  norm_num [totalDeg] at*
  induction P
  obtain ⟨a,⟨A, B, _⟩, rfl⟩:=hx
  cases‹OrderIdeal 3›
  norm_num[a.sum_of_support_subset (s:=⊤), and_assoc,IsPure]at*
  norm_num[Monomial,IsPure,‹_=0›, Fin.sum_univ_three, Finsupp.sum_of_support_subset (s:=⊤), Finsupp.le_def, Fin.forall_iff_succ]at‹IsPure _› A B⊢
  cases h: a (1)
  · use (by bound), fun and=>⟨.single 0 j,‹∀ (x a _),x ≤ a →x ∈_› _ _ (by assumption) (by simp_all[ Finsupp.le_def, Fin.forall_iff_succ]),by simp_all⟩
  norm_num[←Nat.succ_injective (h▸B),←add_assoc, Finsupp.le_def, Fin.forall_iff_succ] at A⊢
  use (by exists Finsupp.equivFunOnFinite.symm ![a 0,by valid, 0x00],‹∀ (x A B _),x ∈_› _ _ (by valid) (by norm_num[ Finsupp.le_def,h, Fin.forall_iff_succ]))
  use fun and=>⟨.single 0 (a 0-1)+.single (1) (by valid+1),?_⟩
  exact ⟨‹∀ (x B _),x≤B →x ∈_› _ _ (by valid) (by match. with|0|1|2=>simp_all),by simp_all[add_comm (by valid),←add_assoc,Nat.succ_le]⟩

lemma setD_X_bound (P : PureOrderIdeal 3) (j x : ℕ) (hx : x ∈ setD_X P j) :
  x ≤ j := by
  simp_all only[setD_X,Set.mem_setOf]
  norm_num [setD] at hx
  cases P
  delta totalDeg IsPure maximalMonomials at*
  obtain ⟨y,⟨z,rfl, _⟩, rfl⟩:=hx
  norm_num[y.sum_of_support_subset (s:=⊤),Fin.sum_univ_three]at z⊢
  omega

lemma card_setD_le (P : PureOrderIdeal 3) (j : ℕ) :
  (setD P (j + 1)).card ≤ (setD P j).card ∨ ((setD P j).card = j + 1 ∧ (setD P (j + 1)).card = j + 2) := by
  have h_cases : (setD P (j + 1)).card ≤ (setD P j).card ∨ (setD P j).card = j + 1 := by
    rw [card_setD_eq_card_setD_X, card_setD_eq_card_setD_X]
    apply macaulay_2_vars (setD_X P)
    · intro i y hy
      exact setD_X_down P i y hy
    · intro i y hy
      exact setD_X_bound P i y hy
  rcases h_cases with h_le | h_eq
  · left
    exact h_le
  · have h_bound : (setD P (j + 1)).card ≤ j + 2 := by
      have hd_x_bound : ∀ x ∈ setD_X P (j + 1), x ≤ j + 1 := setD_X_bound P (j + 1)
      have hd_card_x : (setD_X P (j + 1)).card ≤ j + 2 := by
        have h_sub : setD_X P (j + 1) ⊆ Finset.range (j + 2) := by
          intro x hx
          rw [Finset.mem_range]
          have hxb := hd_x_bound x hx
          omega
        have h_le := Finset.card_le_card h_sub
        rw [Finset.card_range] at h_le
        exact h_le
      have heq := card_setD_eq_card_setD_X P (j + 1)
      omega
    have h_cases2 : (setD P (j + 1)).card ≤ j + 1 ∨ (setD P (j + 1)).card = j + 2 := by omega
    rcases h_cases2 with h_le2 | h_eq2
    · left
      omega
    · right
      constructor
      · exact h_eq
      · exact h_eq2



lemma slice_size_Z_le (P : PureOrderIdeal 3) (k d : ℕ) :
  slice_size P (k + 1) d ≤ slice_size P k d := by
  let f : Monomial 3 → Monomial 3 := fun m => m - Finsupp.single 2 1
  have h_inj : ∀ m ∈ P.ideal.carrier.filter (fun m => degZ m = k + 1 ∧ degXY m = d),
    f m ∈ P.ideal.carrier.filter (fun m => degZ m = k ∧ degXY m = d) := by
    intro m hm
    rw [Finset.mem_filter] at hm ⊢
    rcases hm with ⟨hm_c, hm_deg⟩
    have h_le : f m ≤ m := by intro i; exact tsub_le_self
    have hf_c : f m ∈ P.ideal.carrier := OrderIdeal.mem_of_dvd P.ideal hm_c h_le
    constructor
    · exact hf_c
    · constructor
      · have h_sub : (f m) 2 = m 2 - 1 := by simp [f]
        have hz : m 2 = k + 1 := hm_deg.1
        unfold degZ
        rw [h_sub, hz]
        omega
      · have h_sub0 : (f m) 0 = m 0 := by simp [f]
        have h_sub1 : (f m) 1 = m 1 := by simp [f]
        have hxy : m 0 + m 1 = d := hm_deg.2
        unfold degXY
        rw [h_sub0, h_sub1]
        exact hxy
  have h_inj_on : ∀ m1 ∈ P.ideal.carrier.filter (fun m => degZ m = k + 1 ∧ degXY m = d),
    ∀ m2 ∈ P.ideal.carrier.filter (fun m => degZ m = k + 1 ∧ degXY m = d),
    f m1 = f m2 → m1 = m2 := by
    intro m1 hm1 m2 hm2 heq
    rw [Finset.mem_filter] at hm1 hm2
    ext i
    have hi : i.val = 0 ∨ i.val = 1 ∨ i.val = 2 := by omega
    rcases hi with h | h | h
    · have heqi : i = 0 := Fin.ext h
      rw [heqi]
      have hf1 : (f m1) 0 = m1 0 := by simp [f]
      have hf2 : (f m2) 0 = m2 0 := by simp [f]
      have heqi0 : (f m1) 0 = (f m2) 0 := by rw [heq]
      rw [hf1, hf2] at heqi0
      exact heqi0
    · have heqi : i = 1 := Fin.ext h
      rw [heqi]
      have hf1 : (f m1) 1 = m1 1 := by simp [f]
      have hf2 : (f m2) 1 = m2 1 := by simp [f]
      have heqi1 : (f m1) 1 = (f m2) 1 := by rw [heq]
      rw [hf1, hf2] at heqi1
      exact heqi1
    · have heqi : i = 2 := Fin.ext h
      rw [heqi]
      have hz1 : m1 2 = k + 1 := hm1.2.1
      have hz2 : m2 2 = k + 1 := hm2.2.1
      rw [hz1, hz2]
  unfold slice_size
  exact Finset.card_le_card_of_injOn f h_inj h_inj_on

lemma FirstDiffZ_le_slice0 (P : PureOrderIdeal 3) (j : ℕ) (hj : 0 < j) :
  (pureOSequence P.ideal j : ℤ) - (pureOSequence P.ideal (j - 1) : ℤ) ≤ (slice_size P 0 j : ℤ) := by
  have h_j := pureOSeq_eq_sum_slice P j
  have h_jm1 := pureOSeq_eq_sum_slice P (j - 1)
  have h_split : (Finset.range (j + 1)).sum (fun k => (slice_size P k (j - k) : ℤ)) =
    (slice_size P 0 j : ℤ) + (Finset.range j).sum (fun k => (slice_size P (k + 1) (j - 1 - k) : ℤ)) := by
    rw [Finset.sum_range_succ']
    have hz : j - 0 = j := by omega
    have h_eq : slice_size P 0 (j - 0) = slice_size P 0 j := by rw [hz]
    rw [h_eq]
    have h_sum_eq : (Finset.range j).sum (fun (x : ℕ) => (slice_size P (x + 1) (j - (x + 1)) : ℤ)) = (Finset.range j).sum (fun k => (slice_size P (k + 1) (j - 1 - k) : ℤ)) := by
      apply Finset.sum_congr rfl
      intro x hx
      have h_eq2 : j - (x + 1) = j - 1 - x := by omega
      rw [h_eq2]
    rw [h_sum_eq]
    ring
  have h_sum_le : (Finset.range j).sum (fun k => (slice_size P (k + 1) (j - 1 - k) : ℤ)) ≤
    (Finset.range j).sum (fun k => (slice_size P k (j - 1 - k) : ℤ)) := by
    apply Finset.sum_le_sum
    intro k hk
    have h_le := slice_size_Z_le P k (j - 1 - k)
    omega
  have h_sum_j : (pureOSequence P.ideal j : ℤ) = (Finset.range (j + 1)).sum (fun k => (slice_size P k (j - k) : ℤ)) := by
    rw [h_j]
    push_cast
    rfl
  have h_sum_jm1 : (pureOSequence P.ideal (j - 1) : ℤ) = (Finset.range ((j - 1) + 1)).sum (fun k => (slice_size P k (j - 1 - k) : ℤ)) := by
    rw [h_jm1]
    push_cast
    rfl
  have h_range_eq : (j - 1) + 1 = j := by omega
  rw [h_range_eq] at h_sum_jm1
  linarith


lemma FirstDiffZ_le_max (P : PureOrderIdeal 3) (j : ℕ) :
  FirstDiffZ P j ≤ (j : ℤ) + 1 := by
  unfold FirstDiffZ
  cases j with
  | zero =>
    simp
  | succ j =>
    simp
    have hj : 0 < j + 1 := by omega
    have h_le := FirstDiffZ_le_slice0 P (j + 1) hj
    have h_sub : j + 1 - 1 = j := by omega
    rw [h_sub] at h_le
    have h_slice := pureOSeq_bound_slice P 0 (j + 1)
    linarith

lemma slice_diff_eq_card (P : PureOrderIdeal 3) (k d : ℕ) :
  slice_size P k d - slice_size P (k + 1) d =
    (P.ideal.carrier.filter (fun m => degZ m = k ∧ degXY m = d ∧ m + Finsupp.single 2 1 ∉ P.ideal.carrier)).card := by
  symm
  show ( _)=((id) _)-id (@ _)
  induction P
  norm_num[degXY,degZ,maximalMonomials,IsPure,Finset.filter_and,Finset.filter_not,Finset.card_sdiff,Finset.Nonempty]at*
  simp_all[maximalMonomials,IsPure, false, ← Finset.inter_sdiff_assoc _,Nat.eq_sub_of_add_eq ( Finset.card_sdiff_add_card_inter _ _), false, Finset.inter_eq_left.mpr]
  induction‹OrderIdeal (3)›
  revert‹ Finset _›k(d)
  delta totalDeg IsMaximalIn Monomial
  use fun and A B a s⟨R, M⟩=>congr_arg _ (( Finset.exists_max_image _ (. 2) ⟨ R, M⟩).elim fun and (H) =>? _)
  apply Finset.card_bij
  show∀ (x _),(x)+.single 02 1 ∈_
  · norm_num+decide+contextual
  · exact fun and _ _ _ => add_right_cancel
  use fun R M=>⟨R-.single 2 1,(Finset.mem_inter.1 M).elim fun and α=>?_⟩
  norm_num+decide[a (Finset.filter_subset _ _ α),Finsupp.le_def,Fin.forall_iff_succ, Finset.mem_filter.1 α, Finset.mem_filter.1 and,tsub_add_cancel_of_le]

lemma card_setE_eq_sum (P : PureOrderIdeal 3) (j : ℕ) :
  (setE P j).card = (Finset.range (j + 1)).sum (fun k =>
    (P.ideal.carrier.filter (fun m => degZ m = k ∧ degXY m = j - k ∧ m + Finsupp.single 2 1 ∉ P.ideal.carrier)).card) := by
  delta setE degXY degZ
  push_cast[totalDeg, true, Fin.sum_univ_three, false, Finset.card_filter]
  cases P
  cases‹OrderIdeal (3)›
  norm_num[IsPure,ite_and, Fin.sum_univ_three, Finsupp.sum_of_support_subset (s:=⊤)]at *
  refine(Finset.sum_comm.trans (congr_arg _ (funext fun and=>?_))).symm
  norm_num at*
  refine if a:_ then (if_pos a).trans (if R:_ then (if_pos R)▸if_pos (R▸j.sub_add_cancel a)▸.trans (ite_not ..).symm (if_congr ?_ rfl rfl )else (if_neg R)▸ (if_neg (by valid)).symm)else by grind
  use fun and A B _ _ _=>and (‹∀ (x a _),x ≤ a →x ∈_› _ _ (by assumption) (by match. with|0|1|2=>simp_all)), (by norm_num+decide ∘. _)

lemma card_setE_eq_sum_slice_diff (P : PureOrderIdeal 3) (j : ℕ) :
  (setE P j).card = (Finset.range (j + 1)).sum (fun k => slice_size P k (j - k) - slice_size P (k + 1) (j - k)) := by
  rw [card_setE_eq_sum P j]
  apply Finset.sum_congr rfl
  intro k _
  exact (slice_diff_eq_card P k (j - k)).symm

def slice_X (P : PureOrderIdeal 3) (k d : ℕ) : Finset ℕ :=
  (P.ideal.carrier.filter fun m => degZ m = k ∧ degXY m = d).image fun m => m 0

lemma card_slice_eq_card_X (P : PureOrderIdeal 3) (k d : ℕ) :
  slice_size P k d = (slice_X P k d).card := by simp_all![slice_X]
                                                change(id _) = _
                                                cases P
                                                delta IsPure degXY degZ maximalMonomials at*
                                                induction‹OrderIdeal (3)›
                                                delta totalDeg IsMaximalIn id Monomial at *
                                                rw[ Finset.card_image_of_injOn fun and _ _ _ _=> Finsupp.ext ?_]
                                                use (by match. with|0=> valid|1|2=>cases Finset.mem_filter.1 ‹and ∈_› with cases Finset.mem_filter.1 (by valid) with omega)

lemma slice_X_down (P : PureOrderIdeal 3) (k d x : ℕ) (hx : x ∈ slice_X P k (d + 1)) :
  (x < d + 1 → x ∈ slice_X P k d) ∧ (x > 0 → x - 1 ∈ slice_X P k d) := by change(x) ∈ {s |_}at @hx
                                                                          norm_num[slice_X,x.lt_succ] at*
                                                                          obtain ⟨y,⟨z,rfl, _⟩, rfl⟩:=hx
                                                                          induction P
                                                                          delta degXY IsPure degZ maximalMonomials at*
                                                                          induction‹OrderIdeal (3)›
                                                                          norm_num[Monomial, and_assoc]at‹_ = _›z⊢
                                                                          norm_num[totalDeg,IsMaximalIn, Finset.Nonempty]at‹_ = _›‹∀_, _›‹∃_, _›⊢
                                                                          delta Monomial at *
                                                                          revert‹ Finset _›y
                                                                          use fun and a s A B h⟨x,R, L⟩=> if I:and 0=0 then(? _)else(? _)
                                                                          · use fun and' =>⟨.single (1) d+.single (2) (and 2),?_⟩,by valid
                                                                            exact ⟨ A B (by match. with|0|1|2=>norm_num+decide[I, zero_add (and _)▸I▸a,d.le_succ]),by norm_num+decide[I]⟩
                                                                          rcases Nat.exists_eq_succ_of_ne_zero I
                                                                          norm_num[←Nat.succ_injective ((Nat.succ_add _ _▸‹_›▸a)),by valid, Finsupp.le_def, Fin.forall_iff_succ] at B⊢
                                                                          exists fun and' =>⟨.single 0 (by valid+1)+.single (1) (and (1)-1)+.single (2) (and 2),A B ? _,?_⟩,.single 0 (by valid)+.single (1) (and (1))+.single (2) (and 2),A B ?_
                                                                          · exact (by match · with|0|2 | ( (1)) =>norm_num +decide[show (and _) = _ by assumption])
                                                                          · norm_num+decide[and',add_assoc]
                                                                          · use (by match· with|0|1|(2) =>norm_num+decide [show and 0 = _ by valid])
                                                                          · norm_num+decide

lemma slice_X_bound (P : PureOrderIdeal 3) (k d x : ℕ) (hx : x ∈ slice_X P k d) :
  x ≤ d := by change x ∈({s |_}) at@hx
              norm_num[slice_X] at hx
              delta degXY at*
              omega

lemma card_slice_le (P : PureOrderIdeal 3) (k d : ℕ) :
  slice_size P k (d + 1) ≤ slice_size P k d ∨ (slice_size P k d = d + 1 ∧ slice_size P k (d + 1) = d + 2) := by
  have h_cases : slice_size P k (d + 1) ≤ slice_size P k d ∨ slice_size P k d = d + 1 := by
    rw [card_slice_eq_card_X, card_slice_eq_card_X]
    apply macaulay_2_vars (slice_X P k)
    · intro i y hy
      exact slice_X_down P k i y hy
    · intro i y hy
      exact slice_X_bound P k i y hy
  rcases h_cases with h_le | h_eq
  · left
    exact h_le
  · have h_bound : slice_size P k (d + 1) ≤ d + 2 := by
      have hd_x_bound : ∀ x ∈ slice_X P k (d + 1), x ≤ d + 1 := slice_X_bound P k (d + 1)
      have hd_card_x : (slice_X P k (d + 1)).card ≤ d + 2 := by
        have h_sub : slice_X P k (d + 1) ⊆ Finset.range (d + 2) := by
          intro x hx
          rw [Finset.mem_range]
          have hxb := hd_x_bound x hx
          omega
        have h_le := Finset.card_le_card h_sub
        rw [Finset.card_range] at h_le
        exact h_le
      have heq := card_slice_eq_card_X P k (d + 1)
      omega
    have h_cases2 : slice_size P k (d + 1) ≤ d + 1 ∨ slice_size P k (d + 1) = d + 2 := by omega
    rcases h_cases2 with h_le2 | h_eq2
    · left
      omega
    · right
      constructor
      · exact h_eq
      · exact h_eq2

lemma slice_X_subset (P : PureOrderIdeal 3) (k d : ℕ) :
  slice_X P (k + 1) d ⊆ slice_X P k d := by
  intro x hx
  unfold slice_X at hx ⊢
  simp only [Finset.mem_image, Finset.mem_filter] at hx ⊢
  rcases hx with ⟨m, ⟨hm, hz, hxy⟩, rfl⟩
  use m - Finsupp.single 2 1
  have h_le : m - Finsupp.single 2 1 ≤ m := by intro i; exact tsub_le_self
  refine ⟨⟨OrderIdeal.mem_of_dvd P.ideal hm h_le, ?_, ?_⟩, ?_⟩
  · unfold degZ at hz ⊢; simp; omega
  · unfold degXY at hxy ⊢; simp; omega
  · simp

lemma slice_diff_le_slice_diff_next (P : PureOrderIdeal 3) (k d : ℕ) (hd : d + k < socleDegree P / 2) :
  slice_size P k d - slice_size P (k + 1) d ≤ slice_size P k (d + 1) - slice_size P (k + 1) (d + 1) := by
  let A := slice_X P k d \ slice_X P (k + 1) d
  let B := slice_X P k (d + 1) \ slice_X P (k + 1) (d + 1)
  have hA : slice_size P k d - slice_size P (k + 1) d = A.card := by
    rw [card_slice_eq_card_X P k d, card_slice_eq_card_X P (k + 1) d]
    have h_sub : slice_X P (k + 1) d ⊆ slice_X P k d := slice_X_subset P k d
    have h_inter : slice_X P (k + 1) d ∩ slice_X P k d = slice_X P (k + 1) d := Finset.inter_eq_left.mpr h_sub
    rw [← h_inter]
    exact Finset.card_sdiff.symm
  have hB : slice_size P k (d + 1) - slice_size P (k + 1) (d + 1) = B.card := by
    rw [card_slice_eq_card_X P k (d + 1), card_slice_eq_card_X P (k + 1) (d + 1)]
    have h_sub : slice_X P (k + 1) (d + 1) ⊆ slice_X P k (d + 1) := slice_X_subset P k (d + 1)
    have h_inter : slice_X P (k + 1) (d + 1) ∩ slice_X P k (d + 1) = slice_X P (k + 1) (d + 1) := Finset.inter_eq_left.mpr h_sub
    rw [← h_inter]
    exact Finset.card_sdiff.symm
  rw [hA, hB]
  have h_cases : A ⊆ B ∨ ∃ u ∈ A \ B, ∀ a ∈ A \ B, u ≤ a := by
    by_cases h : A ⊆ B
    · left; exact h
    · right
      let C := A \ B
      have hC_nonempty : C.Nonempty := by
        rw [Finset.nonempty_iff_ne_empty]
        intro h_empty
        have : A ⊆ B := by
          intro x hx
          have h_notin : x ∉ C := by rw [h_empty]; simp
          rw [Finset.mem_sdiff] at h_notin
          tauto
        contradiction
      let u := C.min' hC_nonempty
      use u
      constructor
      · exact Finset.min'_mem C hC_nonempty
      · intro a ha
        exact Finset.min'_le C a ha
  rcases h_cases with h_sub | ⟨u, hu_in, hu_min⟩
  · exact Finset.card_le_card h_sub
  · let g : ℕ → ℕ := fun a => if a < u then a else a + 1
    have h_inj : Set.InjOn g A := by
      intro a1 _ a2 _ heq
      dsimp [g] at heq
      split at heq <;> split at heq
      · exact heq
      · omega
      · omega
      · omega
    have h_map : ∀ a ∈ A, g a ∈ B := by
      intro a ha
      dsimp [g]
      split
      next h_lt =>
        have h_notin : a ∉ A \ B := by
          intro h_in
          have := hu_min a h_in
          omega
        rw [Finset.mem_sdiff] at h_notin
        tauto
      next h_ge =>
        by_contra! h_not_in
        have h_u_A : u ∈ A := by
          have := hu_in
          rw [Finset.mem_sdiff] at this
          exact this.1
        have h_u_not_B : u ∉ B := by
          have := hu_in
          rw [Finset.mem_sdiff] at this
          exact this.2
        have ha_in_X : a ∈ slice_X P k d := by rw [Finset.mem_sdiff] at ha; exact ha.1
        have ha_notin_X : a ∉ slice_X P (k + 1) d := by rw [Finset.mem_sdiff] at ha; exact ha.2
        have hu_in_X : u ∈ slice_X P k d := by rw [Finset.mem_sdiff] at h_u_A; exact h_u_A.1
        have hu_notin_X : u ∉ slice_X P (k + 1) d := by rw [Finset.mem_sdiff] at h_u_A; exact h_u_A.2

        have hu_le_d : u ≤ d := slice_X_bound P k d u hu_in_X
        have ha_le_d : a ≤ d := slice_X_bound P k d a ha_in_X

        unfold slice_X at hu_in_X
        simp only [Finset.mem_image, Finset.mem_filter] at hu_in_X
        rcases hu_in_X with ⟨mu, ⟨hmu, hmu_z, hmu_xy⟩, hmu_x⟩
        have hmu_eq : mu = Finsupp.single 0 u + Finsupp.single 1 (d - u) + Finsupp.single 2 k := by
          ext i
          have hi : i.val = 0 ∨ i.val = 1 ∨ i.val = 2 := by omega
          unfold degZ at hmu_z; unfold degXY at hmu_xy
          rcases hi with h | h | h
          · have heqi : i = 0 := Fin.ext h; rw [heqi, hmu_x]; simp
          · have heqi : i = 1 := Fin.ext h; rw [heqi]; simp; omega
          · have heqi : i = 2 := Fin.ext h; rw [heqi, hmu_z]; simp
        have h_max_u := exists_maximal_super P.ideal mu hmu
        rcases h_max_u with ⟨Mu, hMu_max, hMu_le⟩
        have hMu_deg : totalDeg Mu = socleDegree P := pure_degree_eq P Mu hMu_max
        have hMu_carrier : Mu ∈ P.ideal.carrier := (Finset.mem_filter.mp hMu_max).1
        have hMu_z : Mu 2 = k := by
          have h_le_z : mu 2 ≤ Mu 2 := hMu_le 2
          have h_mu_z : mu 2 = k := by rw [hmu_eq]; simp
          rw [h_mu_z] at h_le_z
          by_contra! h_gt
          have h_k1 : k + 1 ≤ Mu 2 := by omega
          have hm_k1 : mu + Finsupp.single 2 1 ≤ Mu := by
            intro i
            have hi : i.val = 0 ∨ i.val = 1 ∨ i.val = 2 := by omega
            rcases hi with h | h | h
            · have heqi : i = 0 := Fin.ext h; rw [heqi]; simp; exact hMu_le 0
            · have heqi : i = 1 := Fin.ext h; rw [heqi]; simp; exact hMu_le 1
            · have heqi : i = 2 := Fin.ext h; rw [heqi]; simp; omega
          have hm_k1_in : mu + Finsupp.single 2 1 ∈ P.ideal.carrier := OrderIdeal.mem_of_dvd P.ideal hMu_carrier hm_k1
          have h_contra : u ∈ slice_X P (k + 1) d := by
            unfold slice_X
            rw [Finset.mem_image]
            use mu + Finsupp.single 2 1
            refine ⟨?_, ?_⟩
            · rw [Finset.mem_filter]
              refine ⟨hm_k1_in, ?_, ?_⟩
              · unfold degZ; rw [hmu_eq]; simp
              · unfold degXY; rw [hmu_eq]; simp; omega
            · rw [hmu_eq]; simp
          exact hu_notin_X h_contra
        have hMu_y : Mu 1 = d - u := by
          have h_le_y : mu 1 ≤ Mu 1 := hMu_le 1
          have h_mu_y : mu 1 = d - u := by rw [hmu_eq]; simp
          rw [h_mu_y] at h_le_y
          by_contra! h_gt
          have h_d1 : d - u + 1 ≤ Mu 1 := by omega
          have hm_y1 : mu + Finsupp.single 1 1 ≤ Mu := by
            intro i
            have hi : i.val = 0 ∨ i.val = 1 ∨ i.val = 2 := by omega
            rcases hi with h | h | h
            · have heqi : i = 0 := Fin.ext h; rw [heqi]; simp; exact hMu_le 0
            · have heqi : i = 1 := Fin.ext h; rw [heqi]; simp; omega
            · have heqi : i = 2 := Fin.ext h; rw [heqi]; simp; exact hMu_le 2
          have hm_y1_in : mu + Finsupp.single 1 1 ∈ P.ideal.carrier := OrderIdeal.mem_of_dvd P.ideal hMu_carrier hm_y1
          have hu_B_in : u ∈ slice_X P k (d + 1) := by
            unfold slice_X
            rw [Finset.mem_image]
            use mu + Finsupp.single 1 1
            refine ⟨?_, ?_⟩
            · rw [Finset.mem_filter]
              refine ⟨hm_y1_in, ?_, ?_⟩
              · unfold degZ; rw [hmu_eq]; simp
              · unfold degXY; rw [hmu_eq]; simp; omega
            · rw [hmu_eq]; simp
          have hu_B_notin : u ∉ slice_X P (k + 1) (d + 1) := by
            intro h_in
            unfold slice_X at h_in
            rw [Finset.mem_image] at h_in
            rcases h_in with ⟨m2, hm2_f, hm2_x⟩
            rw [Finset.mem_filter] at hm2_f
            have hm_k1 : m2 - Finsupp.single 1 1 ∈ P.ideal.carrier := by
              have h_le : m2 - Finsupp.single 1 1 ≤ m2 := by intro i; exact tsub_le_self
              exact OrderIdeal.mem_of_dvd P.ideal hm2_f.1 h_le
            have h_contra : u ∈ slice_X P (k + 1) d := by
              unfold slice_X
              rw [Finset.mem_image]
              use m2 - Finsupp.single 1 1
              refine ⟨?_, ?_⟩
              · rw [Finset.mem_filter]
                refine ⟨hm_k1, ?_, ?_⟩
                · unfold degZ at hm2_f ⊢; simp; exact hm2_f.2.1
                · unfold degXY at hm2_f ⊢; simp; omega
              · simp; exact hm2_x
            exact hu_notin_X h_contra
          have hu_B_true : u ∈ B := by
            rw [Finset.mem_sdiff]
            exact ⟨hu_B_in, hu_B_notin⟩
          exact h_u_not_B hu_B_true
        have hMu_x : Mu 0 = socleDegree P - k - (d - u) := by
          have h_sum := deg_eq_degXY_plus_degZ Mu
          unfold degXY degZ at h_sum
          rw [hMu_z, hMu_y] at h_sum
          omega
        have h_socle_bound : 2 * (d + k) + 1 ≤ socleDegree P := by omega
        have h_a_1_le_Mu_0 : a + 1 ≤ Mu 0 := by
          rw [hMu_x]
          omega
        have hm_a1 : Finsupp.single 0 (a + 1) + Finsupp.single 1 (d - a) + Finsupp.single 2 k ≤ Mu := by
          intro i
          have hi : i.val = 0 ∨ i.val = 1 ∨ i.val = 2 := by omega
          rcases hi with h | h | h
          · have heqi : i = 0 := Fin.ext h; rw [heqi]; simp; exact h_a_1_le_Mu_0
          · have heqi : i = 1 := Fin.ext h; rw [heqi]; simp; rw [hMu_y]; omega
          · have heqi : i = 2 := Fin.ext h; rw [heqi]; simp; omega
        have hm_a1_in : Finsupp.single 0 (a + 1) + Finsupp.single 1 (d - a) + Finsupp.single 2 k ∈ P.ideal.carrier := OrderIdeal.mem_of_dvd P.ideal hMu_carrier hm_a1
        have ha_B_in : a + 1 ∈ slice_X P k (d + 1) := by
          simp only [slice_X, Finset.mem_image, Finset.mem_filter]
          use Finsupp.single 0 (a + 1) + Finsupp.single 1 (d - a) + Finsupp.single 2 k
          refine ⟨⟨hm_a1_in, ?_, ?_⟩, ?_⟩
          · unfold degZ; simp
          · unfold degXY; simp; omega
          · simp
        have ha_B_notin : a + 1 ∉ slice_X P (k + 1) (d + 1) := by
          intro h_in
          simp only [slice_X, Finset.mem_image, Finset.mem_filter] at h_in
          rcases h_in with ⟨m2, ⟨hm2_f, hz2, hxy2⟩, hm2_x⟩
          have hm_k1 : m2 - Finsupp.single 0 1 ∈ P.ideal.carrier := by
            have h_le : m2 - Finsupp.single 0 1 ≤ m2 := by intro i; exact tsub_le_self
            exact OrderIdeal.mem_of_dvd P.ideal hm2_f h_le
          have h_contra : a ∈ slice_X P (k + 1) d := by
            simp only [slice_X, Finset.mem_image, Finset.mem_filter]
            use m2 - Finsupp.single 0 1
            refine ⟨⟨hm_k1, ?_, ?_⟩, ?_⟩
            · unfold degZ at hz2 ⊢; simp; exact hz2
            · unfold degXY at hxy2 ⊢; simp; omega
            · simp; omega
          exact ha_notin_X h_contra
        have ha_B_true : a + 1 ∈ B := by
          rw [Finset.mem_sdiff]
          exact ⟨ha_B_in, ha_B_notin⟩
        exact h_not_in ha_B_true
    exact Finset.card_le_card_of_injOn g h_map h_inj

lemma min_not_full_slice (P : PureOrderIdeal 3) (j : ℕ)
  (h_base : slice_size P 0 (j + 1) = j + 2)
  (h_not_full : ∃ k ≤ j + 1, slice_size P k (j + 1 - k) < j + 2 - k) :
  ∃ K ≤ j + 1, 0 < K ∧ slice_size P K (j + 1 - K) < j + 2 - K ∧
    ∀ k < K, slice_size P k (j + 1 - k) = j + 2 - k := by
  let S := (Finset.range (j + 2)).filter (fun k => slice_size P k (j + 1 - k) < j + 2 - k)
  have h_nonempty : S.Nonempty := by
    rcases h_not_full with ⟨k, hk_le, hk_lt⟩
    use k
    rw [Finset.mem_filter, Finset.mem_range]
    exact ⟨by omega, hk_lt⟩
  let K := S.min' h_nonempty
  have hK_mem : K ∈ S := Finset.min'_mem S h_nonempty
  rw [Finset.mem_filter, Finset.mem_range] at hK_mem
  use K
  constructor
  · omega
  · constructor
    · have hK_prop : slice_size P K (j + 1 - K) < j + 2 - K := hK_mem.2
      have h_K_not_0 : K ≠ 0 := by
        intro h0
        rw [h0] at hK_prop
        have h_contra : slice_size P 0 (j + 1) < j + 2 := by
          have h1 : j + 1 - 0 = j + 1 := by omega
          have h2 : j + 2 - 0 = j + 2 := by omega
          rw [h1, h2] at hK_prop
          exact hK_prop
        linarith [h_base]
      omega
    · constructor
      · exact hK_mem.2
      · intro k hk
        have hk_not_mem : k ∉ S := by
          intro h_in
          have h_min := Finset.min'_le S k h_in
          omega
        rw [Finset.mem_filter, Finset.mem_range] at hk_not_mem
        push_neg at hk_not_mem
        have hk_le_j1 : k < j + 2 := by omega
        have hk_ge : j + 2 - k ≤ slice_size P k (j + 1 - k) := hk_not_mem hk_le_j1
        have hk_bound := pureOSeq_bound_slice P k (j + 1 - k)
        have h_eq : slice_size P k (j + 1 - k) = j + 2 - k := by omega
        exact h_eq

lemma slice_diff_strict_increase (P : PureOrderIdeal 3) (k d : ℕ) (hd_pos : 0 < d)
  (h_full : slice_size P k d = d + 1) (h_not_full : slice_size P (k + 1) d < d + 1) :
  slice_size P k (d - 1) - slice_size P (k + 1) (d - 1) + 1 ≤ slice_size P k d - slice_size P (k + 1) d := by
  have h_bound_k := pureOSeq_bound_slice P k (d - 1)
  have h_slice_k1 := card_slice_le P (k + 1) (d - 1)
  have h_sub : d - 1 + 1 = d := by omega
  rw [h_sub] at h_slice_k1
  rcases h_slice_k1 with h_le | ⟨h_eq1, h_eq2⟩
  · omega
  · omega

lemma card_setE_le (P : PureOrderIdeal 3) (j : ℕ) (hj : j < socleDegree P / 2) :
  (setE P j).card ≤ (setE P (j + 1)).card := by
  rw [card_setE_eq_sum_slice_diff P j, card_setE_eq_sum_slice_diff P (j + 1)]
  have h_le_terms : ∀ k ∈ Finset.range (j + 1), slice_size P k (j - k) - slice_size P (k + 1) (j - k) ≤ slice_size P k (j + 1 - k) - slice_size P (k + 1) (j + 1 - k) := by
    intro k hk
    rw [Finset.mem_range] at hk
    have hd : j - k + k < socleDegree P / 2 := by omega
    have h_le := slice_diff_le_slice_diff_next P k (j - k) hd
    have h_sub : j + 1 - k = (j - k) + 1 := by omega
    rw [h_sub]
    exact h_le
  have h_sum_le := Finset.sum_le_sum h_le_terms
  have h_split : (Finset.range (j + 1 + 1)).sum (fun k => slice_size P k (j + 1 - k) - slice_size P (k + 1) (j + 1 - k)) =
    (Finset.range (j + 1)).sum (fun k => slice_size P k (j + 1 - k) - slice_size P (k + 1) (j + 1 - k)) +
    (slice_size P (j + 1) 0 - slice_size P (j + 1 + 1) 0) := by
    rw [Finset.sum_range_succ]
    have h_sub : j + 1 - (j + 1) = 0 := by omega
    rw [h_sub]
  have h_split2 : j + 2 = j + 1 + 1 := by omega
  rw [h_split2]
  rw [h_split]
  omega

lemma setD_card_eq_slice_size_zero (P : PureOrderIdeal 3) (j : ℕ) :
  (setD P j).card = slice_size P 0 j := by
  unfold setD slice_size
  have h_eq : P.ideal.carrier.filter (fun m => totalDeg m = j ∧ m 2 = 0) = P.ideal.carrier.filter (fun m => degZ m = 0 ∧ degXY m = j) := by
    ext m
    rw [Finset.mem_filter, Finset.mem_filter]
    have h_sum := deg_eq_degXY_plus_degZ m
    constructor
    · rintro ⟨hm, h_deg, hz⟩
      have hz_eq : degZ m = 0 := hz
      constructor
      · exact hm
      · constructor
        · exact hz_eq
        · omega
    · rintro ⟨hm, hz, h_deg⟩
      have hz_eq : m 2 = 0 := hz
      constructor
      · exact hm
      · constructor
        · omega
        · exact hz_eq
  rw [h_eq]

lemma sum_strict_mono (j : ℕ) (f g : ℕ → ℕ)
  (h_le : ∀ k ∈ Finset.range (j + 1), f k ≤ g k)
  (h_strict : ∃ k ∈ Finset.range (j + 1), f k + 1 ≤ g k) :
  (Finset.range (j + 1)).sum f + 1 ≤ (Finset.range (j + 1)).sum g := by
  apply Finset.sum_lt_sum h_le (by assumption)

lemma setE_empty_of_full_simplex (P : PureOrderIdeal 3) (j : ℕ) (h_full : ∀ k ≤ j + 1, slice_size P k (j + 1 - k) = j + 2 - k) :
  (setE P j).card = 0 := by
  have h_sum := card_setE_eq_sum_slice_diff P j
  rw [h_sum]
  have h_terms_zero : ∀ k ∈ Finset.range (j + 1), slice_size P k (j - k) - slice_size P (k + 1) (j - k) = 0 := by
    intro k hk
    rw [Finset.mem_range] at hk
    have hk_le : k ≤ j + 1 := by omega
    have hk1_le : k + 1 ≤ j + 1 := by omega
    have hc_k := h_full k hk_le
    have hc_k1 := h_full (k + 1) hk1_le
    have h_sub : j + 1 - (k + 1) = j - k := by omega
    rw [h_sub] at hc_k1
    have h_bound_k := pureOSeq_bound_slice P k (j - k)
    omega
  exact Finset.sum_eq_zero h_terms_zero

lemma card_setE_strict_mono_helper (P : PureOrderIdeal 3) (j : ℕ) (hj_pos : 0 < j)
  (h_le : ∀ k ∈ Finset.range j, slice_size P k (j - 1 - k) - slice_size P (k + 1) (j - 1 - k) ≤ slice_size P k (j - k) - slice_size P (k + 1) (j - k))
  (h_strict_or : (∃ k ∈ Finset.range j, slice_size P k (j - 1 - k) - slice_size P (k + 1) (j - 1 - k) + 1 ≤ slice_size P k (j - k) - slice_size P (k + 1) (j - k)) ∨
                 (1 ≤ slice_size P j 0 - slice_size P (j + 1) 0)) :
  (Finset.range j).sum (fun k => slice_size P k (j - 1 - k) - slice_size P (k + 1) (j - 1 - k)) + 1 ≤
  (Finset.range (j + 1)).sum (fun k => slice_size P k (j - k) - slice_size P (k + 1) (j - k)) := by
  have h_split : (Finset.range (j + 1)).sum (fun k => slice_size P k (j - k) - slice_size P (k + 1) (j - k)) =
    (Finset.range j).sum (fun k => slice_size P k (j - k) - slice_size P (k + 1) (j - k)) +
    (slice_size P j 0 - slice_size P (j + 1) 0) := by
    rw [Finset.sum_range_succ]
    have h_sub : j - j = 0 := by omega
    rw [h_sub]
  rw [h_split]
  rcases h_strict_or with h_strict | h0_strict
  · have h_sum := sum_strict_mono (j - 1)
      (fun k => slice_size P k (j - 1 - k) - slice_size P (k + 1) (j - 1 - k))
      (fun k => slice_size P k (j - k) - slice_size P (k + 1) (j - k))
    have h_range : j - 1 + 1 = j := by omega
    rw [h_range] at h_sum
    have h_sum_le := h_sum h_le h_strict
    have h_0_diff : 0 ≤ slice_size P j 0 - slice_size P (j + 1) 0 := by
      have h_bound := slice_size_Z_le P j 0
      omega
    omega
  · have h_sum_le := Finset.sum_le_sum h_le
    omega

lemma card_setE_strict_mono (P : PureOrderIdeal 3) (j : ℕ) (hj_pos : 0 < j) (hje : j ≤ socleDegree P / 2)
  (hD : (setD P (j + 1)).card = j + 2) :
  (setE P j).card = 0 ∨ (setE P (j - 1)).card + 1 ≤ (setE P j).card := by
  have h_base : slice_size P 0 (j + 1) = j + 2 := by
    rw [← setD_card_eq_slice_size_zero P (j + 1)]
    exact hD
  have h_cases : (∀ k ≤ j + 1, slice_size P k (j + 1 - k) = j + 2 - k) ∨
                 (∃ k ≤ j + 1, slice_size P k (j + 1 - k) < j + 2 - k) := by
    by_cases h : ∃ k ≤ j + 1, slice_size P k (j + 1 - k) < j + 2 - k
    · right; exact h
    · left; push_neg at h; intro k hk
      have h_bound := pureOSeq_bound_slice P k (j + 1 - k)
      have h_ge := h k hk
      omega
  rcases h_cases with h_full | h_not_full
  · left
    exact setE_empty_of_full_simplex P j h_full
  · right
    have h_min := min_not_full_slice P j h_base h_not_full
    rcases h_min with ⟨K, hK_le, hK_pos, hK_not_full, hK_min⟩
    have h_k_def : ∃ k, K = k + 1 := ⟨K - 1, by omega⟩
    rcases h_k_def with ⟨k, hk_eq⟩
    have h_k_full : slice_size P k (j + 1 - k) = j + 2 - k := by
      have hk_lt : k < K := by omega
      exact hK_min k hk_lt
    have h_le_all : ∀ k ∈ Finset.range j, slice_size P k (j - 1 - k) - slice_size P (k + 1) (j - 1 - k) ≤ slice_size P k (j - k) - slice_size P (k + 1) (j - k) := by
      intro k hk
      rw [Finset.mem_range] at hk
      have hd : j - 1 - k + k < socleDegree P / 2 := by omega
      have h_le := slice_diff_le_slice_diff_next P k (j - 1 - k) hd
      have h_sub : j - 1 - k + 1 = j - k := by omega
      rw [h_sub] at h_le
      exact h_le
    have h_K_cases : K ≤ j ∨ K = j + 1 := by omega
    have h_strict_or : (∃ k ∈ Finset.range j, slice_size P k (j - 1 - k) - slice_size P (k + 1) (j - 1 - k) + 1 ≤ slice_size P k (j - k) - slice_size P (k + 1) (j - k)) ∨ (1 ≤ slice_size P j 0 - slice_size P (j + 1) 0) := by
      rcases h_K_cases with hK_le_j | hK_eq_j1
      · left
        use k
        constructor
        · rw [Finset.mem_range]; omega
        · have hd_pos : 0 < j - k := by omega
          have h_full_k : slice_size P k (j - k) = j - k + 1 := by
            have hk_lt : k < K := by omega
            have h_full_k2 : slice_size P k (j + 1 - k) = j + 2 - k := hK_min k hk_lt
            have h_eq1 : j + 1 - k = j - k + 1 := by omega
            have h_eq2 : j + 2 - k = j - k + 1 + 1 := by omega
            rw [h_eq1, h_eq2] at h_full_k2
            have h_mac := card_slice_le P k (j - k)
            have h_bnd := pureOSeq_bound_slice P k (j - k)
            rcases h_mac with h_le | ⟨h_eq_B, h_eq_A⟩
            · linarith
            · exact h_eq_B
          have h_not_full_k1 : slice_size P (k + 1) (j - k) < j - k + 1 := by
            have h_eq : j + 1 - K = j - k := by omega
            have h_eq2 : j + 2 - K = j - k + 1 := by omega
            have h_K_not_full2 : slice_size P K (j + 1 - K) < j + 2 - K := hK_not_full
            rw [h_eq, h_eq2] at h_K_not_full2
            have h_match : slice_size P (k + 1) (j - k) = slice_size P K (j - k) := by
              congr 2; omega
            rw [h_match]
            exact h_K_not_full2
          have h_strict_k := slice_diff_strict_increase P k (j - k) hd_pos h_full_k h_not_full_k1
          have h_sub_d : j - k - 1 = j - 1 - k := by omega
          rw [h_sub_d] at h_strict_k
          exact h_strict_k
      · right
        have h_k_is_j : k = j := by omega
        have h_full_j : slice_size P j 1 = 2 := by
          have h_sub : j + 1 - j = 1 := by omega
          have h_sub2 : j + 2 - j = 2 := by omega
          have hf : slice_size P j (j + 1 - j) = j + 2 - j := hK_min j (by omega)
          rw [h_sub, h_sub2] at hf
          exact hf
        have h_full_j0 : slice_size P j 0 = 1 := by
          have h_mac := card_slice_le P j 0
          have h_bnd := pureOSeq_bound_slice P j 0
          rcases h_mac with h_le | ⟨h_eq0, h_eq1⟩
          · linarith
          · exact h_eq0
        have h_not_full_j1 : slice_size P (j + 1) 0 < 1 := by
          have h_sub : j + 1 - (j + 1) = 0 := by omega
          have h_sub2 : j + 2 - (j + 1) = 1 := by omega
          have hnf : slice_size P (j + 1) (j + 1 - (j + 1)) < j + 2 - (j + 1) := by
            have heq : K = j + 1 := by omega
            have hnf_K := hK_not_full
            rw [heq] at hnf_K
            exact hnf_K
          rw [h_sub, h_sub2] at hnf
          exact hnf
        omega
    have h_helper := card_setE_strict_mono_helper P j hj_pos h_le_all h_strict_or
    have h_sum_j := card_setE_eq_sum_slice_diff P j
    have h_sum_jm1 := card_setE_eq_sum_slice_diff P (j - 1)
    rw [h_sum_j, h_sum_jm1]
    have h_range : Finset.range (j - 1 + 1) = Finset.range j := by congr 1; omega
    rw [h_range]
    exact h_helper

lemma pure_O_seq_Macaulay_diff_Z (P : PureOrderIdeal 3) (j : ℕ) (hj : j ≤ socleDegree P / 2) :
  FirstDiffZ P (j + 1) ≤ FirstDiffZ P j ∨ (FirstDiffZ P j = (j : ℤ) + 1 ∧ FirstDiffZ P (j + 1) = (j : ℤ) + 2) := by
  have hj_pos : 0 < j + 1 := by omega
  have eq1 := pureOSeq_eq_D_E P (j + 1) hj_pos
  have hD := card_setD_le P j
  if h0 : j = 0 then
    rw [h0]
    have eq0 : FirstDiffZ P 0 = 1 := by rfl
    have h_bound : FirstDiffZ P 1 ≤ 2 := FirstDiffZ_le_max P 1
    have h_cases : FirstDiffZ P 1 ≤ 1 ∨ FirstDiffZ P 1 = 2 := by omega
    rcases h_cases with h1 | h2
    · left; rw [eq0]; exact h1
    · right; constructor
      · rw [eq0]; norm_num
      · rw [h2]; norm_num
  else
    have hj_pos2 : 0 < j := by omega
    have eq2 := pureOSeq_eq_D_E P j hj_pos2
    have hj_lt_socle : j - 1 < socleDegree P / 2 := by omega
    have hE := card_setE_le P (j - 1) hj_lt_socle
    have h_sub_eq2 : j - 1 + 1 = j := by omega
    rw [h_sub_eq2] at hE
    have hz_E : ((setE P (j - 1)).card : ℤ) ≤ ((setE P j).card : ℤ) := by exact_mod_cast hE
    rcases hD with hD_le | ⟨hDj, hDj1⟩
    · left
      have hz_D : ((setD P (j + 1)).card : ℤ) ≤ ((setD P j).card : ℤ) := by exact_mod_cast hD_le
      have h_sub_eq : j + 1 - 1 = j := by omega
      rw [h_sub_eq] at eq1
      linarith
    · have h_sub_eq : j + 1 - 1 = j := by omega
      rw [h_sub_eq] at eq1
      have hz_D1 : ((setD P (j + 1)).card : ℤ) = (j : ℤ) + 2 := by exact_mod_cast hDj1
      have hz_D : ((setD P j).card : ℤ) = (j : ℤ) + 1 := by exact_mod_cast hDj
      have h_strict := card_setE_strict_mono P j hj_pos2 hj hDj1
      rcases h_strict with hE_zero | hE_inc
      · right
        have hz_E0 : ((setE P j).card : ℤ) = 0 := by exact_mod_cast hE_zero
        have hz_E_prev_0 : ((setE P (j - 1)).card : ℤ) = 0 := by linarith
        constructor
        · linarith
        · linarith
      · left
        have hz_E_inc : ((setE P (j - 1)).card : ℤ) + 1 ≤ ((setE P j).card : ℤ) := by exact_mod_cast hE_inc
        linarith

lemma pure_O_seq_Macaulay_diff_max_Z (P : PureOrderIdeal 3) (j : ℕ) (hj : j ≤ socleDegree P / 2 + 1) :
  FirstDiffZ P j = (j : ℤ) + 1 → ∀ k ≤ j, FirstDiffZ P k = (k : ℤ) + 1 := by
  intro h_max k hk
  induction j with
  | zero =>
    have h_eq : k = 0 := by omega
    rw [h_eq]
    unfold FirstDiffZ
    rfl
  | succ j ih =>
    have h_le_socle : j ≤ socleDegree P / 2 := by omega
    have h_cases := pure_O_seq_Macaulay_diff_Z P j h_le_socle
    rcases h_cases with h_le | ⟨h_prev, h_eq⟩
    · have h_bound := FirstDiffZ_le_max P j
      have hz_j : ((j + 1 : ℕ) : ℤ) = (j : ℤ) + 1 := by omega
      rw [hz_j] at h_max
      linarith
    · have hk_cases : k ≤ j ∨ k = j + 1 := by omega
      rcases hk_cases with hk_le | hk_eq
      · exact ih (by omega) h_prev hk_le
      · rw [hk_eq]
        exact h_max

lemma FirstDiffZ_OSeq_property (P : PureOrderIdeal 3) (i : ℕ) (hi0 : 0 < i) (hie : i ≤ socleDegree P / 2) :
  FirstDiffZ P (i + 1) ≤ FirstDiffZ P i ∨
  (∀ j ≤ i + 1, FirstDiffZ P j = (j : ℤ) + 1) := by
  have h_diff := pure_O_seq_Macaulay_diff_Z P i hie
  rcases h_diff with h_le | ⟨h_prev, h_eq⟩
  · left
    exact h_le
  · right
    have h_le_socle_1 : i + 1 ≤ socleDegree P / 2 + 1 := by omega
    exact pure_O_seq_Macaulay_diff_max_Z P (i + 1) h_le_socle_1 h_eq

lemma P3_dichotomy (P : PureOrderIdeal 3) (i : ℕ) (hi0 : 0 < i) (hie : i ≤ socleDegree P / 2) :
  (pureOSequence P.ideal (i + 1) : ℤ) + (pureOSequence P.ideal (i - 1) : ℤ) ≤ 2 * (pureOSequence P.ideal i : ℤ) ∨
  (2 * (pureOSequence P.ideal (i - 1) : ℤ) = (i : ℤ) * ((i : ℤ) + 1) ∧
   2 * (pureOSequence P.ideal i : ℤ) = ((i : ℤ) + 1) * ((i : ℤ) + 2) ∧
   2 * (pureOSequence P.ideal (i + 1) : ℤ) = ((i : ℤ) + 2) * ((i : ℤ) + 3)) := by
  have h_diff := FirstDiffZ_OSeq_property P i hi0 hie
  rcases h_diff with h_le | h_eq
  · left
    have hd1 : FirstDiffZ P (i + 1) = (pureOSequence P.ideal (i + 1) : ℤ) - (pureOSequence P.ideal i : ℤ) := by
      unfold FirstDiffZ
      simp
    have hd2 : FirstDiffZ P i = (pureOSequence P.ideal i : ℤ) - (pureOSequence P.ideal (i - 1) : ℤ) := by
      unfold FirstDiffZ
      have hnz : i ≠ 0 := by omega
      simp [hnz]
    linarith
  · right
    exact binomial_of_FirstDiffZ P i hi0 h_eq
