lemma pureOSequence_eq_card_degree {r : ℕ} (I : OrderIdeal r) (d : ℕ) :
  pureOSequence I d = (I.carrier.filter (fun m => totalDeg m = d)).card := by
  rfl

lemma macaulay_2_vars (X : ℕ → Finset ℕ)
  (h_down : ∀ i x, x ∈ X (i + 1) → (x < i + 1 → x ∈ X i) ∧ (x > 0 → x - 1 ∈ X i))
  (h_bound : ∀ i x, x ∈ X i → x ≤ i)
  (i : ℕ) : (X (i + 1)).card ≤ (X i).card ∨ (X i).card = i + 1 := by
  have h_bound_card : (X i).card ≤ i + 1 := by
    have h_sub : X i ⊆ Finset.range (i + 1) := by
      intro x hx
      rw [Finset.mem_range]
      have hxb := h_bound i x hx
      omega
    have h_le := Finset.card_le_card h_sub
    rw [Finset.card_range] at h_le
    exact h_le
  have h_dec : (X i).card = i + 1 ∨ (X i).card < i + 1 := by omega
  rcases h_dec with h_eq | h_lt
  · right
    exact h_eq
  · left
    have h_missing : ∃ k ≤ i, k ∉ X i := by
      by_contra! h_all
      have h_sub : Finset.range (i + 1) ⊆ X i := by
        intro x hx
        rw [Finset.mem_range] at hx
        exact h_all x (by omega)
      have h_le := Finset.card_le_card h_sub
      rw [Finset.card_range] at h_le
      omega
    rcases h_missing with ⟨k, hk_le, hk_notin⟩
    let f : ℕ → ℕ := fun x => if x ≤ k then x else x - 1
    have h_inj : Set.InjOn f (X (i + 1)) := by
      intro x hx y hy heq
      dsimp [f] at heq
      split at heq <;> split at heq
      · exact heq
      · have h_y_eq : y = k + 1 := by omega
        have h_y_in : k + 1 ∈ X (i + 1) := by
          rw [← h_y_eq]
          exact hy
        have h_k_in : k ∈ X i := by
          have h_down_y := (h_down i (k + 1) h_y_in).2 (by omega)
          have h_simp : k + 1 - 1 = k := by omega
          rw [h_simp] at h_down_y
          exact h_down_y
        contradiction
      · have h_x_eq : x = k + 1 := by omega
        have h_x_in : k + 1 ∈ X (i + 1) := by
          rw [← h_x_eq]
          exact hx
        have h_k_in : k ∈ X i := by
          have h_down_x := (h_down i (k + 1) h_x_in).2 (by omega)
          have h_simp : k + 1 - 1 = k := by omega
          rw [h_simp] at h_down_x
          exact h_down_x
        contradiction
      · omega
    have h_mem : ∀ x ∈ X (i + 1), f x ∈ X i := by
      intro x hx
      dsimp [f]
      split
      · have h_lt : x < i + 1 := by omega
        exact (h_down i x hx).1 h_lt
      · have hpos : x > 0 := by omega
        exact (h_down i x hx).2 hpos
    exact Finset.card_le_card_of_injOn f h_mem h_inj

def degXY (m : Monomial 3) : ℕ := m 0 + m 1
def degZ (m : Monomial 3) : ℕ := m 2

lemma deg_eq_degXY_plus_degZ (m : Monomial 3) : totalDeg m = degXY m + degZ m := by
  have h_sum : m.sum (fun _ e => e) = m 0 + m 1 + m 2 := by
    exact (m|>.sum_fintype _ (by simp_all)).trans ( Fin.sum_univ_three _)
  delta totalDeg degXY degZ
  omega

def slice_size (P : PureOrderIdeal 3) (k : ℕ) (d : ℕ) : ℕ :=
  (P.ideal.carrier.filter fun m => degZ m = k ∧ degXY m = d).card

lemma slice_downward_x (P : PureOrderIdeal 3) (k d : ℕ) (x : ℕ) (hx : x ≤ d) :
  (∃ m ∈ P.ideal.carrier, degZ m = k ∧ m 0 = x ∧ degXY m = d + 1) →
  (∃ m ∈ P.ideal.carrier, degZ m = k ∧ m 0 = x ∧ degXY m = d) := by
  show (∃ a ∈{s |_},_) → ∃ a ∈{s |_},_
  norm_num(config := {singlePass:=1})[degXY,degZ,Monomial]
  cases P
  delta IsPure Monomial maximalMonomials at*
  cases‹OrderIdeal 3›
  delta totalDeg IsMaximalIn Monomial at*
  revert‹ Finset _›k(d)x
  simp_rw [and_imp]
  use fun and A B a s R L K V M _ _ _=>⟨.single 0 B+.single (1) (A-B)+.single (2) and,?_⟩
  exact ⟨ R M (by match. with|0|1|2=>norm_num+decide[ (by linarith![B.add_sub_of_le a]:A-B≤V 1),show V 0 = _∧V (2) = _∧V (1) = _ by tauto]),by norm_num+decide[a]⟩

lemma slice_downward_y (P : PureOrderIdeal 3) (k d : ℕ) (x : ℕ) (hx : 1 ≤ x ∧ x ≤ d + 1) :
  (∃ m ∈ P.ideal.carrier, degZ m = k ∧ m 0 = x ∧ degXY m = d + 1) →
  (∃ m ∈ P.ideal.carrier, degZ m = k ∧ m 0 = x - 1 ∧ degXY m = d) := by
  show (∃ a ∈ {s |_},_) →∃ a ∈{s |_},_
  rintro ⟨a, true,rfl,rfl, _⟩
