  cases P
  norm_num[maximalMonomials, and_assoc,IsPure]at*
  simp_all[maximalMonomials,IsPure, true,Set.nonempty_def]
  norm_num[totalDeg, Finset.Nonempty]at*
  cases‹OrderIdeal (3)›
  cases(1).exists_eq_add_of_le' hx.1
  simp_all-contextual [Monomial,Nat.succ_add]
  exists Finsupp.single 0 (by valid)+.single (1) (a (1))+.single (2) (a 2),‹∀ (x a _),x ≤ a →x ∈_› _ _ (by valid) (by match. with|0|1|2=>simp_all)
  norm_num+decide[←‹_ = d›]

