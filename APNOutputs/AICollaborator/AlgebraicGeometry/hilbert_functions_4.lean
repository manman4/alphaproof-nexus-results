noncomputable def monomialInf {r : ℕ} (m1 m2 : Monomial r) : Monomial r where
  support := m1.support ∩ m2.support
  toFun i := min (m1 i) (m2 i)
  mem_support_toFun i := by
    simp only [Finset.mem_inter, Finsupp.mem_support_iff, ne_eq]
    omega

lemma type_two_maximals {r : ℕ} (P : PureOrderIdeal r) (h : typePO P = 2) :
  ∃ m1 m2 : Monomial r, m1 ≠ m2 ∧ maximalMonomials P.ideal = {m1, m2} := by
  delta maximalMonomials typePO Ne Monomial at*
  exact Finset.card_eq_two.mp h

lemma carrier_of_maximals {r : ℕ} (P : PureOrderIdeal r) (m1 m2 : Monomial r)
  (h : maximalMonomials P.ideal = {m1, m2}) :
  P.ideal.carrier = divisorsFinset m1 ∪ divisorsFinset m2 := by
  show(id _) = _
  simp_all[divisorsFinset,maximalMonomials, Finset.ext_iff]
  cases P
  delta IsPure IsMaximalIn maximalMonomials at*
  induction‹ OrderIdeal r›
  use fun and=>⟨ fun and=>? _, (by cases. with cases(h _).2 (.inl rfl ) with cases(h _).2 (.inr rfl ) with tauto)⟩
  choose _ _ _ using Finset.exists_max_image ↑_ ↑(Set.ncard { a ∈‹ Finset @_›| a≤ ·}) ⟨ _,and⟩
  revert‹Monomial r›m1‹ @Monomial r›m2‹ Finset _›
  use fun and A B a s R M K V W E=>by_contra fun and=>?_
  let := {N ∈B|by bound≤N}
  use(this.exists_max_image (Set.ncard { a ∈B|a≤.}) ⟨ _,B.mem_filter.2 (by use K)⟩).elim fun a s=>and ?_
  cases Finset.mem_filter.1 s.1 with|intro R L=>bound[(M _).1 ⟨ R, R, fun and K V=>((Set.eq_of_subset_of_ncard_le (by gcongr) (s.2 and (by grind)) (B.finite_toSet.sep _)).ge (by use K)).2⟩]

lemma OSeq_union {r : ℕ} (I : OrderIdeal r) (m1 m2 : Monomial r)
  (h : I.carrier = divisorsFinset m1 ∪ divisorsFinset m2) (d : ℕ) :
  pureOSequence I d =
    ((divisorsFinset m1).filter (fun m => totalDeg m = d)).card +
    ((divisorsFinset m2).filter (fun m => totalDeg m = d)).card -
    (((divisorsFinset m1) ∩ (divisorsFinset m2)).filter (fun m => totalDeg m = d)).card := by
  rw[pureOSequence, Finset.card_filter, Finset.card_filter, Finset.card_filter]
  rw [← Finset.sum_union_inter, Finset.card_filter,h,Nat.add_sub_cancel]

lemma divisors_inter {r : ℕ} (m1 m2 : Monomial r) :
  divisorsFinset m1 ∩ divisorsFinset m2 = divisorsFinset (monomialInf m1 m2) := by
  delta divisorsFinset monomialInf Monomial at *
  exact Finset.ext fun and=>.trans (by rw [ Finset.mem_inter, Finset.mem_Iic, Finset.mem_Iic]) (Finset.mem_Iic.trans (by use forall_and.1 ∘fun R M=>le_min_iff.1 (R _),fun R M=>le_min (R.1 M) (R.2 M))).symm

lemma size_S1_le_1_or_size_S2_le_1 (m1 m2 : Monomial 3) :
  (Finset.univ.filter (fun i => m2 i < m1 i)).card ≤ 1 ∨
  (Finset.univ.filter (fun i => m1 i < m2 i)).card ≤ 1 := by
  exact (le_or_gt _ _).imp_right fun and=> not_lt.mp (by decide ∘(Nat.add_le_add and ·|>.trans (.trans ( Finset.card_union_of_disjoint.comp Finset.disjoint_filter.mpr (by valid)).ge (Finset.card_le_univ _))))

noncomputable def OSeq (m : Monomial 3) (d : ℕ) : ℕ :=
  ((divisorsFinset m).filter (fun x => totalDeg x = d)).card

noncomputable def OSeqZ (m : Monomial 3) (d : ℤ) : ℤ :=
  if d < 0 then 0 else OSeq m d.toNat

def c_seq (A B : ℕ) (d : ℤ) : ℤ :=
  if d < 0 then 0 else if d > A + B then 0 else
  (min d.toNat A : ℤ) + 1 - if d > B then (d - B) else 0

lemma c_seq_symm (A B : ℕ) (d : ℤ) :
  c_seq A B d = c_seq A B (A + B - d) := by
  delta c_seq
  grind [min_comm]

lemma sum_telescope_c_seq (A B C : ℕ) (d : ℤ) :
  (∑ k ∈ Finset.Iic C, c_seq A B (d - k)) - (∑ k ∈ Finset.Iic C, c_seq A B (d - 1 - k)) =
  c_seq A B d - c_seq A B (d - C - 1) := by
  exact (.trans (by rw [← Finset.sum_sub_distrib, show Finset.Iic C=.range (C + 1)by simp_all[ Finset.ext_iff,Nat.lt_succ]]) (by exact C.rec ((by simp_all ) ) fun and true=>.trans (by rw [ Finset.sum_range_succ, true,]) (by·grind)))

lemma totalDeg_three (x : Monomial 3) : totalDeg x = x 0 + x 1 + x 2 := by
  rewrite [totalDeg, add_assoc]
  exact (x|>.sum_fintype _ (by simp_all)).trans ( Fin.sum_univ_three x▸add_assoc _ _ _)

lemma card_solutions_2d (A B S : ℕ) :
  (((Finset.Iic A) ×ˢ (Finset.Iic B)).filter (fun p => p.1 + p.2 = S)).card =
  if S > A + B then 0 else min S A + 1 - if S > B then (S - B) else 0 := by
  refine show Finset.Iic A=.range (A+1)by simp_all[ Finset.ext_iff,Nat.lt_succ]▸show Finset.Iic B=.range (B+1)by simp_all [ Finset.ext_iff,Nat.lt_succ]▸.trans (by rw [ Finset.card_filter, Finset.sum_product]) ?_
  trans∑ a ∈.range (A+1),ite ( a≤S ∧S-a≤B) (1) 0
  · exact (congr_arg _) ((funext fun and=>by if a: S≥ and then norm_num[a,add_comm and,←eq_tsub_iff_add_eq_of_le _,Nat.lt_succ]else norm_num[a,mt le_self_add.trans_eq]))
  · exact ( Finset.card_filter _ _).symm.trans ( ((congr_arg _) (Finset.ext (by simp_all[add_comm,←and_assoc, and_comm]))).trans (((S-B).card_Icc (S⊓A)).trans ((em _).elim (if_pos ·▸by valid) (if_neg ·▸by grind))))

lemma card_filter_eq_card_solutions (m : Monomial 3) (d k : ℕ) (hk : k ≤ m 2) :
  ((divisorsFinset m).filter (fun x => totalDeg x = d ∧ x 2 = k)).card =
  if d < k then 0 else (((Finset.Iic (m 0)) ×ˢ (Finset.Iic (m 1))).filter (fun p => p.1 + p.2 = d - k)).card := by
  delta totalDeg divisorsFinset Monomial at*
  (( aesop))
  · norm_num[ Finsupp.sum_of_support_subset (s:=⊤)] at h
    simp_all[ Fin.sum_univ_three]
  refine Finset.card_bij ?_ (@?_) ?_ @(? _)
  refine fun and x =>(and 0, and 01)
  · simp_all[eq_comm, Fin.sum_univ_three, Finsupp.sum_of_support_subset (s:=⊤), Finsupp.le_def]
  · simp_all[Fin.sum_univ_three,Finsupp.sum_of_support_subset (s:=⊤),Finsupp.ext_iff,eq_comm,Fin.forall_iff_succ]
  refine fun and x =>⟨.single 0 and.fst+.single (1) (and.snd) +.single (2) k,? _,by simp_all⟩
  simp_all[ Finsupp.sum_add_index', Finsupp.le_def, Fin.forall_iff_succ]

lemma c_seq_eq_card_solutions (A B S : ℕ) :
  c_seq A B S = (((Finset.Iic A) ×ˢ (Finset.Iic B)).filter (fun p => p.1 + p.2 = S)).card := by
  rw [card_solutions_2d]
  unfold c_seq
  have h_S : (S : ℤ).toNat = S := by omega
  rw [h_S]
  split_ifs <;> omega

lemma disjoint_filter_filter_helper {α : Type*} (s : Finset α) {P Q : α → Prop} [DecidablePred P] [DecidablePred Q]
  (h : ∀ x, ¬(P x ∧ Q x)) : Disjoint (s.filter P) (s.filter Q) := by
  rw [Finset.disjoint_filter]
  intro x _ hP hQ
  exact h x ⟨hP, hQ⟩

lemma OSeq_eq_sum_c_seq_nat (m : Monomial 3) (d : ℕ) :
  (OSeq m d : ℤ) = ∑ k ∈ Finset.Iic (m 2), c_seq (m 0) (m 1) ((d : ℤ) - k) := by
  unfold OSeq
  have h_bij : (divisorsFinset m).filter (fun x => totalDeg x = d) =
               Finset.biUnion (Finset.Iic (m 2)) (fun k => (divisorsFinset m).filter (fun x => totalDeg x = d ∧ x 2 = k)) := by
    ext x
    simp only [Finset.mem_filter, Finset.mem_biUnion, Finset.mem_Iic]
    constructor
    · rintro ⟨hx_mem, hx_deg⟩
      use x 2
      have hx_le : x 2 ≤ m 2 := by
        rw [mem_divisorsFinset_iff] at hx_mem
        exact hx_mem 2
      exact ⟨hx_le, ⟨hx_mem, ⟨hx_deg, rfl⟩⟩⟩
    · rintro ⟨k, _, hx_mem, hx_deg, _⟩
      exact ⟨hx_mem, hx_deg⟩
  rw [h_bij]
  have h_card : (Finset.biUnion (Finset.Iic (m 2)) (fun k => (divisorsFinset m).filter (fun x => totalDeg x = d ∧ x 2 = k))).card =
                ∑ k ∈ Finset.Iic (m 2), ((divisorsFinset m).filter (fun x => totalDeg x = d ∧ x 2 = k)).card := by
    apply Finset.card_biUnion
    intro k1 _ k2 _ h_neq
    apply disjoint_filter_filter_helper
    intro x hx
    exact h_neq (hx.1.2.symm.trans hx.2.2)
  rw [h_card]
  push_cast
  apply Finset.sum_congr rfl
  intro k hk
  rw [Finset.mem_Iic] at hk
  rw [card_filter_eq_card_solutions m d k hk]
  by_cases hdk : d < k
  · rw [if_pos hdk]
    have h_neg : (d : ℤ) - k < 0 := by omega
    unfold c_seq
    rw [if_pos h_neg]
    rfl
  · rw [if_neg hdk]
    have h_pos : 0 ≤ (d : ℤ) - k := by omega
    have h_eq : (d : ℤ) - k = ((d - k : ℕ) : ℤ) := by omega
    rw [h_eq]
    rw [c_seq_eq_card_solutions]

lemma OSeqZ_eq_sum_c_seq (m : Monomial 3) (d : ℤ) :
  OSeqZ m d = ∑ k ∈ Finset.Iic (m 2), c_seq (m 0) (m 1) (d - k) := by
  unfold OSeqZ
  by_cases hd : d < 0
  · rw [if_pos hd]
    have h_sum : ∑ k ∈ Finset.Iic (m 2), c_seq (m 0) (m 1) (d - k) = 0 := by
      apply Finset.sum_eq_zero
      intro k _
      unfold c_seq
      have h_neg : d - k < 0 := by omega
      rw [if_pos h_neg]
    rw [h_sum]
  · rw [if_neg hd]
    have hd_eq : (d.toNat : ℤ) = d := Int.toNat_of_nonneg (by omega)
    have h1 := OSeq_eq_sum_c_seq_nat m d.toNat
    rw [hd_eq] at h1
    exact h1



noncomputable def swap02 (m : Monomial 3) : Monomial 3 :=
  Finsupp.single 0 (m 2) + Finsupp.single 1 (m 1) + Finsupp.single 2 (m 0)

lemma swap02_0 (m : Monomial 3) : (swap02 m) 0 = m 2 := by simp_all[swap02]
lemma swap02_1 (m : Monomial 3) : (swap02 m) 1 = m 1 := by simp_all [swap02]
lemma swap02_2 (m : Monomial 3) : (swap02 m) 2 = m 0 := by simp_all [swap02]

lemma totalDeg_swap02 (m : Monomial 3) : totalDeg (swap02 m) = totalDeg m := by delta swap02 totalDeg
                                                                                simp_all -contextual [add_comm, add_assoc, Fin.sum_univ_three _, Finsupp.sum_of_support_subset (s:=⊤), Finsupp.sum_add_index']
                                                                                abel
lemma swap02_swap02 (m : Monomial 3) : swap02 (swap02 m) = m := by norm_num [swap02]
                                                                   apply Finsupp.ext (by match. with|0|1|2=>simp_all)
lemma swap02_divisors (m x : Monomial 3) :
  x ∈ divisorsFinset m ↔ swap02 x ∈ divisorsFinset (swap02 m) := by delta swap02 divisorsFinset Monomial at *
                                                                    simp_all[ Finsupp.le_def, Fin.forall_iff_succ]
                                                                    tauto

lemma OSeq_swap02 (m : Monomial 3) (d : ℕ) :
  OSeq m d = OSeq (swap02 m) d := by
  unfold OSeq
  apply Finset.card_bij (fun x _ => swap02 x)
  · intro x hx
    rw [Finset.mem_filter] at hx ⊢
    exact ⟨(swap02_divisors m x).mp hx.1, by rw [totalDeg_swap02, hx.2]⟩
  · intro a ha b hb h_eq
    have h : swap02 (swap02 a) = swap02 (swap02 b) := by rw [h_eq]
    rw [swap02_swap02 a, swap02_swap02 b] at h
    exact h
  · intro b hb
    use swap02 b
    have h1 : swap02 b ∈ (divisorsFinset m).filter (fun x => totalDeg x = d) := by
      rw [Finset.mem_filter] at hb ⊢
      constructor
      · have h_iff := swap02_divisors m (swap02 b)
        have hb1 : swap02 (swap02 b) ∈ divisorsFinset (swap02 m) := by
          rw [swap02_swap02]
          exact hb.1
        exact h_iff.mpr hb1
      · rw [totalDeg_swap02]
        exact hb.2
    exact ⟨h1, swap02_swap02 b⟩

lemma OSeqZ_swap02 (m : Monomial 3) (d : ℤ) :
  OSeqZ m d = OSeqZ (swap02 m) d := by
  unfold OSeqZ
  by_cases hd : d < 0
  · rw [if_pos hd, if_pos hd]
  · rw [if_neg hd, if_neg hd]
    have h := OSeq_swap02 m d.toNat
    rw [h]

lemma diff_OSeqZ_eq (m : Monomial 3) (d : ℤ) :
  OSeqZ m d - OSeqZ m (d - 1) =
  c_seq (m 0) (m 1) d - c_seq (m 0) (m 1) (d - m 2 - 1) := by
  have h1 := OSeqZ_eq_sum_c_seq m d
  have h2 := OSeqZ_eq_sum_c_seq m (d - 1)
  rw [h1, h2]
  exact sum_telescope_c_seq (m 0) (m 1) (m 2) d

noncomputable def dc_seq (A B : ℕ) (x : ℤ) : ℤ :=
  if x < 0 then 0
  else if x ≤ min A B then 1
  else if x ≤ max A B then 0
  else if x ≤ A + B + 1 then -1
  else 0

lemma c_seq_diff_eq (A B : ℕ) (x : ℤ) :
  c_seq A B x - c_seq A B (x - 1) = dc_seq A B x := by
  delta dc_seq c_seq
  grind

lemma dc_seq_mono (A B : ℕ) (x y : ℤ) (h1 : 1 ≤ y) (h2 : y ≤ x) (h3 : x ≤ A + B + 1) :
  dc_seq A B x ≤ dc_seq A B y := by
  unfold dc_seq
  split_ifs <;> omega

lemma diff2_OSeqZ_le_zero_C (m : Monomial 3) (d : ℤ)
  (h_bound0 : 1 ≤ d - m 2 - 1)
  (h_bound1 : d ≤ m 0 + m 1 + 1) :
  OSeqZ m d - OSeqZ m (d - 1) ≤ OSeqZ m (d - 1) - OSeqZ m (d - 2) := by
  have h1 := diff_OSeqZ_eq m d
  have h2 := diff_OSeqZ_eq m (d - 1)
  have hd_2 : d - 1 - 1 = d - 2 := by omega
  rw [hd_2] at h2
  rw [h1, h2]
  have eq1 : c_seq (m 0) (m 1) d - c_seq (m 0) (m 1) (d - 1) = dc_seq (m 0) (m 1) d := c_seq_diff_eq (m 0) (m 1) d
  have eq2 : c_seq (m 0) (m 1) (d - m 2 - 1) - c_seq (m 0) (m 1) (d - 1 - m 2 - 1) = dc_seq (m 0) (m 1) (d - m 2 - 1) := by
    have h_sub : d - 1 - m 2 - 1 = d - m 2 - 1 - 1 := by omega
    rw [h_sub]
    exact c_seq_diff_eq (m 0) (m 1) (d - m 2 - 1)
  linarith [eq1, eq2, dc_seq_mono (m 0) (m 1) d (d - m 2 - 1) h_bound0 (by omega) h_bound1]

lemma diff2_OSeqZ_le_zero_symm (m : Monomial 3) (d : ℤ)
  (hd_bound0 : 1 ≤ d - m 0 - 1)
  (hd_bound : d ≤ m 1 + m 2 + 1) :
  OSeqZ m d - OSeqZ m (d - 1) ≤ OSeqZ m (d - 1) - OSeqZ m (d - 2) := by
  have h := diff2_OSeqZ_le_zero_C (swap02 m) d
  rw [← OSeqZ_swap02 m d, ← OSeqZ_swap02 m (d - 1), ← OSeqZ_swap02 m (d - 2)] at h
  apply h
  · rw [swap02_2]
    exact hd_bound0
  · rw [swap02_0, swap02_1]
    have h_add : (m 2 : ℤ) + m 1 = (m 1 : ℤ) + m 2 := by omega
    rw [h_add]
    exact hd_bound

noncomputable def swap12 (m : Monomial 3) : Monomial 3 :=
  Finsupp.single 0 (m 0) + Finsupp.single 1 (m 2) + Finsupp.single 2 (m 1)

lemma swap12_0 (m : Monomial 3) : (swap12 m) 0 = m 0 := by simp_all[swap12]
lemma swap12_1 (m : Monomial 3) : (swap12 m) 1 = m 2 := by simp_all [swap12,]
lemma swap12_2 (m : Monomial 3) : (swap12 m) 2 = m 1 := by simp_all [swap12]

lemma totalDeg_swap12 (m : Monomial 3) : totalDeg (swap12 m) = totalDeg m := by delta totalDeg swap12 Monomial at*
                                                                                simp_all -contextual [ Fin.sum_univ_three _, Finsupp.sum_add_index',m.sum_fintype, add_assoc,add_comm (m (2))]
lemma swap12_swap12 (m : Monomial 3) : swap12 (swap12 m) = m := by delta swap12 Monomial at *
                                                                   simp_all+decide -contextual[ Finsupp.ext_iff, Fin.forall_iff_succ]
lemma swap12_divisors (m x : Monomial 3) :
  x ∈ divisorsFinset m ↔ swap12 x ∈ divisorsFinset (swap12 m) := by delta swap12 divisorsFinset Monomial at*
                                                                    norm_num+decide[ Finsupp.le_def, true, Fin.forall_fin_succ]
                                                                    tauto

lemma OSeq_swap12 (m : Monomial 3) (d : ℕ) :
  OSeq m d = OSeq (swap12 m) d := by
  unfold OSeq
  apply Finset.card_bij (fun x _ => swap12 x)
  · intro x hx
    rw [Finset.mem_filter] at hx ⊢
    exact ⟨(swap12_divisors m x).mp hx.1, by rw [totalDeg_swap12, hx.2]⟩
  · intro a ha b hb h_eq
    have h : swap12 (swap12 a) = swap12 (swap12 b) := by rw [h_eq]
    rw [swap12_swap12 a, swap12_swap12 b] at h
    exact h
  · intro b hb
    use swap12 b
    have h1 : swap12 b ∈ (divisorsFinset m).filter (fun x => totalDeg x = d) := by
      rw [Finset.mem_filter] at hb ⊢
      constructor
      · have h_iff := swap12_divisors m (swap12 b)
        have hb1 : swap12 (swap12 b) ∈ divisorsFinset (swap12 m) := by
          rw [swap12_swap12]
          exact hb.1
        exact h_iff.mpr hb1
      · rw [totalDeg_swap12]
        exact hb.2
    exact ⟨h1, swap12_swap12 b⟩

lemma OSeqZ_swap12 (m : Monomial 3) (d : ℤ) :
  OSeqZ m d = OSeqZ (swap12 m) d := by
  unfold OSeqZ
  by_cases hd : d < 0
  · rw [if_pos hd, if_pos hd]
  · rw [if_neg hd, if_neg hd]
    have h := OSeq_swap12 m d.toNat
    rw [h]

lemma diff2_OSeqZ_le_zero_symm2 (m : Monomial 3) (d : ℤ)
  (hd_bound0 : 1 ≤ d - m 1 - 1)
  (hd_bound : d ≤ m 0 + m 2 + 1) :
  OSeqZ m d - OSeqZ m (d - 1) ≤ OSeqZ m (d - 1) - OSeqZ m (d - 2) := by
  have h := diff2_OSeqZ_le_zero_C (swap12 m) d
  rw [← OSeqZ_swap12 m d, ← OSeqZ_swap12 m (d - 1), ← OSeqZ_swap12 m (d - 2)] at h
  apply h
  · rw [swap12_2]
    exact hd_bound0
  · rw [swap12_0, swap12_1]
    exact hd_bound

lemma diff2_OSeqZ_le_zero_min (m : Monomial 3) (d : ℤ)
  (hd_bound0 : 1 ≤ d - min (m 0) (min (m 1) (m 2)) - 1)
  (hd_bound : d ≤ (totalDeg m : ℤ) - min (m 0) (min (m 1) (m 2)) + 1) :
  OSeqZ m d - OSeqZ m (d - 1) ≤ OSeqZ m (d - 1) - OSeqZ m (d - 2) := by
  have h_cases : m 2 ≤ m 0 ∧ m 2 ≤ m 1 ∨ m 0 ≤ m 1 ∧ m 0 ≤ m 2 ∨ m 1 ≤ m 0 ∧ m 1 ≤ m 2 := by omega
  have h_deg_nat := totalDeg_three m
  have h_deg : (totalDeg m : ℤ) = (m 0 : ℤ) + (m 1 : ℤ) + (m 2 : ℤ) := by omega
  rcases h_cases with h | h | h
  · have h_min : (min (m 0) (min (m 1) (m 2)) : ℤ) = m 2 := by omega
    have hb0 : 1 ≤ d - (m 2 : ℤ) - 1 := by omega
    have hb1 : d ≤ (m 0 : ℤ) + (m 1 : ℤ) + 1 := by omega
    exact diff2_OSeqZ_le_zero_C m d hb0 hb1
  · have h_min : (min (m 0) (min (m 1) (m 2)) : ℤ) = m 0 := by omega
    have hb0 : 1 ≤ d - (m 0 : ℤ) - 1 := by omega
    have hb1 : d ≤ (m 1 : ℤ) + (m 2 : ℤ) + 1 := by omega
    exact diff2_OSeqZ_le_zero_symm m d hb0 hb1
  · have h_min : (min (m 0) (min (m 1) (m 2)) : ℤ) = m 1 := by omega
    have hb0 : 1 ≤ d - (m 1 : ℤ) - 1 := by omega
    have hb1 : d ≤ (m 0 : ℤ) + (m 2 : ℤ) + 1 := by omega
    exact diff2_OSeqZ_le_zero_symm2 m d hb0 hb1

lemma c_seq_diff_pos (A B C : ℕ) (d : ℤ) (h_center : 2 * d ≤ A + B + C) :
  c_seq A B (d - C - 1) ≤ c_seq A B d := by
  norm_num[c_seq, sub_sub, two_mul,id]at*
  omega

lemma OSeqZ_diff_pos (m : Monomial 3) (d : ℤ) (h_center : 2 * d ≤ totalDeg m) :
  0 ≤ OSeqZ m d - OSeqZ m (d - 1) := by
  rw [diff_OSeqZ_eq]
  have h_c : 2 * d ≤ m 0 + m 1 + m 2 := by simp_all[totalDeg]
                                           simp_all[m.sum_of_support_subset (s:=⊤), Fin.sum_univ_three]
  exact sub_nonneg.mpr (c_seq_diff_pos (m 0) (m 1) (m 2) d h_c)

lemma diff_OSeqZ_anti_symm (m : Monomial 3) (d : ℤ) :
  OSeqZ m d - OSeqZ m (d - 1) = -(OSeqZ m (totalDeg m - d + 1) - OSeqZ m (totalDeg m - d)) := by
  have h_left := diff_OSeqZ_eq m d
  have h_right := diff_OSeqZ_eq m ((totalDeg m : ℤ) - d + 1)
  have h_deg : (totalDeg m : ℤ) = m 0 + m 1 + m 2 := by norm_num [totalDeg, true, Fin.sum_univ_three]
                                                        exact (m|>.sum_fintype _ (by norm_num)).trans ( Fin.sum_univ_three _)
  have h_right_eq : ((totalDeg m : ℤ) - d + 1) - 1 = (totalDeg m : ℤ) - d := by omega
  rw [h_right_eq] at h_right
  rw [h_left, h_right, h_deg]
  have h1 : c_seq (m 0) (m 1) ((m 0 : ℤ) + m 1 + m 2 - d + 1) = c_seq (m 0) (m 1) (d - m 2 - 1) := by
    have h_s := c_seq_symm (m 0) (m 1) ((m 0 : ℤ) + m 1 + m 2 - d + 1)
    have h_eq : ((m 0 : ℤ) + m 1 - ((m 0 : ℤ) + m 1 + m 2 - d + 1)) = d - m 2 - 1 := by omega
    rw [h_eq] at h_s
    exact h_s
  have h2 : c_seq (m 0) (m 1) ((m 0 : ℤ) + m 1 + m 2 - d + 1 - m 2 - 1) = c_seq (m 0) (m 1) d := by
    have h_eq : ((m 0 : ℤ) + m 1 + m 2 - d + 1 - m 2 - 1) = (m 0 : ℤ) + m 1 - d := by omega
    rw [h_eq]
    have h_s := c_seq_symm (m 0) (m 1) d
    exact h_s.symm
  rw [h1, h2]
  omega

noncomputable def OSeq_diff (m1 m2 : Monomial 3) (d : ℕ) : ℕ :=
  (((divisorsFinset m1) \ (divisorsFinset m2)).filter (fun x => totalDeg x = d)).card

lemma oseq_union_eq_add_diff (m1 m2 : Monomial 3) (d : ℕ) :
  ((divisorsFinset m1).filter (fun m => totalDeg m = d)).card +
  ((divisorsFinset m2).filter (fun m => totalDeg m = d)).card -
  ((divisorsFinset (monomialInf m1 m2)).filter (fun m => totalDeg m = d)).card =
  OSeq m2 d + OSeq_diff m1 (monomialInf m1 m2) d := by
  delta monomialInf OSeq_diff totalDeg OSeq divisorsFinset
  refine tsub_eq_of_eq_add ((add_comm _ _).trans (symm ((add_assoc _ _ _).trans ((congr_arg _) (( Finset.card_union_of_disjoint (Finset.disjoint_left.2 (by simp_all))).symm.trans (congr_arg _ (Finset.ext fun and=>? _)))))))
  rw [← Finset.filter_union, Finset.sdiff_union_of_subset (Finset.Iic_subset_Iic.2 (by use fun and=>inf_le_left))]

lemma diff_eq_shifted_OSeq (m1 m2 : Monomial 3) (i : Fin 3)
  (h_diff : ∀ j, j ≠ i → m1 j ≤ m2 j) (h_strict : m2 i < m1 i) (d : ℕ) :
  OSeq_diff m1 (monomialInf m1 m2) d =
  if d < (m2 i) + 1 then 0 else
  OSeq (m1 - Finsupp.single i ((m2 i) + 1)) (d - ((m2 i) + 1)) := by
  have h_g_le : ∀ x, x ∈ divisorsFinset m1 → (x ∈ divisorsFinset (monomialInf m1 m2) ↔ x i ≤ m2 i) := by
    norm_num[divisorsFinset,monomialInf,funext_iff]
    use fun and b=>⟨inf_le_right.trans'.comp (. _),fun A B=>le_min (b _) (or_not.elim ↑(.▸A) ((b B).trans ∘h_diff B))⟩
  have h_not_g : ∀ x, x ∈ divisorsFinset m1 → (x ∉ divisorsFinset (monomialInf m1 m2) ↔ m2 i + 1 ≤ x i) := by
    exact (by rw [Nat.succ_le,h_g_le · ·, not_le])
  have h_eq : (((divisorsFinset m1) \ (divisorsFinset (monomialInf m1 m2))).filter (fun x => totalDeg x = d)) =
    (divisorsFinset m1).filter (fun x => m2 i + 1 ≤ x i ∧ totalDeg x = d) := by
    grind
  by_cases hd : d < m2 i + 1
  · rw [if_pos hd]
    delta totalDeg OSeq_diff divisorsFinset at*
    exact (congr_arg _) (h_eq.trans ( Finset.filter_false_of_mem fun and A B=>hd.not_ge (B.1.trans (B.2▸by norm_num[ Finset.single_le_sum, and.sum_of_support_subset (s:=⊤)]))))
  · rw [if_neg hd]
    push_neg at hd
    let S := (m2 i) + 1
    let A := ((divisorsFinset m1) \ (divisorsFinset (monomialInf m1 m2))).filter (fun x => totalDeg x = d)
    let B := (divisorsFinset (m1 - Finsupp.single i S)).filter (fun x => totalDeg x = d - S)
    have h_card : A.card = B.card := by
      apply Finset.card_bij (fun x _ => x - Finsupp.single i S)
      · simp_rw [A,B,divisorsFinset, S, Finset.mem_filter, Finset.mem_sdiff,totalDeg]
        norm_num[divisorsFinset,monomialInf, Finsupp.sum_of_support_subset (s:=⊤)]at h_not_g⊢
        use fun and R M true => true▸⟨R.trans (le_tsub_add), (Nat.eq_sub_of_add_eq (.trans (congr_arg _ (by norm_num[ Finsupp.single_apply, Finset.sum_add_distrib])) (Finset.sum_add_distrib.symm.trans ( Fintype.sum_congr _ _ fun and=>Nat.sub_add_cancel ?_))))⟩
        use if a:i = and then a▸.trans (by norm_num) ( (h_not_g _ R).1 M)else (by norm_num[a])
      · use fun and R L M=>tsub_left_inj (( Finsupp.single_le_iff.2 ( Finset.mem_filter.1 (h_eq.le R)).2.1)) ( (Finsupp.single_le_iff.2 (Finset.mem_filter.1 (h_eq.le M)).2.1))|>.1
      · simp_rw [B,A,divisorsFinset, S, Finset.mem_filter]
        use fun and(a)=>⟨ _,? _,add_tsub_cancel_right _ _⟩
        norm_num[totalDeg,monomialInf,and.le_def] at a⊢
        use⟨ fun and=>.trans (Nat.add_le_add_right (a.1 _) _) (by cases em<|i =and with simp_all[Nat.succ_le]),by norm_num[add_left_comm] ∘(. i)⟩,by norm_num[*, and.sum_add_index', Finsupp.sum_add_index']
    unfold OSeq OSeq_diff
    exact h_card

noncomputable def H_Z (m2 m1_star : Monomial 3) (shift : ℕ) (d : ℤ) : ℤ :=
  OSeqZ m2 d + if d < shift then 0 else OSeqZ m1_star (d - shift)

lemma H_Z_eq (m2 m1_star : Monomial 3) (shift : ℕ) (d : ℤ) :
  H_Z m2 m1_star shift d = OSeqZ m2 d + OSeqZ m1_star (d - shift) := by
  unfold H_Z OSeqZ
  split_ifs <;> omega





lemma IsUnimodal_of_Z_diff (e : ℕ) (h : ℕ → ℕ) (H : ℤ → ℤ)
  (h_eq : ∀ d : ℕ, H d = h d)
  (j k : ℤ) (h_jk : j ≤ k)
  (h_inc : ∀ d : ℤ, d ≤ j → 0 ≤ H d - H (d - 1))
  (h_dec : ∀ d : ℤ, k < d → H d - H (d - 1) ≤ 0)
  (h_concave : ∀ d : ℤ, j < d → d ≤ k → (H d - H (d - 1)) ≤ (H (d - 1) - H (d - 2))) :
  IsUnimodal e h := by
  delta IsUnimodal
  (inhabit ℝ)
  by_cases h:{R≤e|∀n< R,h n≤h (n + 1)}.Nonempty
  · refine((Set.exists_max_image _) id ((Set.finite_le_nat @e).sep _) h).imp fun and⟨ ⟨A, B⟩,C⟩=>⟨A, B,Nat.strongRec ?_⟩
    use fun a s R M=>not_lt.1 fun and' => R.not_gt.comp (C _) ⟨ M,fun K V=> (K.le_of_lt_succ V).eq_or_lt.elim (.▸le_of_lt and') fun and' =>?_⟩
    use not_lt.1 fun and=>‹‹∀ (n : ℕ),ℕ› a<_›.not_ge ?_
    use(show∀n ∈ Finset.Icc K a,(‹∀ (n : ℕ),ℕ› (n + 1):) ≤(‹∀ (n : ℕ),ℕ› n:) from fun and=>And.elim ↑(K.le_induction (by valid) ? _ _) ∘ Finset.mem_Icc.1) a (by norm_num[le_of_lt and'])
    use fun and a s R=>not_lt.1 fun and' =>absurd (h_eq (and+2) ) fun and' =>absurd (h_eq (and + 1)) fun and' =>absurd (h_concave (and+2)) (absurd (h_inc (and + 1)) ∘ fun and' =>absurd (h_dec (and+2)) ∘? _)
    exact (add_sub_cancel_right _) (1 : ℤ)▸add_sub_assoc _ _ (1: Int)▸fun A B=>by linarith![s (le_of_lt R), B (by grind),congr_arg H (add_sub_cancel_right ↑and 2),and' (by grind) (by grind),h_eq and]
  · rcases h ⟨0,bot_le, nofun⟩

lemma H_Z_eq_fun (m2 m1_star : Monomial 3) (shift : ℕ) (d : ℕ) :
  H_Z m2 m1_star shift d = OSeq m2 d + if d < shift then 0 else OSeq m1_star (d - shift) := by
  norm_num(config := {singlePass:= true})[ H_Z]
  simp_all[OSeqZ, OSeq]

lemma H_Z_inc (m2 m1_star : Monomial 3) (shift : ℕ) (h_deg : totalDeg m2 = totalDeg m1_star + shift)
  (d : ℤ) (hd : d ≤ totalDeg m2 / 2) :
  0 ≤ H_Z m2 m1_star shift d - H_Z m2 m1_star shift (d - 1) := by
  have h1 : 0 ≤ OSeqZ m2 d - OSeqZ m2 (d - 1) := OSeqZ_diff_pos m2 d (by omega)
  have h2 : 0 ≤ OSeqZ m1_star (d - shift) - OSeqZ m1_star (d - shift - 1) := OSeqZ_diff_pos m1_star (d - shift) (by omega)
  have eq1 := H_Z_eq m2 m1_star shift d
  have eq2 := H_Z_eq m2 m1_star shift (d - 1)
  have hd_shift : (d - 1) - shift = d - shift - 1 := by omega
  rw [hd_shift] at eq2
  linarith

lemma H_Z_dec (m2 m1_star : Monomial 3) (shift : ℕ) (h_deg : totalDeg m2 = totalDeg m1_star + shift)
  (d : ℤ) (hd : ((totalDeg m2 : ℤ) + shift) / 2 < d) :
  H_Z m2 m1_star shift d - H_Z m2 m1_star shift (d - 1) ≤ 0 := by
  have h1 : OSeqZ m2 d - OSeqZ m2 (d - 1) ≤ 0 := by
    have h_anti := diff_OSeqZ_anti_symm m2 d
    by_cases h_eq : 2 * ((totalDeg m2 : ℤ) - d + 1) ≤ totalDeg m2
    · have h_pos := OSeqZ_diff_pos m2 (totalDeg m2 - d + 1) h_eq
      have h_idx : ((totalDeg m2 : ℤ) - d + 1) - 1 = (totalDeg m2 : ℤ) - d := by omega
      rw [h_idx] at h_pos
      linarith
    · have hd1 : (totalDeg m2 : ℤ) - d + 1 = d := by omega
      have hd2 : (totalDeg m2 : ℤ) - d = d - 1 := by omega
      rw [hd1, hd2] at h_anti
      linarith
  have h2 : OSeqZ m1_star (d - shift) - OSeqZ m1_star (d - shift - 1) ≤ 0 := by
    have h_anti := diff_OSeqZ_anti_symm m1_star (d - shift)
    by_cases h_eq : 2 * ((totalDeg m1_star : ℤ) - (d - shift) + 1) ≤ totalDeg m1_star
    · have h_pos := OSeqZ_diff_pos m1_star (totalDeg m1_star - (d - shift) + 1) h_eq
      have h_idx : ((totalDeg m1_star : ℤ) - (d - shift) + 1) - 1 = (totalDeg m1_star : ℤ) - (d - shift) := by omega
      rw [h_idx] at h_pos
      linarith
    · have hd1 : (totalDeg m1_star : ℤ) - (d - shift) + 1 = d - shift := by omega
      have hd2 : (totalDeg m1_star : ℤ) - (d - shift) = d - shift - 1 := by omega
      rw [hd1, hd2] at h_anti
      linarith
  have eq1 := H_Z_eq m2 m1_star shift d
  have eq2 := H_Z_eq m2 m1_star shift (d - 1)
  have hd_shift : (d - 1) - shift = d - shift - 1 := by omega
  rw [hd_shift] at eq2
  linarith

lemma diff_c_seq_mono (A B : ℕ) (d1 d2 : ℤ) (h_le : d1 ≤ d2)
  (h_bounds0 : 1 ≤ d1)
  (h_bounds1 : d1 ≤ A + B + 1) (h_bounds2 : d2 ≤ A + B + 1) :
  c_seq A B d2 - c_seq A B (d2 - 1) ≤ c_seq A B d1 - c_seq A B (d1 - 1) := by
  norm_num[c_seq, mul_pow]
  grind

lemma diff_c_seq_le_diff_c_seq (A1 B1 A2 B2 : ℕ) (x : ℤ)
  (hA : A1 ≤ A2) (hB : B1 ≤ B2) (hx : x ≤ max A2 B2) :
  c_seq A1 B1 x - c_seq A1 B1 (x - 1) ≤ c_seq A2 B2 x - c_seq A2 B2 (x - 1) := by
  norm_num[c_seq ]
  grind

lemma diff_c_seq_le_zero (A B : ℕ) (x : ℤ) (hx : min A B < x) :
  c_seq A B x - c_seq A B (x - 1) ≤ 0 := by
  delta c_seq Real
  use not_lt.1 (absurd hx ∘ fun and=> (by use absurd (min_le_right (x.toNat : ℤ) A) ∘ fun and=>absurd (min_le_left ((x-1).toNat : ℤ) A) ∘by grind : ¬Nat.cast _<x))

lemma diff_c_seq_ge_zero (A B : ℕ) (x : ℤ) (hx : x ≤ max A B) :
  0 ≤ c_seq A B x - c_seq A B (x - 1) := by
  norm_num[c_seq, true,id]
  use (by valid ∘hx.trans_eq) (Nat.cast_max _ _)

lemma H_Z_concave_exact (m2 m1_star : Monomial 3)
  (hA : m1_star 0 ≤ m2 0) (hB : m1_star 1 ≤ m2 1)
  (shift : ℕ) (h_shift : shift = m2 2 + 1)
  (d : ℤ) (hd1 : (min (m2 0) (m2 1) : ℤ) < d)
  (hd2 : d - shift ≤ max (m2 0) (m2 1))
  (hd3 : d - shift - m1_star 2 - 1 ≤ max (m1_star 0) (m1_star 1)) :
  H_Z m2 m1_star shift d - H_Z m2 m1_star shift (d - 1) ≤ H_Z m2 m1_star shift (d - 1) - H_Z m2 m1_star shift (d - 2) := by
  have eq0 := H_Z_eq m2 m1_star shift d
  have eq1 := H_Z_eq m2 m1_star shift (d - 1)
  have eq2 := H_Z_eq m2 m1_star shift (d - 2)
  have h_d1 : (d - 1) - shift = d - shift - 1 := by omega
  have h_d2 : (d - 2) - shift = d - shift - 2 := by omega
  rw [h_d1] at eq1
  rw [h_d2] at eq2

  have h_diff2_1 := diff_OSeqZ_eq m2 d
  have h_diff2_2 := diff_OSeqZ_eq m2 (d - 1)
  have hd_2_1 : d - 1 - 1 = d - 2 := by omega
  rw [hd_2_1] at h_diff2_2

  have h_diff1_1 := diff_OSeqZ_eq m1_star (d - shift)
  have h_diff1_2 := diff_OSeqZ_eq m1_star (d - shift - 1)
  have hd_2_2 : d - shift - 1 - 1 = d - shift - 2 := by omega
  rw [hd_2_2] at h_diff1_2

  have h_sub1 : d - (m2 2 : ℤ) - 1 = d - shift := by omega
  have h_sub2 : d - 1 - (m2 2 : ℤ) - 1 = d - shift - 1 := by omega
  rw [h_sub1] at h_diff2_1
  rw [h_sub2] at h_diff2_2

  have hd1_eq : ↑(min (m2 0) (m2 1)) < d := by omega
  have h_c2_le_0 : c_seq (m2 0) (m2 1) d - c_seq (m2 0) (m2 1) (d - 1) ≤ 0 := diff_c_seq_le_zero (m2 0) (m2 1) d hd1_eq
  have h_c1_ge_0 : 0 ≤ c_seq (m1_star 0) (m1_star 1) (d - shift - (m1_star 2 : ℤ) - 1) - c_seq (m1_star 0) (m1_star 1) (d - shift - 1 - (m1_star 2 : ℤ) - 1) := by
    have h_idx : d - shift - 1 - (m1_star 2 : ℤ) - 1 = d - shift - (m1_star 2 : ℤ) - 1 - 1 := by omega
    rw [h_idx]
    exact diff_c_seq_ge_zero (m1_star 0) (m1_star 1) (d - shift - (m1_star 2 : ℤ) - 1) hd3

  have h_c_diff : c_seq (m1_star 0) (m1_star 1) (d - shift) - c_seq (m1_star 0) (m1_star 1) (d - shift - 1) ≤ c_seq (m2 0) (m2 1) (d - shift) - c_seq (m2 0) (m2 1) (d - shift - 1) :=
    diff_c_seq_le_diff_c_seq (m1_star 0) (m1_star 1) (m2 0) (m2 1) (d - shift) hA hB hd2

  rw [eq0, eq1, eq2]
  linarith



lemma unimodal_of_OSeq_add_shifted_exact (m2 m1_star : Monomial 3)
  (hA : m1_star 0 ≤ m2 0) (hB : m1_star 1 ≤ m2 1)
  (shift : ℕ) (h_shift : shift = m2 2 + 1)
  (h_deg : totalDeg m2 = totalDeg m1_star + shift) :
  IsUnimodal (totalDeg m2) (fun d =>
    OSeq m2 d + if d < shift then 0 else OSeq m1_star (d - shift)) := by
  apply IsUnimodal_of_Z_diff (totalDeg m2) _ (H_Z m2 m1_star shift) (j := totalDeg m2 / 2) (k := ((totalDeg m2 : ℤ) + shift) / 2)
  · intro d; exact H_Z_eq_fun m2 m1_star shift d
  · omega
  · intro d hd; exact H_Z_inc m2 m1_star shift h_deg d hd
  · intro d hd; exact H_Z_dec m2 m1_star shift h_deg d hd
  · intro d hd1 hd2
    apply H_Z_concave_exact m2 m1_star hA hB shift h_shift d
    · use min_lt_iff.2 (by match show totalDeg m2=m2 0+m2 1+m2 2by norm_num+decide[totalDeg, Finsupp.sum_of_support_subset (s:=⊤),Fin.sum_univ_three] with | S=>omega)
    · norm_num[totalDeg,h_shift] at hd2⊢
      refine (by valid ∘hd2.trans_eq ∘congr_arg fun and => (and + _)/2) ( (m2|>.sum_fintype @_ (by·subsingleton) ).trans ( Fin.sum_univ_three @_ ) )
    · norm_num[totalDeg, sub_sub] at hd2 h_deg⊢
      norm_num[totalDeg, Finsupp.sum_of_support_subset (s:=⊤), Fin.sum_univ_three] at hd1 hd2 h_deg⊢
      try ·omega

lemma IsUnimodal_eq {e : ℕ} {f g : ℕ → ℕ} (h_eq : ∀ d, f d = g d) (hf : IsUnimodal e f) : IsUnimodal e g := by
  have h : f = g := funext h_eq
  rw [← h]
  exact hf

lemma unimodal_of_OSeq_add_shifted (m2 m1_star : Monomial 3) (shift : ℕ)
  (i : Fin 3) (h_diff : ∀ j, j ≠ i → m1_star j ≤ m2 j) (h_shift : shift = m2 i + 1)
  (h_deg : totalDeg m2 = totalDeg m1_star + shift) :
  IsUnimodal (totalDeg m2) (fun d =>
    OSeq m2 d + if d < shift then 0 else OSeq m1_star (d - shift)) := by
  have hi : i.val = 0 ∨ i.val = 1 ∨ i.val = 2 := by omega
  rcases hi with h0 | h1 | h2
  · have h_i : i = 0 := Fin.ext h0
    subst h_i
    have hA : (swap02 m1_star) 0 ≤ (swap02 m2) 0 := by
      rw [swap02_0, swap02_0]
      exact h_diff 2 (by decide)
    have hB : (swap02 m1_star) 1 ≤ (swap02 m2) 1 := by
      rw [swap02_1, swap02_1]
      exact h_diff 1 (by decide)
    have h_shift_new : shift = (swap02 m2) 2 + 1 := by
      rw [swap02_2]
      exact h_shift
    have h_deg_new : totalDeg (swap02 m2) = totalDeg (swap02 m1_star) + shift := by
      rw [totalDeg_swap02, totalDeg_swap02]
      exact h_deg
    have h_uni := unimodal_of_OSeq_add_shifted_exact (swap02 m2) (swap02 m1_star) hA hB shift h_shift_new h_deg_new
    rw [totalDeg_swap02] at h_uni
    apply IsUnimodal_eq _ h_uni
    intro d
    have eq1 : OSeq m2 d = OSeq (swap02 m2) d := OSeq_swap02 m2 d
    have eq2 : OSeq m1_star (d - shift) = OSeq (swap02 m1_star) (d - shift) := OSeq_swap02 m1_star (d - shift)
    split_ifs <;> omega
  · have h_i : i = 1 := Fin.ext h1
    subst h_i
    have hA : (swap12 m1_star) 0 ≤ (swap12 m2) 0 := by
      rw [swap12_0, swap12_0]
      exact h_diff 0 (by decide)
    have hB : (swap12 m1_star) 1 ≤ (swap12 m2) 1 := by
      rw [swap12_1, swap12_1]
      exact h_diff 2 (by decide)
    have h_shift_new : shift = (swap12 m2) 2 + 1 := by
      rw [swap12_2]
      exact h_shift
    have h_deg_new : totalDeg (swap12 m2) = totalDeg (swap12 m1_star) + shift := by
      rw [totalDeg_swap12, totalDeg_swap12]
      exact h_deg
    have h_uni := unimodal_of_OSeq_add_shifted_exact (swap12 m2) (swap12 m1_star) hA hB shift h_shift_new h_deg_new
    rw [totalDeg_swap12] at h_uni
    apply IsUnimodal_eq _ h_uni
    intro d
    have eq1 : OSeq m2 d = OSeq (swap12 m2) d := OSeq_swap12 m2 d
    have eq2 : OSeq m1_star (d - shift) = OSeq (swap12 m1_star) (d - shift) := OSeq_swap12 m1_star (d - shift)
    split_ifs <;> omega
  · have h_i : i = 2 := Fin.ext h2
    subst h_i
    have hA : m1_star 0 ≤ m2 0 := h_diff 0 (by decide)
    have hB : m1_star 1 ≤ m2 1 := h_diff 1 (by decide)
    exact unimodal_of_OSeq_add_shifted_exact m2 m1_star hA hB shift h_shift h_deg

lemma unimodal_of_two_maximals_case1 (m1 m2 : Monomial 3) (i : Fin 3)
  (h_deg : totalDeg m1 = totalDeg m2)
  (h_diff : ∀ j, j ≠ i → m1 j ≤ m2 j)
  (h_strict : m2 i < m1 i) :
  IsUnimodal (totalDeg m1) (fun d => OSeq m2 d + OSeq_diff m1 (monomialInf m1 m2) d) := by
  have h1 : (fun d => OSeq m2 d + OSeq_diff m1 (monomialInf m1 m2) d) =
            (fun d => OSeq m2 d + if d < (m2 i) + 1 then 0 else OSeq (m1 - Finsupp.single i ((m2 i) + 1)) (d - ((m2 i) + 1))) := by
    funext d
    rw [diff_eq_shifted_OSeq m1 m2 i h_diff h_strict d]
  rw [h1]
  have h_deg_star : totalDeg m2 = totalDeg (m1 - Finsupp.single i ((m2 i) + 1)) + ((m2 i) + 1) := by
    norm_num[totalDeg,←h_deg]
    linear_combination2(norm:=norm_num[totalDeg, Finsupp.sum_of_support_subset (s:=⊤)])h_deg.symm
    exact ( Fintype.sum_congr _ _ fun and=>Nat.sub_add_cancel (by cases em<|i =and with simp_all[Nat.succ_le])).symm.trans ( Finset.sum_add_distrib.trans (congr_arg _ (by norm_num[ Finsupp.single_apply, Finset.sum_add_distrib])))
  have h2 := unimodal_of_OSeq_add_shifted m2 (m1 - Finsupp.single i ((m2 i) + 1)) ((m2 i) + 1) i (by exact (.trans (Nat.sub_le _ _) ∘h_diff ·)) rfl h_deg_star
  rw [← h_deg] at h2
  exact h2

lemma exists_eq_empty_or_singleton {α : Type*} [DecidableEq α] (s : Finset α) (h : s.card ≤ 1) :
  s = ∅ ∨ ∃ x, s = {x} := by
  rwa[Nat.le_one_iff_eq_zero_or_eq_one,(s).card_eq_zero,(s).card_eq_one] at h

lemma unimodal_OSeq (m : Monomial 3) : IsUnimodal (totalDeg m) (OSeq m) := by
  apply IsUnimodal_of_Z_diff (totalDeg m) (OSeq m) (OSeqZ m) (j := totalDeg m / 2) (k := totalDeg m / 2)
  · intro d; rfl
  · rfl
  · intro d hd; exact OSeqZ_diff_pos m d (by omega)
  · intro d hd
    have h_anti := diff_OSeqZ_anti_symm m d
    by_cases h_eq : 2 * ((totalDeg m : ℤ) - d + 1) ≤ totalDeg m
    · have h_pos := OSeqZ_diff_pos m (totalDeg m - d + 1) h_eq
      have h_idx : ((totalDeg m : ℤ) - d + 1) - 1 = (totalDeg m : ℤ) - d := by omega
      rw [h_idx] at h_pos
      linarith
    · have hd1 : (totalDeg m : ℤ) - d + 1 = d := by omega
      have hd2 : (totalDeg m : ℤ) - d = d - 1 := by omega
      rw [hd1, hd2] at h_anti
      linarith
  · intro d hd1 hd2
    omega

lemma unimodal_of_two_maximals_case1_wrapper (m1 m2 : Monomial 3)
  (h_deg : totalDeg m1 = totalDeg m2)
  (h_card : (Finset.univ.filter (fun i => m2 i < m1 i)).card ≤ 1) :
  IsUnimodal (totalDeg m1) (fun d => OSeq m2 d + OSeq_diff m1 (monomialInf m1 m2) d) := by
  have h_empty_or := exists_eq_empty_or_singleton _ h_card
  rcases h_empty_or with h_emp | ⟨i, hi⟩
  · have h_diff_empty : ∀ d, OSeq_diff m1 (monomialInf m1 m2) d = 0 := by delta totalDeg OSeq_diff monomialInf Monomial at *
                                                                          simp_all[divisorsFinset, true, Finset.ext_iff]
                                                                          use fun and A B R M=>R fun and=> if a:_ then(? _)else(B _).trans ( not_lt.1 a)
                                                                          cases a.false
    have h_seq : (fun d => OSeq m2 d + OSeq_diff m1 (monomialInf m1 m2) d) = OSeq m2 := by
      funext d; rw [h_diff_empty d, add_zero]
    rw [h_seq, h_deg]
    exact unimodal_OSeq m2
  · have h_diff : ∀ j, j ≠ i → m1 j ≤ m2 j := by simp_all[ Finset.ext_iff]
                                                 norm_num[ ←hi]
    have h_strict : m2 i < m1 i := by simp_all only[ Finset.eq_singleton_iff_unique_mem, false, Finset.mem_filter_univ]
    exact unimodal_of_two_maximals_case1 m1 m2 i h_deg h_diff h_strict

lemma oseq_union_eq_add_diff_symm (m1 m2 : Monomial 3) (d : ℕ) :
  OSeq m2 d + OSeq_diff m1 (monomialInf m1 m2) d =
  OSeq m1 d + OSeq_diff m2 (monomialInf m2 m1) d := by
  delta OSeq_diff OSeq
  delta totalDeg divisorsFinset monomialInf Monomial at *
  simp_rw [min_comm, Finset.inter_comm, Finset.card_filter]
  repeat rw [← Finset.sum_inter_add_sum_diff (.Iic _)<|.Iic ⟨m1.support ∩m2.support,fun i=>min (m1 i) (m2 i),fun k=> by aesop⟩]
  exact (congrArg (.+_+ _) ((congr_arg₂ _) (Finset.ext (by simp_all[·.le_def, and_comm])) rfl)).trans (add_right_comm _ _ _)

lemma unimodal_of_two_maximals (m1 m2 : Monomial 3)
  (h_deg : totalDeg m1 = totalDeg m2) :
  IsUnimodal (totalDeg m1) (fun d =>
    ((divisorsFinset m1).filter (fun m => totalDeg m = d)).card +
    ((divisorsFinset m2).filter (fun m => totalDeg m = d)).card -
    ((divisorsFinset (monomialInf m1 m2)).filter (fun m => totalDeg m = d)).card) := by
  have h_eq : (fun d => ((divisorsFinset m1).filter (fun m => totalDeg m = d)).card +
                        ((divisorsFinset m2).filter (fun m => totalDeg m = d)).card -
                        ((divisorsFinset (monomialInf m1 m2)).filter (fun m => totalDeg m = d)).card) =
              (fun d => OSeq m2 d + OSeq_diff m1 (monomialInf m1 m2) d) := by
    funext d
    rw [oseq_union_eq_add_diff m1 m2 d]
  rw [h_eq]
  have h_cases := size_S1_le_1_or_size_S2_le_1 m1 m2
  rcases h_cases with h1 | h2
  · exact unimodal_of_two_maximals_case1_wrapper m1 m2 h_deg h1
  · have h_symm : (fun d => OSeq m2 d + OSeq_diff m1 (monomialInf m1 m2) d) =
                  (fun d => OSeq m1 d + OSeq_diff m2 (monomialInf m2 m1) d) := by
      funext d
      exact oseq_union_eq_add_diff_symm m1 m2 d
    rw [h_symm]
    have h_deg_symm : totalDeg m2 = totalDeg m1 := h_deg.symm
    have h_uni := unimodal_of_two_maximals_case1_wrapper m2 m1 h_deg_symm h2
    rw [← h_deg] at h_uni
    exact h_uni
