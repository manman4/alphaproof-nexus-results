/-- Monomials in `r` variables as finitely supported exponent vectors on `Fin r`. -/
abbrev Monomial (r : ℕ) := Fin r →₀ ℕ

/-- Total degree of a monomial (sum of all exponents). -/
def totalDeg {r : ℕ} (m : Monomial r) : ℕ :=
  m.sum fun _ e => e

/-- A finite order ideal of monomials, closed downward under divisibility.
    Divisibility of monomials uses the standard pointwise `≤` on `Finsupp`. -/
structure OrderIdeal (r : ℕ) where
  carrier : Finset (Monomial r)
  downward_closed : ∀ {m n : Monomial r}, n ∈ carrier → m ≤ n → m ∈ carrier

lemma OrderIdeal.mem_of_dvd {r : ℕ} (I : OrderIdeal r) {m n : Monomial r}
    (hn : n ∈ I.carrier) (hmn : m ≤ n) : m ∈ I.carrier :=
  I.downward_closed hn hmn

/-- The finite set of divisors of a monomial, i.e. the principal lower set `{m | m ≤ g}`. -/
noncomputable def divisorsFinset {r : ℕ} (g : Monomial r) : Finset (Monomial r) :=
  Finset.Iic g

lemma mem_divisorsFinset_iff {r : ℕ} {m g : Monomial r} :
    m ∈ divisorsFinset g ↔ m ≤ g :=
  Finset.mem_Iic

/-- The finite order ideal generated by a finite set of monomials. -/
noncomputable def generatedOrderIdeal {r : ℕ} (G : Finset (Monomial r)) : OrderIdeal r where
  carrier := G.biUnion divisorsFinset
  downward_closed := by
    intro m n hn hmn
    rcases Finset.mem_biUnion.mp hn with ⟨g, hg, hng⟩
    exact Finset.mem_biUnion.mpr ⟨g, hg, mem_divisorsFinset_iff.2
      (le_trans hmn (mem_divisorsFinset_iff.1 hng))⟩

lemma mem_generatedOrderIdeal_iff {r : ℕ} {G : Finset (Monomial r)} {m : Monomial r} :
    m ∈ (generatedOrderIdeal G).carrier ↔ ∃ g ∈ G, m ≤ g := by
  constructor
  · intro hm
    rcases Finset.mem_biUnion.mp hm with ⟨g, hg, hmg⟩
    exact ⟨g, hg, mem_divisorsFinset_iff.1 hmg⟩
  · rintro ⟨g, hg, hmg⟩
    exact Finset.mem_biUnion.mpr ⟨g, hg, mem_divisorsFinset_iff.2 hmg⟩

/-- Maximality with respect to divisibility inside an order ideal. -/
def IsMaximalIn {r : ℕ} (I : OrderIdeal r) (m : Monomial r) : Prop :=
  m ∈ I.carrier ∧ ∀ n, n ∈ I.carrier → m ≤ n → n ≤ m

open Classical in
/-- The finite set of maximal monomials of an order ideal. -/
noncomputable def maximalMonomials {r : ℕ} (I : OrderIdeal r) : Finset (Monomial r) :=
  I.carrier.filter (fun m => IsMaximalIn I m)

/-- Purity: all maximal monomials have the same total degree. -/
def IsPure {r : ℕ} (I : OrderIdeal r) : Prop :=
  ∀ m n, m ∈ maximalMonomials I → n ∈ maximalMonomials I → totalDeg m = totalDeg n

/-- A pure order ideal packages an order ideal with purity and a nonempty maximal set. -/
structure PureOrderIdeal (r : ℕ) where
  ideal : OrderIdeal r
  isPure : IsPure ideal
  maximal_nonempty : (maximalMonomials ideal).Nonempty

/-- Type of a pure order ideal: the number of maximal monomials. -/
noncomputable def typePO {r : ℕ} (P : PureOrderIdeal r) : ℕ :=
  (maximalMonomials P.ideal).card

open Classical in
/-- Socle degree of a pure order ideal (the common degree of maximal monomials). -/
noncomputable def socleDegree {r : ℕ} (P : PureOrderIdeal r) : ℕ :=
  totalDeg (Classical.choose P.maximal_nonempty)

/-- The pure O-sequence: number of monomials of total degree `d` in an order ideal. -/
def pureOSequence {r : ℕ} (I : OrderIdeal r) (d : ℕ) : ℕ :=
  (I.carrier.filter fun m => totalDeg m = d).card

/-- Unimodality of a finite sequence `h` up to index `e`:
    there exists a peak `j ≤ e` such that `h` is weakly increasing
    on `[0, j]` and weakly decreasing on `[j, e]`. -/
def IsUnimodal (e : ℕ) (h : ℕ → ℕ) : Prop :=
  ∃ j, j ≤ e ∧
    (∀ i, i < j → h i ≤ h (i + 1)) ∧
    (∀ i, j ≤ i → i < e → h (i + 1) ≤ h i)

/-- Log-concavity up to degree `e`: `h_i² ≥ h_{i-1} h_{i+1}` for `i ∈ (0, e)`. -/
def IsLogConcaveUpTo (e : ℕ) (h : ℕ → ℕ) : Prop :=
  ∀ i ∈ Finset.Ioo 0 e, h (i - 1) * h (i + 1) ≤ (h i) ^ 2


/-- The monomial `xyz` encoded as an exponent vector in 3 variables. -/
noncomputable def mXYZ : Monomial 3 :=
  Finsupp.single (0 : Fin 3) 1 + Finsupp.single (1 : Fin 3) 1 + Finsupp.single (2 : Fin 3) 1

/-- The monomial `xz^2` encoded as an exponent vector in 3 variables. -/
noncomputable def mXZ2 : Monomial 3 :=
  Finsupp.single (0 : Fin 3) 1 + Finsupp.single (2 : Fin 3) 2

/-- The order ideal generated by the two monomials from P1. -/
noncomputable def GammaP1 : OrderIdeal 3 :=
  generatedOrderIdeal ({mXYZ, mXZ2} : Finset (Monomial 3))

/-- P1 statement: the degree-counting values for the generated order ideal are `(1, 3, 4, 2)`. -/
def ProblemP1 : Prop :=
  pureOSequence GammaP1 0 = 1 ∧
  pureOSequence GammaP1 1 = 3 ∧
  pureOSequence GammaP1 2 = 4 ∧
  pureOSequence GammaP1 3 = 2

-- Reformulation choice for P2:
-- instead of formal power series, we encode the generating-function claim at the
-- coefficient level using degree counts of divisors of the single generator.
/-- P2 (coefficient-level): one-generator degree counts match the product-formula coefficients. -/
def ProblemP2CoeffFormula : Prop :=
  ∀ {r : ℕ} (g : Monomial r) (d : ℕ),
    pureOSequence (generatedOrderIdeal ({g} : Finset (Monomial r))) d =
      ((divisorsFinset g).filter fun m => totalDeg m = d).card

/-- P2 consequence: every type-1 pure O-sequence is unimodal. -/
def ProblemP2Type1Unimodal : Prop :=
  ∀ {r : ℕ} (P : PureOrderIdeal r), typePO P = 1 →
    IsUnimodal (socleDegree P) (pureOSequence P.ideal)

/-- P2 consequence: every type-1 pure O-sequence is log-concave. -/
def ProblemP2Type1LogConcave : Prop :=
  ∀ {r : ℕ} (P : PureOrderIdeal r), typePO P = 1 →
    IsLogConcaveUpTo (socleDegree P) (pureOSequence P.ideal)

/-- P2 statement, split into a coefficient-level formula plus two sequence consequences. -/
def ProblemP2 : Prop :=
  ProblemP2CoeffFormula ∧ ProblemP2Type1Unimodal ∧ ProblemP2Type1LogConcave

/-- P3 statement: in codimension 3, first-half log-concavity up to `e / 2`.
Here `e` is the socle degree of the pure order ideal. -/
def ProblemP3 : Prop :=
  ∀ (P : PureOrderIdeal 3) (i : ℕ),
    0 < i →
    i ≤ socleDegree P / 2 →
      pureOSequence P.ideal (i - 1) * pureOSequence P.ideal (i + 1) ≤
        (pureOSequence P.ideal i) ^ 2

/-- P4 statement: codimension 3 and type 2 imply unimodality. -/
def ProblemP4 : Prop :=
  ∀ (P : PureOrderIdeal 3),
    typePO P = 2 →
    IsUnimodal (socleDegree P) (pureOSequence P.ideal)

/-- Helper predicate for open problems about non-log-concavity at fixed codimension/type. -/
def ExistsNonLogConcavePureOSeq (r t : ℕ) : Prop :=
  ∃ P : PureOrderIdeal r, typePO P = t ∧
    ¬ IsLogConcaveUpTo (socleDegree P) (pureOSequence P.ideal)

/-- P5: in codimension `3`, every type-`2` pure O-sequence is log-concave. -/
def ProblemP5 : Prop :=
  ∀ (P : PureOrderIdeal 3),
    typePO P = 2 →
    IsLogConcaveUpTo (socleDegree P) (pureOSequence P.ideal)

/-- P6: for fixed `r ≥ 5`, every type-`2` pure O-sequence in codimension `r` is unimodal. -/
def ProblemP6 (r : ℕ) : Prop :=
  5 ≤ r →
    ∀ (P : PureOrderIdeal r),
      typePO P = 2 →
      IsUnimodal (socleDegree P) (pureOSequence P.ideal)

/-- P7: threshold existence for eventual log-concavity failure in codimension `r`. -/
def ProblemP7 (r : ℕ) : Prop :=
  3 ≤ r →
    ∃ T : ℕ, 1 ≤ T ∧ ∀ t : ℕ, T ≤ t → ExistsNonLogConcavePureOSeq r t

/-- Helper: `t0` is a threshold after which all types admit a non-log-concave example. -/
def LCFailureThreshold (r t0 : ℕ) : Prop :=
  ∀ t : ℕ, t0 ≤ t → ExistsNonLogConcavePureOSeq r t

/-- P8: least threshold for eventual log-concavity failure in codimension `r`. -/
def ProblemP8 (r : ℕ) : Prop :=
  3 ≤ r →
    ∃ t0 : ℕ, IsLeast {t : ℕ | LCFailureThreshold r t} t0

