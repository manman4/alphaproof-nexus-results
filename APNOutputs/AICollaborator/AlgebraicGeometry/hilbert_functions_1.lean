noncomputable def m110 : Monomial 3 := Finsupp.single 0 1 + Finsupp.single 1 1
noncomputable def m101 : Monomial 3 := Finsupp.single 0 1 + Finsupp.single 2 1
noncomputable def m011 : Monomial 3 := Finsupp.single 1 1 + Finsupp.single 2 1
noncomputable def m002 : Monomial 3 := Finsupp.single 2 2

lemma GammaP1_0 : pureOSequence GammaP1 0 = 1 := by
  delta GammaP1 pureOSequence
  norm_num[generatedOrderIdeal,totalDeg, Finset.card_eq_one, Finset.ext_iff]
  norm_num[mXYZ, or_and_right,divisorsFinset, true,mXZ2, Finsupp.sum_of_support_subset (s:=⊤)]
  use(0),by bound

lemma GammaP1_1 : pureOSequence GammaP1 1 = 3 := by
  delta GammaP1 pureOSequence
  norm_num [generatedOrderIdeal, totalDeg, false, Finset.card_eq_three, true, Finset.ext_iff]
  delta mXYZ mXZ2 divisorsFinset Monomial
  use .single 0 1,.single 1 1,by simp_all ∘congr_arg (. 1),.single 2 1,by simp_all ∘congr_arg (. 0),by simp_all ∘congr_arg (. 1), fun and=>⟨ fun and=>? _,?_⟩
  · simp_all[ Finsupp.sum_of_support_subset (s:=⊤), Fin.sum_univ_three _, Finsupp.ext_iff,Nat.add_eq_one_iff, Fin.forall_iff_succ]
    match h : ‹Fin 3 →₀ ℕ› 0 with | 0 => omega | 1 => omega | n + 2 => omega
  · simp_all[add_assoc, or_imp]

lemma GammaP1_2 : pureOSequence GammaP1 2 = 4 := by
  have h_set : (GammaP1.carrier.filter fun m => totalDeg m = 2) = {m110, m101, m011, m002} := by
    norm_num[m110,GammaP1,m101,m011,min_mul,totalDeg, false, Finset.ext_iff]
    conv_rhs =>norm_num[mXYZ,generatedOrderIdeal, true, mXZ2, Fin.sum_univ_three _, Finsupp.sum_of_support_subset (s:=⊤)]
    conv_rhs=>norm_num+decide[divisorsFinset, or_and_right,Monomial,←List.ofFn_inj, Finsupp.ext_iff, Fin.forall_iff_succ]
    norm_num+decide[m002,Monomial,←or_and_right,←and_or_left,←or_assoc, Finsupp.le_def, Fin.forall_iff_succ]
    omega
  rw [pureOSequence, h_set]
  simp_all[m110,m101,m011,m002]
  simp_all-contextual[ Finsupp.ext_iff, Fin.forall_iff_succ]

lemma GammaP1_3 : pureOSequence GammaP1 3 = 2 := by
  simp_all![GammaP1]
  simp_all! -contextual[mXYZ, true,generatedOrderIdeal, true, mXZ2]
  norm_num[pureOSequence]
  norm_num[divisorsFinset,totalDeg, false, Finset.card_eq_two, false, Finset.ext_iff]
  use .single 0 (1)+.single 1 1+.single 2 1,.single 0 (1)+.single 2 2,by simp_all ∘congr_arg (. 2),fun c=>⟨ fun and=>and.1.imp ( fun and=>c.ext ? _) fun and=>? _,?_⟩
  · use (and ·|>.eq_of_not_lt (mt (Finset.sum_lt_sum (fun R L=>and R) ⟨ _, Finset.mem_univ _,.⟩) (by simp_all[c.sum_of_support_subset (s:=⊤), Fin.sum_univ_three])))
  · simp_all[c.sum_of_support_subset (s:=⊤),c.ext_iff, Fin.sum_univ_three, Fin.forall_iff_succ]
    exact (by match (and (1)).trans (by ·norm_num +decide:_≤0), (and (2)).trans (by·norm_num+decide:(2)≥ _), (and 0).trans (by ·norm_num+decide:_ ≤ 1) with |_, _A, B=>omega)
  · simp_all[Finsupp.sum_add_index',or_imp]
